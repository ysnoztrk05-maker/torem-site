---
import '../styles/global.css';
import { kategoriler } from '../data/faaliyet-alanlari';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  schema?: object | object[];
  noindex?: boolean;
  heroPreload?: string;
}

const {
  title,
  description = 'Torem Zemin Mühendislik — Geoteknik çözümler, fore kazık, ankraj, jet grout ve zemin iyileştirme uygulamaları.',
  canonical = Astro.url.href,
  ogImage = '/og-default.jpg',
  ogType = 'website',
  schema,
  noindex = false,
  heroPreload,
} = Astro.props;

const siteUrl = 'https://www.toremzemin.com';
const ogImageAbs = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const phone    = '+90 531 659 46 36';
const phoneTel = 'tel:+905316594636';
const email    = 'info@toremzemin.com';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Torem Zemin Mühendislik',
  url: siteUrl,
  telephone: '+905316594636',
  email,
  address: { '@type': 'PostalAddress', addressLocality: 'Pendik', addressRegion: 'Istanbul', addressCountry: 'TR' },
  areaServed: 'Türkiye',
  knowsAbout: ['Geoteknik Mühendislik','Zemin İyileştirme','Fore Kazık','Jet Grout','Öngermeli Ankraj','Mini Kazık','Zemin Çivisi','Püskürtme Beton','İksa Sistemleri'],
  sameAs: ['https://www.linkedin.com/company/toremzemin','https://www.instagram.com/toremzemin'],
};

const schemas = [orgSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];

const nav = [
  { label: 'Ana Sayfa',         href: '/' },
  {
    label: 'Kurumsal',
    href: '/kurumsal/',
    dropdown: [
      { label: 'Hakkımızda',        href: '/kurumsal/' },
      { label: 'Neden Torem?',      href: '/kurumsal/neden-torem/' },
      { label: 'Ekibimiz',          href: '/kurumsal/ekibimiz/' },
      { label: 'Belgelerimiz',      href: '/kurumsal/belgelerimiz/' },
      { label: '—', href: '' },
      { label: 'KVKK Aydınlatma',   href: '/yasal/kvkk-aydinlatma/' },
      { label: 'Gizlilik Politikası', href: '/yasal/gizlilik-politikasi/' },
      { label: 'Çerez Politikası',  href: '/yasal/cerez-politikasi/' },
    ],
  },
  { label: 'Faaliyet Alanları', href: '/faaliyet-alanlari/', mega: true },
  { label: 'Projelerimiz',      href: '/projelerimiz/' },
  { label: 'Makine Parkı',      href: '/makine-parki/' },
  { label: 'Blog',              href: '/blog/' },
  { label: 'İletişim',          href: '/iletisim/' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#002147" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <link rel="canonical" href={canonical} />
  <meta property="og:type"        content={ogType} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:image"       content={ogImageAbs} />
  <meta property="og:locale"      content="tr_TR" />
  <meta property="og:site_name"   content="Torem Zemin Mühendislik" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {heroPreload && (
    <link
      rel="preload"
      as="image"
      href={heroPreload}
      type="image/webp"
      fetchpriority="high"
    />
  )}
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,700;1,9..144,500&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,700;1,9..144,500&display=swap" />
  {schemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body>
  <a class="skip-link" href="#main-content">İçeriğe geç</a>

  <div class="topbar">
    <div class="container topbar__inner">
      <a href={phoneTel} class="topbar__link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {phone}
      </a>
      <a href={`mailto:${email}`} class="topbar__link topbar__link--email">{email}</a>
    </div>
  </div>

  <header class="site-header" id="site-header">
    <div class="container site-header__inner">
      <a href="/" class="site-logo" aria-label="Torem Zemin Ana Sayfa">
        <span class="site-logo__bar"></span>
        <span class="site-logo__torem">Torem</span>
        <span class="site-logo__zemin">Zemin</span>
      </a>

      <nav class="site-nav" id="site-nav" aria-label="Ana Menu">
        <ul class="site-nav__list">
          {nav.map(({ label, href, mega, dropdown }: any) => (
            <li class={`site-nav__item${mega ? ' site-nav__item--mega' : ''}${dropdown ? ' site-nav__item--dropdown' : ''}`}>
              <a
                href={href}
                class={`site-nav__link${currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? ' site-nav__link--active' : ''}`}
              >
                {label}
                {(mega || dropdown) && (
                  <svg class="nav-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M2 4l3 3 3-3"/>
                  </svg>
                )}
              </a>

              {/* Dropdown menü — Kurumsal gibi küçük alt menüler */}
              {dropdown && (
                <div class="dropdown-menu">
                  {dropdown.map((item: any) =>
                    item.href === '' ? (
                      <hr class="dropdown-menu__sep" />
                    ) : (
                      <a
                        href={item.href}
                        class={`dropdown-menu__link${currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) ? ' dropdown-menu__link--active' : ''}`}
                      >
                        {item.label}
                      </a>
                    )
                  )}
                </div>
              )}

              {/* Mega menü — Faaliyet Alanları */}
              {mega && (
                <div class="mega-menu">
                  <div class="mega-menu__panel">
                    <div class="mega-menu__grid">
                      {kategoriler.map((k) => (
                        <a href={`/faaliyet-alanlari/${k.slug}/`} class="mega-menu__item">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20" aria-hidden="true"><path d={k.icon}/></svg>
                          <span>{k.title}</span>
                        </a>
                      ))}
                    </div>
                    <div class="mega-menu__footer">
                      <a href="/faaliyet-alanlari/" class="mega-menu__all">Tüm Faaliyet Alanları</a>
                    </div>
                  </div>
                </div>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <a href="/iletisim/" class="btn btn--primary site-header__cta">Teklif Al</a>

      <button class="mobile-toggle" id="mobile-toggle" aria-controls="site-nav" aria-expanded="false" aria-label="Menuyu ac/kapat">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <main id="main-content"><slot /></main>

  <section class="cta-band">
    <div class="cta-band__top-line" aria-hidden="true"></div>
    <div class="container cta-band__inner">
      <div>
        <span class="cta-band__badge">Hızlı Yanıt Garantisi</span>
        <h2 class="cta-band__title">Projeniz İçin Profesyonel Çözüm mü Arıyorsunuz?</h2>
        <p class="cta-band__sub">Uzman ekibimizle zemin mühendisliği projelerinizi güvenle hayata geçirin.</p>
      </div>
      <div class="cta-band__actions">
        <a href="/iletisim/" class="btn btn--primary btn--lg">Ücretsiz Keşif Raporu Alın</a>
        <a href={phoneTel} class="btn btn--outline btn--lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {phone}
        </a>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container site-footer__grid">
      <div class="site-footer__about">
        <a href="/" class="site-footer__logo" aria-label="Torem Zemin Ana Sayfa">
          <span class="site-footer__logo-bar"></span>
          <span class="site-footer__logo-torem">Torem</span>
          <span class="site-footer__logo-zemin">Zemin</span>
        </a>
        <p>Temelden Zirveye Uzanan Çözümler. 13+ yıllık deneyimle geoteknik mühendisliğin güvenilir adresi.</p>
        <div class="site-footer__social">
          <a href="https://www.linkedin.com/company/toremzemin" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://www.instagram.com/toremzemin" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
          <a href="https://www.youtube.com/@toremzemin" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>
      <div>
        <h4>Faaliyet Alanları</h4>
        <ul class="site-footer__links">
          <li><a href="/faaliyet-alanlari/kazikli-temeller/">Kazıklı Temeller</a></li>
          <li><a href="/faaliyet-alanlari/iksa-sistemleri/">İksa Sistemleri</a></li>
          <li><a href="/faaliyet-alanlari/zemin-iyilestirme/">Zemin İyileştirme</a></li>
          <li><a href="/faaliyet-alanlari/destekleme-ankraj/">Destekleme ve Ankraj</a></li>
          <li><a href="/faaliyet-alanlari/sev-stabilitesi/">Şev Stabilitesi</a></li>
          <li><a href="/faaliyet-alanlari/geoteknik-proje/">Geoteknik Proje</a></li>
        </ul>
      </div>
      <div>
        <h4>Kurumsal</h4>
        <ul class="site-footer__links">
          <li><a href="/kurumsal/">Hakkımızda</a></li>
          <li><a href="/projelerimiz/">Projelerimiz</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/iletisim/">İletişim</a></li>
          <li><a href="/yasal/kvkk-aydinlatma/">KVKK Aydınlatma</a></li>
          <li><a href="/yasal/gizlilik-politikasi/">Gizlilik Politikası</a></li>
          <li><a href="/yasal/cerez-politikasi/">Çerez Politikası</a></li>
        </ul>
      </div>
      <div>
        <h4>İletişim</h4>
        <ul class="site-footer__contact">
          <li><a href={phoneTel}>{phone}</a></li>
          <li><a href="tel:+902163793310">+90 216 379 33 10</a></li>
          <li><a href={`mailto:${email}`}>{email}</a></li>
          <li>Pendik, İstanbul</li>
        </ul>
      </div>
    </div>
    <div class="site-footer__bottom">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Torem Zemin Mühendislik. Tüm hakları saklıdır.</p>
      </div>
    </div>
  </footer>

  <!-- FAB Group: Scroll-top + WhatsApp -->
  <div class="fab-group">
    <button class="scroll-top" id="scroll-top" aria-label="Sayfa başına dön">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="20" height="20" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg>
    </button>
    <a href="https://wa.me/905316594636" class="whatsapp-fab" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp ile iletişime geçin">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="28" height="28"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </a>
  </div>

  <script>
    // Scroll to top
    const scrollBtn = document.getElementById('scroll-top');
    window.addEventListener('scroll', () => {
      scrollBtn?.classList.toggle('is-visible', window.scrollY >= 300);
    }, { passive: true });
    scrollBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    const toggle = document.getElementById('mobile-toggle');
    const navEl  = document.getElementById('site-nav');
    toggle?.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      navEl?.classList.toggle('site-nav--open', !open);
    });

    const megaLink = document.querySelector('.site-nav__item--mega .site-nav__link');
    const megaMenu = document.querySelector('.site-nav__item--mega .mega-menu');
    megaLink?.addEventListener('click', (e) => {
      if (window.innerWidth <= 900) {
        e.preventDefault();
        megaMenu?.classList.toggle('mega-menu--open');
      }
    });

    const header   = document.getElementById('site-header');
    const sentinel = document.createElement('div');
    document.body.prepend(sentinel);
    new IntersectionObserver(
      ([e]) => header?.classList.toggle('site-header--scrolled', !e.isIntersecting),
      { rootMargin: '-1px 0px 0px 0px', threshold: [1] }
    ).observe(sentinel);

    // Scroll Reveal
    const reveals = document.querySelectorAll('.reveal, .reveal-left, .reveal-scale');
    if (reveals.length > 0 && 'IntersectionObserver' in window) {
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              entry.target.classList.add('visible');
            }, i * 80);
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -50px 0px' });
      reveals.forEach((el) => revealObserver.observe(el));
    }
  </script>
</body>
</html>

<style>
.skip-link { position:absolute; top:-100%; left:0; background:var(--color-highlight); color:#fff; padding:var(--s-2) var(--s-4); z-index:9999; font-weight:600; }
.skip-link:focus { top:0; }

/* Topbar */
.topbar { background:var(--color-primary); color:rgba(255,255,255,.75); font-size:var(--text-sm); padding-block:.4rem; }
.topbar__inner { display:flex; justify-content:space-between; align-items:center; gap:var(--s-4); }
.topbar__link { display:flex; align-items:center; gap:var(--s-2); transition:color var(--t-fast); }
.topbar__link:hover { color:#fff; }
.topbar__link--email { display:none; }
@media(min-width:640px){ .topbar__link--email { display:flex; } }

/* Header */
.site-header {
  position:sticky; top:0;
  z-index:500;              /* sayfa icerigi uzerinde */
  background:var(--color-white);
  border-bottom:1px solid var(--color-border);
  transition:box-shadow var(--t-base);
}
.site-header--scrolled { box-shadow:var(--shadow-md); }
.site-header__inner {
  display:flex; align-items:center; gap:var(--s-6);
  height:var(--header-h);
  overflow:visible;         /* mega menu kesilmesin */
}

/* Logo */
.site-logo {
  display:flex;
  align-items:center;
  gap:0;
  flex-shrink:0;
  text-decoration:none;
}
.site-logo__bar {
  display:block;
  width:3px;
  height:1.8rem;
  background:var(--color-highlight);
  border-radius:2px;
  margin-right:12px;
  flex-shrink:0;
}
.site-logo__torem {
  font-size:1.875rem;
  font-weight:800;
  color:#002147;
  letter-spacing:0.1em;
  line-height:1;
  text-transform:uppercase;
}
.site-logo__zemin {
  font-size:1.875rem;
  font-weight:800;
  color:#d4af37;
  letter-spacing:0.1em;
  line-height:1;
  text-transform:uppercase;
  margin-left:0.3em;
}

/* Nav */
.site-nav { margin-left:auto; overflow:visible; }
.site-nav__list { display:flex; align-items:center; gap:var(--s-1); overflow:visible; }
.site-nav__item { overflow:visible; }
.site-nav__link {
  display:flex; align-items:center; gap:4px;
  padding:var(--s-2) var(--s-3);
  border-radius:var(--r-md);
  font-size:var(--text-sm); font-weight:500;
  color:var(--color-text);
  transition:background var(--t-fast), color var(--t-fast);
  white-space:nowrap;
}
.site-nav__link:hover,
.site-nav__link--active { background:var(--color-highlight-10); color:var(--color-highlight); }
.site-header__cta { flex-shrink:0; }

.mobile-toggle { display:none; flex-direction:column; gap:5px; padding:var(--s-2); border-radius:var(--r-md); margin-left:auto; }
