---
export interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaSecondaryText?: string;
  ctaSecondaryHref?: string;
  tag?: string;
  fullHeight?: boolean;
}

const {
  title,
  subtitle,
  ctaText = 'Ücretsiz Keşif Raporu Alın',
  ctaHref = '/iletisim/',
  ctaSecondaryText,
  ctaSecondaryHref,
  tag,
  fullHeight = false,
} = Astro.props;
---

<section class={`hero${fullHeight ? ' hero--full' : ''}`}>
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="container hero__inner">
    {tag && <p class="hero__tag">{tag}</p>}
    <h1 class="hero__title" set:html={title} />
    {subtitle && <p class="hero__subtitle">{subtitle}</p>}
    <div class="hero__actions">
      <a href={ctaHref} class="btn btn--primary btn--lg">{ctaText}</a>
      {ctaSecondaryText && ctaSecondaryHref && (
        <a href={ctaSecondaryHref} class="btn btn--outline btn--lg">{ctaSecondaryText}</a>
      )}
    </div>
  </div>
  <div class="hero__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="var(--color-bg)" />
    </svg>
  </div>
</section>

<style>
.hero {
  position: relative;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  color: var(--color-white);
  padding-block: var(--s-24) var(--s-20);
  overflow: hidden;
  text-align: center;
}
.hero--full { min-height: 70vh; display: flex; flex-direction: column; justify-content: center; }

/* Subtle geometric background pattern */
.hero__bg {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle at 20% 50%, rgba(74,127,165,0.15) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(200,135,58,0.1) 0%, transparent 40%);
  pointer-events: none;
}

.hero__inner {
  position: relative;
  z-index: 1;
  max-width: 820px;
  margin-inline: auto;
}

.hero__tag {
  display: inline-block;
  background: rgba(200,135,58,0.2);
  color: var(--color-highlight-light, #E8A85A);
  border: 1px solid rgba(200,135,58,0.4);
  padding: 0.35rem 1rem;
  border-radius: 999px;
  font-size: var(--text-sm);
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: var(--s-5);
}

.hero__title {
  color: var(--color-white);
  font-size: var(--text-5xl);
  line-height: 1.15;
  margin-bottom: var(--s-5);
}
.hero__title :global(em) {
  font-style: normal;
  color: var(--color-highlight-light, #E8A85A);
}

.hero__subtitle {
  color: rgba(255,255,255,0.8);
  font-size: var(--text-xl);
  line-height: 1.7;
  margin-bottom: var(--s-8);
  max-width: 620px;
  margin-inline: auto;
}

.hero__actions {
  display: flex;
  justify-content: center;
  gap: var(--s-4);
  flex-wrap: wrap;
}

.hero__wave {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60px;
  line-height: 0;
}
.hero__wave svg { width: 100%; height: 100%; }

@media (max-width: 640px) {
  .hero { padding-block: var(--s-16) var(--s-16); }
  .hero__title { font-size: var(--text-4xl); }
  .hero__subtitle { font-size: var(--text-lg); }
  .hero__actions { flex-direction: column; align-items: center; }
  .hero__actions .btn { width: 100%; justify-content: center; }
}
</style>
