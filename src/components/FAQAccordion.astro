---
export interface FAQItem {
  question: string;
  answer: string;
}

export interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title = 'Sıkça Sorulan Sorular' } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};
---

<section class="faq section">
  <div class="container">
    <h2 class="faq__title text-center">{title}</h2>
    <div class="faq__list">
      {items.map(({ question, answer }, i) => (
        <div class="faq__item" id={`faq-${i}`}>
          <button
            class="faq__question"
            aria-expanded="false"
            aria-controls={`faq-answer-${i}`}
          >
            <span>{question}</span>
            <svg class="faq__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </button>
          <div class="faq__answer" id={`faq-answer-${i}`} hidden>
            <p>{answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
.faq__title { margin-bottom: var(--s-10); }
.faq__list  { max-width: var(--content-width); margin-inline: auto; display: flex; flex-direction: column; gap: var(--s-3); }

.faq__item { border: 1px solid var(--color-border); border-radius: var(--r-md); overflow: hidden; }

.faq__question {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--s-4);
  padding: var(--s-5) var(--s-6);
  background: var(--color-bg-alt);
  font-weight: 600;
  font-size: var(--text-base);
  color: var(--color-primary);
  text-align: left;
  transition: background var(--t-fast);
  cursor: pointer;
  border: none;
}
.faq__question:hover { background: var(--color-border); }
.faq__question[aria-expanded="true"] { background: var(--color-primary); color: var(--color-white); }
.faq__question[aria-expanded="true"] .faq__icon { stroke: var(--color-highlight); transform: rotate(180deg); }

.faq__icon { flex-shrink: 0; transition: transform var(--t-base); }

.faq__answer {
  padding: var(--s-5) var(--s-6);
  background: var(--color-white);
  border-top: 1px solid var(--color-border);
}
.faq__answer p { margin: 0; color: var(--color-text-muted); line-height: 1.8; }

@media (max-width: 560px) {
  .faq__title { margin-bottom: var(--s-6); }
  .faq__list { gap: var(--s-2); }
  .faq__question { padding: var(--s-4); font-size: var(--text-sm); gap: var(--s-3); }
  .faq__icon { width: 18px; height: 18px; }
  .faq__answer { padding: var(--s-4); }
  .faq__answer p { font-size: var(--text-sm); line-height: 1.7; }
}
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq__question').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answerId = btn.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId);

      // Close all others
      document.querySelectorAll<HTMLButtonElement>('.faq__question').forEach((b) => {
        b.setAttribute('aria-expanded', 'false');
        const id = b.getAttribute('aria-controls')!;
        document.getElementById(id)?.setAttribute('hidden', '');
      });

      if (!expanded && answer) {
        btn.setAttribute('aria-expanded', 'true');
        answer.removeAttribute('hidden');
      }
    });
  });
</script>
