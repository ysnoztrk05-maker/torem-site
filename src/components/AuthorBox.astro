---
export interface Props {
  name?: string;
  credentials?: string;
  date?: string;
}

const {
  name = 'Torem Zemin Mühendislik Birimi',
  credentials = '13+ Yıllık Zemin İyileştirme ve Geoteknik Deneyimi',
  date,
} = Astro.props;
---

<div class="author-box">
  <div class="author-box__avatar" aria-hidden="true">
    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="20" cy="20" r="20" fill="var(--color-secondary)"/>
      <path d="M20 20a6 6 0 1 0 0-12 6 6 0 0 0 0 12zm0 2c-6.627 0-12 2.686-12 6v1h24v-1c0-3.314-5.373-6-12-6z" fill="white" opacity="0.85"/>
    </svg>
  </div>
  <div class="author-box__info">
    <strong>{name}</strong>
    <span>{credentials}</span>
    {date && <time datetime={date} class="author-box__date">Son güncelleme: {date}</time>}
  </div>
</div>

<style>
.author-box {
  display: flex;
  align-items: center;
  gap: var(--s-4);
  padding: var(--s-4) var(--s-5);
  background: var(--color-white);
  border-left: 4px solid var(--color-highlight);
  border-radius: var(--r-sm);
  margin-bottom: var(--s-6);
  box-shadow: var(--shadow-sm);
}
.author-box__avatar { width: 40px; height: 40px; flex-shrink: 0; border-radius: 50%; overflow: hidden; }
.author-box__info { display: flex; flex-direction: column; gap: 2px; font-size: var(--text-sm); }
.author-box__info strong { color: var(--color-primary); font-weight: 600; }
.author-box__info span   { color: var(--color-text-muted); font-style: italic; }
.author-box__date        { color: var(--color-text-muted); }
</style>
