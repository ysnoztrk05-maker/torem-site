---
export interface Props {
  title?: string;
  text?: string;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  title = 'Projeniz İçin Ücretsiz Keşif Raporu Alın',
  text = 'Deneyimli mühendis ekibimiz zemin etüdünden projelendirmeye kadar tüm aşamalarda yanınızda.',
  primaryText = 'Hemen İletişime Geçin',
  primaryHref = '/iletisim/',
  secondaryText = '+90 531 659 46 36',
  secondaryHref = 'tel:+905316594636',
} = Astro.props;
---

<div class="cta-box">
  <div class="cta-box__accent" aria-hidden="true"></div>
  <h3 class="cta-box__title">{title}</h3>
  <p class="cta-box__text">{text}</p>
  <div class="cta-box__actions">
    <a href={primaryHref} class="btn btn--primary">{primaryText}</a>
    {secondaryText && (
      <a href={secondaryHref} class="btn btn--outline">{secondaryText}</a>
    )}
  </div>
</div>

<style>
.cta-box {
  background: linear-gradient(135deg, var(--color-navy-dark, #001530) 0%, var(--color-primary) 100%);
  color: var(--color-white);
  border-radius: var(--r-xl);
  padding: var(--s-10) var(--s-12);
  text-align: center;
  margin-block: var(--s-10);
  position: relative;
  overflow: hidden;
}
/* Gold top accent line */
.cta-box__accent {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent, var(--color-highlight), transparent);
}
.cta-box__title {
  color: var(--color-white);
  font-size: var(--text-2xl);
  margin-bottom: var(--s-3);
}
.cta-box__text {
  color: rgba(255,255,255,0.75);
  margin-bottom: var(--s-6);
  max-width: 540px;
  margin-inline: auto;
}
.cta-box__actions {
  display: flex;
  justify-content: center;
  gap: var(--s-4);
  flex-wrap: wrap;
}
@media (max-width: 560px) {
  .cta-box { padding: var(--s-8) var(--s-6); }
  .cta-box__actions { flex-direction: column; align-items: center; }
}
</style>
