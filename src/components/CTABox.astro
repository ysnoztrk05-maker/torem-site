---
export interface Props {
  variant?: 'inline' | 'footer';
  title?: string;
  text?: string;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  variant = 'inline',
  title = 'Projeniz İçin Ücretsiz Keşif Raporu Alın',
  text = 'Deneyimli mühendis ekibimiz zemin etüdünden projelendirmeye kadar tüm aşamalarda yanınızda.',
  primaryText = 'Hemen İletişime Geçin',
  primaryHref = '/iletisim/',
  secondaryText = '+90 531 659 46 36',
  secondaryHref = 'tel:+905316594636',
} = Astro.props;
---

<div class={`cta-box cta-box--${variant}`}>
  <div class="cta-box__accent" aria-hidden="true"></div>
  <div class="cta-box__content">
    <h3 class="cta-box__title">{title}</h3>
    {text && <p class="cta-box__text">{text}</p>}
  </div>
  <div class="cta-box__actions">
    <a href={primaryHref} class="btn btn--primary">{primaryText}</a>
    {secondaryText && (
      <a href={secondaryHref} class="btn btn--outline">{secondaryText}</a>
    )}
  </div>
</div>

<style>
/* ── Ortak temel ─────────────────────────────────────────── */
.cta-box {
  border-radius: var(--r-xl);
  padding: var(--s-10) var(--s-12);
  margin-block: var(--s-10);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--s-8);
  text-align: left;
}
.cta-box__content {
  flex: 1;
}
.cta-box__actions {
  display: flex;
  gap: var(--s-4);
  flex-wrap: wrap;
  flex-shrink: 0;
  align-items: center;
}

/* ── inline variant — hafif kart (default) ──────────────── */
.cta-box--inline {
  background: #fff;
  border: 1px solid rgba(212,175,55,.25);
  box-shadow: 0 4px 24px rgba(0,0,0,.06);
}
.cta-box--inline .cta-box__accent { 
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6px;
  background: var(--color-highlight);
}
.cta-box--inline .cta-box__title {
  color: var(--color-primary);
  font-size: var(--text-2xl);
  font-weight: 700;
  margin-bottom: var(--s-2);
  line-height: 1.3;
}
.cta-box--inline .cta-box__text {
  color: var(--color-text-muted);
  max-width: 640px;
  font-size: var(--text-base);
  line-height: 1.6;
}

/* ── footer variant — koyu gradyan ─────────────────────── */
.cta-box--footer {
  background: linear-gradient(135deg, var(--color-navy-dark, #001530) 0%, var(--color-primary) 100%);
  color: var(--color-white);
  box-shadow: 0 20px 40px rgba(0,21,48,0.15);
}
.cta-box--footer .cta-box__accent {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: linear-gradient(90deg, transparent, var(--color-highlight), transparent);
}
.cta-box--footer .cta-box__title {
  color: var(--color-white);
  font-size: var(--text-2xl);
  font-weight: 700;
  margin-bottom: var(--s-2);
}
.cta-box--footer .cta-box__text {
  color: rgba(255,255,255,0.8);
  max-width: 640px;
  font-size: var(--text-base);
  line-height: 1.6;
}
.cta-box--footer .btn--outline {
  border-color: rgba(255,255,255,0.2);
  color: white;
}
.cta-box--footer .btn--outline:hover {
  background: white;
  color: var(--color-primary);
}

@media (max-width: 768px) {
  .cta-box {
    flex-direction: column;
    text-align: center;
    padding: var(--s-8) var(--s-6);
    gap: var(--s-6);
  }
  .cta-box--inline .cta-box__accent {
    width: 100%;
    height: 5px;
    bottom: auto;
  }
  .cta-box__content {
    max-width: 420px;
    margin-inline: auto;
  }
  .cta-box__text {
    margin-inline: auto;
  }
  .cta-box__actions {
    justify-content: center;
    width: 100%;
  }
}

@media (max-width: 560px) {
  .cta-box__actions { flex-direction: column; width: 100%; align-items: stretch; }
  .cta-box__actions .btn { width: 100%; justify-content: center; text-align: center; }
}
</style>
