---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import StatsCounter from '../components/StatsCounter.astro';
import CTABox from '../components/CTABox.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { hizmetler, blogPosts, stats, company } from '../data/content';
import { kategoriler, getTekniklerByKategori } from '../data/faaliyet-alanlari';
import { projeler } from '../data/projeler';
import { heroStats, makineSayisi, sirket } from '../data/sirket';

const featuredHizmetler = hizmetler.slice(0, 6);
const featuredProjeler = projeler.slice(0, 3);

// Hero stat kartları için sayı ve suffix ayrıştır: "350+" → [350, "+"], "13 Yıl" → [13, " Yıl"]
function parseDeger(deger: string): [number, string] {
  const m = deger.match(/^(\d+)(.*)/);
  return m ? [parseInt(m[1], 10), m[2]] : [0, deger];
}

const faqItems = [
  { question: 'Fore kazık nedir ve ne zaman kullanılır?', answer: 'Fore kazık, zemin içine açılan deliklere yerinde beton dökülerek oluşturulan derin temel elemanıdır. 400–1500 mm çaplarında, 5–60 m derinliğe imal edilebilir. Zayıf zemin, yüksek yapı ve kentsel alanlar için idealdir.' },
  { question: 'Jet grout ile zemin iyileştirme kaç günde tamamlanır?', answer: 'Orta ölçekli bir jet grout projesi (500 m² alan) genellikle 5–10 gün sürer. Süre, kolon çapı, derinlik ve zemin cinsine bağlıdır. Torem Zemin iş programını önceden taahhüt eder.' },
  { question: 'Zemin etüdü olmadan temel tasarımı yapılabilir mi?', answer: 'Hayır. TBDY 2018 ve TS EN 1997 (Eurocode 7) standartları gereği her yapı için sahaya özgü zemin araştırması zorunludur. Zemin etütsüz temel tasarımı hem teknik hem hukuki risk oluşturur.' },
  { question: 'İstanbul dışında hizmet veriyor musunuz?', answer: 'Evet, Torem Zemin Mühendislik Türkiye\'nin tüm illerinde proje yürütmektedir. Ankara, İzmir, Bursa, Kocaeli ve diğer şehirlerde aktif projelerimiz mevcuttur.' },
];
---

<BaseLayout
  title="Zemin Mühendisliği ve Geoteknik Çözümler | Torem Zemin"
  description="13+ yıllık deneyimle fore kazık, jet grout, ankraj ve zemin iyileştirme projeleri. İstanbul merkezli, Türkiye geneli geoteknik mühendislik hizmetleri."
>

  <!-- ░░ HERO ░░ -->
  <section class="hero">

    <!-- Slide Backgrounds -->
    <div class="hero-slides">
      <div class="hero-slide hero-slide--1 is-active"></div>
      <div class="hero-slide hero-slide--2"></div>
      <div class="hero-slide hero-slide--3"></div>
    </div>

    <!-- Animated SVG Layer — zemin mühendisliği görsel dili -->
    <div class="hero-svg-layer" aria-hidden="true">
      <svg viewBox="0 0 1440 820" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">

        <!-- Zemin katman çizgileri -->
        <line class="geo-layer geo-layer--1" x1="-50" y1="540" x2="1500" y2="480" />
        <line class="geo-layer geo-layer--2" x1="-50" y1="590" x2="1500" y2="535" />
        <line class="geo-layer geo-layer--3" x1="-50" y1="650" x2="1500" y2="600" />
        <line class="geo-layer geo-layer--4" x1="-50" y1="700" x2="1500" y2="660" />
        <line class="geo-layer geo-layer--5" x1="-50" y1="760" x2="1500" y2="720" />

        <!-- Zemin eğrisi -->
        <path class="geo-layer geo-layer--curve"
          d="M 0 580 Q 200 520 400 560 T 800 540 T 1200 510 T 1500 500" />

        <!-- Fore kazık -->
        <line class="pile-line pile-line--1" x1="1224" y1="300" x2="1224" y2="640" />
        <line class="pile-line pile-line--2" x1="1234" y1="300" x2="1234" y2="640" />

        <!-- Kazık başlığı -->
        <rect class="pile-head pile-head--top" x="1210" y="290" width="36" height="14" rx="3" />
        <!-- Fore kazık tabanı -->
        <ellipse class="pile-head pile-head--base" cx="1229" cy="650" rx="22" ry="8" />

        <!-- Radar pulse -->
        <circle class="radar-circle radar-circle--1" cx="1229" cy="648" r="10" />
        <circle class="radar-circle radar-circle--2" cx="1229" cy="648" r="10" />
        <circle class="radar-circle radar-circle--3" cx="1229" cy="648" r="10" />

        <!-- Nokta desen -->
        <defs>
          <pattern id="heroDots" x="0" y="0" width="28" height="28" patternUnits="userSpaceOnUse">
            <circle cx="1" cy="1" r="1" fill="rgba(212,175,55,0.13)" />
          </pattern>
        </defs>
        <rect x="820" y="0" width="620" height="480" fill="url(#heroDots)" />

        <!-- Diagonal accent -->
        <line class="geo-layer geo-layer--diag"
          x1="1050" y1="0" x2="1440" y2="320"
          style="stroke-dasharray:800; stroke-dashoffset:800;" />

      </svg>
    </div>

    <!-- Gradient Overlay -->
    <div class="hero-overlay" aria-hidden="true"></div>

    <!-- Slide Numarası -->
    <div class="hero-slide-label" aria-hidden="true">
      Proje <span id="heroSlideNum">01</span> / 03
    </div>

    <!-- İçerik -->
    <div class="hero-content container">
      <p class="hero-eyebrow"><span>Türkiye'nin Güvenilir Geoteknik Ortağı</span></p>

      <h1 class="hero-title" id="heroTitle">
        Zorlu Zeminde,<br>
        <span class="hero-title__accent">sağlam temeller</span>
      </h1>

      <p class="hero-sub" id="heroSub">
        13 yıl, 350+ proje, kendi makine parkı. Fore kazıktan jet grouta — Türkiye'nin en karmaşık zeminlerinde mühendislik güvencesi.
      </p>

      <div class="hero-cta">
        <a id="heroCta" href="/iletisim/" class="btn btn--primary btn--hero-primary">
          <span id="heroCtaText">Maliyet Analizi İste</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4"/></svg>
        </a>
        <a href="/iletisim/" class="btn btn--ghost btn--hero-ghost">
          Ücretsiz Keşif İste
        </a>
      </div>
    </div>

    <!-- Floating Stats — sirket.ts'den otomatik -->
    <div class="hero-stats" aria-label="Proje İstatistikleri">
      {heroStats.map((stat) => {
        const [numVal, sfx] = parseDeger(stat.deger);
        return (
          <div class="hero-stat-card">
            <span class="hero-stat-card__num hero-counter" data-target={numVal} data-suffix={sfx}>0</span>
            <span class="hero-stat-card__lbl">{stat.etiket}</span>
          </div>
        );
      })}
    </div>

    <!-- Progress Dots -->
    <div class="hero-dots" id="heroDots" role="tablist" aria-label="Hero slaytlar"></div>

    <!-- Scroll İndikatörü -->
    <div class="hero-scroll" aria-hidden="true">
      <div class="hero-scroll__line"></div>
      <span>Aşağı Kaydır</span>
    </div>

  </section>

  <!-- ░░ REFERANS LOGO BANDI ░░ -->
  <section class="logos-band" aria-label="Referans müşterilerimiz">
    <div class="container logos-band__head">
      <p class="logos-band__title">Referans Müşterilerimiz</p>
    </div>
    <div class="logos-track" style="-webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);">
      <div class="logos-inner" aria-hidden="true">
        {[
          { name: 'Rönesans',     src: '/images/logos/ronesans.png'     },
          { name: 'TOKİ',         src: '/images/logos/toki.png'         },
          { name: 'İBB',          src: '/images/logos/ibb.png'          },
          { name: 'Kolin',        src: '/images/logos/kolin.png'        },
          { name: 'Emlak Konut',  src: '/images/logos/emlak-konut.png'  },
          { name: 'Fernas',       src: '/images/logos/fernas.png'       },
          { name: 'Smart',        src: '/images/logos/smart.png'        },
          { name: 'Doğuş',        src: '/images/logos/dogus.png'        },
          { name: 'Rönesans',     src: '/images/logos/ronesans.png'     },
          { name: 'TOKİ',         src: '/images/logos/toki.png'         },
          { name: 'İBB',          src: '/images/logos/ibb.png'          },
          { name: 'Kolin',        src: '/images/logos/kolin.png'        },
          { name: 'Emlak Konut',  src: '/images/logos/emlak-konut.png'  },
          { name: 'Fernas',       src: '/images/logos/fernas.png'       },
          { name: 'Smart',        src: '/images/logos/smart.png'        },
          { name: 'Doğuş',        src: '/images/logos/dogus.png'        },
        ].map((logo) => (
          <div class="logo-item">
            <img
              src={logo.src}
              alt={logo.name + ' — Torem Zemin referans müşteri'}
              loading="lazy"
              width="120"
              height="40"
              style="object-fit:contain; max-height:40px; width:auto;"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ STATS ░░ -->
  <StatsCounter stats={stats} />

  <!-- ░░ NEDEN BİZ? ░░ -->
  <section class="section neden-section">
    <div class="container">
      <div class="sec-head text-center reveal">
        <p class="eyebrow">Neden Torem?</p>
        <h2>Farkımız Sahada Ortaya Çıkar</h2>
        <p class="sec-head__sub">Rakamlar etkileyici — ama asıl fark sahadaki tutumda, kendi ekipmanımızda ve şeffaf iletişimimizde gizli.</p>
      </div>
      <div class="neden-grid">

        <div class="neden-kart reveal">
          <div class="neden-kart__ikon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="26" height="26"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3 class="neden-kart__title">Kendi Makine Parkımız</h3>
          <p class="neden-kart__desc">{makineSayisi} iş makinesi — kiralık değil, mülkümüz. Özel donanımlı filomuzla iş programı değişse bile ekipmanımız sahada daima hazırdır.</p>
        </div>

        <div class="neden-kart reveal">
          <div class="neden-kart__ikon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="26" height="26"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <h3 class="neden-kart__title">Standartlara Tam Uyum</h3>
          <p class="neden-kart__desc">Her kazık sıkı kalite testinden geçer. Projelerimiz ISO 9001 ve TBDY 2018 (Deprem Yönetmeliği) standartlarında güvence altındadır.</p>
        </div>

        <div class="neden-kart reveal">
          <div class="neden-kart__ikon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="26" height="26"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 11-7.778 7.778 5.5 5.5 0 017.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
          </div>
          <h3 class="neden-kart__title">Anahtar Teslim</h3>
          <p class="neden-kart__desc">Etütten projeye, uygulamadan testlere kadar; gecikme ve sürpriz maliyetler yaşamadan tek elden eksiksiz hizmet.</p>
        </div>

        <div class="neden-kart reveal">
          <div class="neden-kart__ikon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="26" height="26"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="neden-kart__title">Zamanında Teslim</h3>
          <p class="neden-kart__desc">Yazılı taahhüt ettiğimiz iş programına uyarız. Haftalık dijital şantiye takibi ve kritik yol analizi ile teslimatlar nettir.</p>
        </div>

        <div class="neden-kart reveal">
          <div class="neden-kart__ikon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="26" height="26"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="neden-kart__title">Saha Pratiği Olan Kadro</h3>
          <p class="neden-kart__desc">Ortalama 12 yol saha pratiği olan mühendis ekibi. Her projenin yetkili geoteknik mühendisi denetiminde yönetilmesi sağlanır.</p>
        </div>

        <div class="neden-kart neden-kart--cta reveal">
          <p class="neden-kart__desc" style="color:var(--color-primary); font-weight:600; font-size:1.15rem; margin-bottom:1.5rem;">Doğru geoteknik çözümü birlikte planlayalım.</p>
          <a href="/iletisim/" class="btn btn--primary" style="width:100%; justify-content:center; padding-block:1rem;">Ücretsiz Keşif İste</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ░░ HİZMETLER ░░ -->
  <section class="section">
    <div class="container">
      <div class="sec-head text-center reveal">
        <p class="eyebrow">Uzmanlık Alanlarımız</p>
        <h2>Öne Çıkan Geoteknik Tekniklerimiz</h2>
        <p class="sec-head__sub">Türkiye'nin en zorlu zeminlerinde uyguladığımız temel mühendislik teknikleri</p>
      </div>
      <div class="services-grid">
        {featuredHizmetler.map((h) => (
          <article class="svc-card reveal">
            <a href={h.href} class="svc-card__img-wrap">
              <img src={h.image} alt={h.title} loading="lazy" width="480" height="320" />
            </a>
            <div class="svc-card__body">
              <p class="svc-card__cat">{h.category}</p>
              <h3 class="svc-card__title">
                <a href={h.href}>{h.shortTitle}</a>
              </h3>
              <p class="svc-card__excerpt">{h.excerpt.slice(0, 110)}…</p>
              <a href={h.href} class="svc-card__link">
                Detaylı Bilgi →
              </a>
            </div>
          </article>
        ))}
      </div>
      <div class="text-center" style="margin-top:var(--s-10)">
        <a href="/faaliyet-alanlari/" class="btn btn--ghost">Tüm Hizmetleri Görüntüle</a>
      </div>
    </div>
  </section>

  <!-- ░░ FAALİYET ALANLARI ░░ -->
  <section class="section section--alt">
    <div class="container">
      <div class="sec-head text-center reveal">
        <p class="eyebrow">Faaliyet Alanları</p>
        <h2>Hizmet Gruplarımız</h2>
        <p class="sec-head__sub">Kazıklı temellerden zemin iyileştirmeye, iksa sistemlerinden geoteknik teste — 8 ana disiplinde 40+ teknik çözüm</p>
      </div>
      <div class="fa-grid">
        {kategoriler.map((k) => {
          const count = getTekniklerByKategori(k.slug).length;
          return (
            <a href={`/faaliyet-alanlari/${k.slug}/`} class="fa-card reveal">
              <div class="fa-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d={k.icon}/></svg>
              </div>
              <h3 class="fa-card__title">{k.title}</h3>
              <p class="fa-card__count">{count} Teknik</p>
            </a>
          );
        })}
      </div>
      <div class="text-center" style="margin-top:var(--s-8)">
        <a href="/faaliyet-alanlari/" class="btn btn--ghost">Tüm Faaliyet Alanlarını Görüntüle</a>
      </div>
    </div>
  </section>

  <!-- ░░ HAKKIMIZDA ░░ -->
  <section class="section section--alt about">
    <div class="container about__grid">
      <div class="about__imgs" aria-hidden="true">
        <img
          class="about__img-main"
          src="/images/fore-kazik-saha.jpg"
          alt="Fore kazık şantiye çalışması"
          loading="lazy" width="600" height="700"
        />
        <img
          class="about__img-accent"
          src="/images/makine-parki.webp"
          alt="Soilmec SR-40 fore kazık makinesi"
          loading="lazy" width="340" height="280"
        />
        <div class="about__badge">
          <strong>{sirket.kurulus}'ten</strong><span>beri güvenle inşa ediyoruz</span>
        </div>
      </div>

      <div class="about__text">
        <p class="eyebrow">Biz Kimiz</p>
        <h2>Sağlam Temellerin<br>Arkasındaki Güç</h2>
        <div class="aeo-box">
          Torem Zemin Mühendislik, {sirket.kurulus}'ten bu yana İstanbul merkezli olarak Türkiye genelinde
          350'yi aşkın geoteknik projeye imza atmıştır.
        </div>
        <p>
          Modern makine parkımız, alanında uzman mühendis kadromuz ve ISO 9001:2015 kalite
          yönetim sistemimizle konut, altyapı ve endüstriyel projelerde güvenilir çözümler sunuyoruz.
          Fore kazıktan jet grouta, ankrajdan iksa sistemlerine kadar tam kapsamlı geoteknik hizmetler.
        </p>
        <ul class="check-list">
          <li>ISO 9001:2015 Kalite Yönetim Sistemi</li>
          <li>{makineSayisi} modern iş makinesi parkı</li>
          <li>Deneyimli jeoteknik mühendis kadrosu</li>
          <li>Türkiye geneli, aynı gün saha ziyareti</li>
        </ul>
        <div class="about__actions">
          <a href="/kurumsal/" class="btn btn--ghost">Hakkımızda Daha Fazla</a>
          <a href="tel:+905316594636" class="btn btn--primary">{company.phone1}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ REFERANS PROJELERİ ░░ -->
  <section class="section ref-strip">
    <div class="container">
      <div class="sec-head text-center reveal">
        <p class="eyebrow">Referanslarımızdan</p>
        <h2>Tamamlanan Projelerden Seçkiler</h2>
        <p class="sec-head__sub">Her proje, mühendislik mükemmeliyetine olan bağlılığımızın somut kanıtıdır.</p>
      </div>
      <div class="ref-grid">
        {featuredProjeler.map((p) => (
          <a href={`/projelerimiz/${p.slug}/`} class="ref-card reveal">
            <div class="ref-card__img-wrap">
              <img src={p.image} alt={p.title} loading="lazy" width="560" height="360" />
              <span class="ref-card__cat">{p.category}</span>
              <div class="ref-card__overlay">
                <span class="ref-card__cta">Projeyi İncele →</span>
              </div>
            </div>
            <div class="ref-card__info">
              <div class="ref-card__meta">
                <span class="ref-card__type">{p.location}</span>
                <span class="ref-card__year">{p.year}</span>
              </div>
              <strong class="ref-card__title">{p.title}</strong>
              <div class="ref-card__tags">
                {p.tags.map((t) => <span class="ref-tag">{t}</span>)}
              </div>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center" style="margin-top:var(--s-8)">
        <a href="/projelerimiz/" class="btn btn--ghost">Tüm Projeler →</a>
      </div>
    </div>
  </section>

  <!-- ░░ NASIL ÇALIŞIYORUZ ░░ -->
  <section class="section section--alt process-section">
    <div class="container">
      <div class="sec-head text-center reveal">
        <p class="eyebrow">Sürecimiz</p>
        <h2>Nasıl Çalışıyoruz?</h2>
        <p class="sec-head__sub">Projelerinizi 4 adımda teslim ediyoruz — saha keşfinden kalite testine kadar</p>
      </div>
      <div class="process__steps" id="processSteps">
        <!-- Dinamik Sondaj Çizgisi -->
        <div class="process__drill" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v20M9 6h6M8 10h8M9 14h6M10 18h4M12 22l-2-4h4z" />
          </svg>
        </div>

        <div class="process__step">
          <div class="process__badge" aria-hidden="true">1</div>
          <div class="process__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <circle cx="21" cy="21" r="12"/>
              <path d="M33 33l9 9" stroke-linecap="round"/>
              <path d="M17 21h8M21 17v8" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Ücretsiz Keşif</h3>
          <p>Saha ziyareti ve zemin değerlendirmesi</p>
        </div>
        <div class="process__step">
          <div class="process__badge" aria-hidden="true">2</div>
          <div class="process__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="16" y="4" width="6" height="30" rx="2"/>
              <path d="M10 34h16" stroke-linecap="round"/>
              <path d="M8 38h24" stroke-linecap="round"/>
              <path d="M6 42h28" stroke-linecap="round"/>
              <circle cx="34" cy="10" r="5"/>
              <path d="M34 6v8M30 10h8" stroke-linecap="round" stroke-width="1.4"/>
            </svg>
          </div>
          <h3>Zemin Etüdü</h3>
          <p>Sondaj ve laboratuvar analizleri</p>
        </div>
        <div class="process__step">
          <div class="process__badge" aria-hidden="true">3</div>
          <div class="process__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="8" y="6" width="28" height="36" rx="3"/>
              <path d="M15 15h18M15 21h18M15 27h12" stroke-linecap="round"/>
