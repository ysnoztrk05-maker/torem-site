---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import StatsCounter from '../components/StatsCounter.astro';
import CTABox from '../components/CTABox.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { hizmetler, blogPosts, stats, company } from '../data/content';
import { kategoriler, getTekniklerByKategori } from '../data/faaliyet-alanlari';

const featuredHizmetler = hizmetler.slice(0, 6);

const faqItems = [
  { question: 'Fore kazık nedir ve ne zaman kullanılır?', answer: 'Fore kazık, zemin içine açılan deliklere yerinde beton dökülerek oluşturulan derin temel elemanıdır. 400–1500 mm çaplarında, 5–60 m derinliğe imal edilebilir. Zayıf zemin, yüksek yapı ve kentsel alanlar için idealdir.' },
  { question: 'Jet grout ile zemin iyileştirme kaç günde tamamlanır?', answer: 'Orta ölçekli bir jet grout projesi (500 m² alan) genellikle 5–10 gün sürer. Süre, kolon çapı, derinlik ve zemin cinsine bağlıdır. Torem Zemin iş programını önceden taahhüt eder.' },
  { question: 'Zemin etüdü olmadan temel tasarımı yapılabilir mi?', answer: 'Hayır. TBDY 2018 ve TS EN 1997 (Eurocode 7) standartları gereği her yapı için sahaya özgü zemin araştırması zorunludur. Zemin etütsüz temel tasarımı hem teknik hem hukuki risk oluşturur.' },
  { question: 'İstanbul dışında hizmet veriyor musunuz?', answer: 'Evet, Torem Zemin Mühendislik Türkiye\'nin tüm illerinde proje yürütmektedir. Ankara, İzmir, Bursa, Kocaeli ve diğer şehirlerde aktif projelerimiz mevcuttur.' },
];
---

<BaseLayout
  title="Zemin Mühendisliği ve Geoteknik Çözümler | Torem Zemin"
  description="20+ yıllık deneyimle fore kazık, jet grout, ankraj ve zemin iyileştirme projeleri. İstanbul merkezli, Türkiye geneli geoteknik mühendislik hizmetleri."
>

  <!-- ░░ HERO ░░ -->
  <section class="premium-hero">
    <div class="premium-hero__bg"></div>
    <div class="premium-hero__overlay"></div>
    <div class="container premium-hero__inner">
      <div class="premium-hero__content">
        <span class="eyebrow eyebrow--gold">Geoteknik Mühendislik</span>
        <h1 class="premium-hero__title">
          Temelden Zirveye<br>
          <span class="text-gradient">Güvenli Zemin Çözümleri</span>
        </h1>
        <p class="premium-hero__sub">
          20+ yıllık deneyimle fore kazık, jet grout, ankraj ve zemin iyileştirme projelerinde
          İstanbul'un güvenilir geoteknik partneri. ISO 9001 kalite güvencesiyle 600+ proje tamamlandı.
        </p>
        <div class="premium-hero__actions">
          <a href="/iletisim/" class="btn btn--primary btn--lg shadow-glow">Ücretsiz Keşif Raporu Alın</a>
          <a href="/hizmetlerimiz/" class="btn btn--outline btn--ghost-light btn--lg">Hizmetleri İncele</a>
        </div>
        <div class="premium-hero__trust">
          <div class="trust-item"><span class="trust-icon">✓</span> ISO 9001</div>
          <div class="trust-item"><span class="trust-icon">✓</span> 600+ Proje</div>
          <div class="trust-item"><span class="trust-icon">✓</span> 20 Yıl Deneyim</div>
        </div>
      </div>
    </div>
    <div class="premium-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="var(--color-white)"/>
      </svg>
    </div>
  </section>

  <!-- ░░ REFERANS LOGO BANDI ░░ -->
  <section class="logos-band" aria-label="Referans müşterilerimiz">
    <div class="container logos-band__head">
      <p class="logos-band__title">Referans Müşterilerimiz</p>
    </div>
    <div class="logos-track">
      <div class="logos-inner" aria-hidden="true">
        {[
          { name:'Rönesans', src:'/images/logos/ronesans.png' },
          { name:'TOKİ', src:'/images/logos/toki.png' },
          { name:'İBB', src:'/images/logos/ibb.png' },
          { name:'Kolin', src:'/images/logos/kolin.png' },
          { name:'Emlak Konut', src:'/images/logos/emlak-konut.png' },
          { name:'Fernas', src:'/images/logos/fernas.png' },
          { name:'Smart', src:'/images/logos/smart.png' },
          { name:'Doğuş', src:'/images/logos/dogus.png' },
          { name:'Rönesans', src:'/images/logos/ronesans.png' },
          { name:'TOKİ', src:'/images/logos/toki.png' },
          { name:'İBB', src:'/images/logos/ibb.png' },
          { name:'Kolin', src:'/images/logos/kolin.png' },
          { name:'Emlak Konut', src:'/images/logos/emlak-konut.png' },
          { name:'Fernas', src:'/images/logos/fernas.png' },
          { name:'Smart', src:'/images/logos/smart.png' },
          { name:'Doğuş', src:'/images/logos/dogus.png' },
        ].map((logo) => (
          <div class="logo-item">
            <img src={logo.src} alt={logo.name} loading="lazy" width="120" height="40" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ STATS ░░ -->
  <StatsCounter stats={stats} />

  <!-- ░░ HİZMETLER ░░ -->
  <section class="section">
    <div class="container">
      <div class="sec-head text-center">
        <p class="eyebrow">Neler Yapıyoruz</p>
        <h2>Geoteknik Mühendislik Hizmetlerimiz</h2>
        <p class="sec-head__sub">Zemin araştırmasından uygulamaya, kalite testinden raporlamaya — anahtar teslim çözümler</p>
      </div>
      <div class="services-grid">
        {featuredHizmetler.map((h) => (
          <article class="svc-card">
            <a href={`/hizmetlerimiz/${h.slug}/`} class="svc-card__img-wrap">
              <img src={h.image} alt={h.title} loading="lazy" width="480" height="320" />
            </a>
            <div class="svc-card__body">
              <p class="svc-card__cat">{h.category}</p>
              <h3 class="svc-card__title">
                <a href={`/hizmetlerimiz/${h.slug}/`}>{h.shortTitle}</a>
              </h3>
              <p class="svc-card__excerpt">{h.excerpt.slice(0, 110)}…</p>
              <a href={`/hizmetlerimiz/${h.slug}/`} class="svc-card__link">
                Detaylı Bilgi →
              </a>
            </div>
          </article>
        ))}
      </div>
      <div class="text-center" style="margin-top:var(--s-10)">
        <a href="/hizmetlerimiz/" class="btn btn--ghost">Tüm Hizmetleri Görüntüle</a>
      </div>
    </div>
  </section>

  <!-- ░░ FAALİYET ALANLARI ░░ -->
  <section class="section section--alt">
    <div class="container">
      <div class="sec-head text-center">
        <p class="eyebrow">Faaliyet Alanları</p>
        <h2>8 Uzmanlık Alanında Çözümler</h2>
        <p class="sec-head__sub">Kazıklı temellerden şev stabilitesine, geoteknik testten proje danışmanlığına — kapsamlı hizmet yelpazesi</p>
      </div>
      <div class="fa-grid">
        {kategoriler.map((k) => {
          const count = getTekniklerByKategori(k.slug).length;
          return (
            <a href={`/faaliyet-alanlari/${k.slug}/`} class="fa-card">
              <div class="fa-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d={k.icon}/></svg>
              </div>
              <h3 class="fa-card__title">{k.title}</h3>
              <p class="fa-card__count">{count} Teknik</p>
            </a>
          );
        })}
      </div>
      <div class="text-center" style="margin-top:var(--s-8)">
        <a href="/faaliyet-alanlari/" class="btn btn--ghost">Tüm Faaliyet Alanlarını Görüntüle</a>
      </div>
    </div>
  </section>

  <!-- ░░ HAKKIMIZDA ░░ -->
  <section class="section section--alt about">
    <div class="container about__grid">
      <div class="about__imgs" aria-hidden="true">
        <img
          class="about__img-main"
          src="/images/fore-kazik-saha.jpg"
          alt="Fore kazık şantiye çalışması"
          loading="lazy" width="600" height="700"
        />
        <img
          class="about__img-accent"
          src="/images/makine-parki.webp"
          alt="Soilmec SR-40 fore kazık makinesi"
          loading="lazy" width="340" height="280"
        />
        <div class="about__badge">
          <strong>2003'ten</strong><span>beri güvenle inşa ediyoruz</span>
        </div>
      </div>

      <div class="about__text">
        <p class="eyebrow">Biz Kimiz</p>
        <h2>Sağlam Temellerin<br>Arkasındaki Güç</h2>
        <div class="aeo-box">
          Torem Zemin Mühendislik, 2003'ten bu yana İstanbul merkezli olarak Türkiye genelinde
          600'ü aşkın geoteknik projeye imza atmıştır.
        </div>
        <p>
          Modern makine parkımız, alanında uzman mühendis kadromuz ve ISO 9001:2015 kalite
          yönetim sistemimizle konut, altyapı ve endüstriyel projelerde güvenilir çözümler sunuyoruz.
          Fore kazıktan jet grouta, ankrajdan iksa sistemlerine kadar tam kapsamlı geoteknik hizmetler.
        </p>
        <ul class="check-list">
          <li>ISO 9001:2015 Kalite Yönetim Sistemi</li>
          <li>55'i aşkın modern iş makinesi parkı</li>
          <li>Deneyimli jeoteknik mühendis kadrosu</li>
          <li>Türkiye geneli, aynı gün saha ziyareti</li>
        </ul>
        <div class="about__actions">
          <a href="/kurumsal/" class="btn btn--ghost">Hakkımızda Daha Fazla</a>
          <a href="tel:+905316594636" class="btn btn--primary">{company.phone1}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ REFERANS PROJELERİ ░░ -->
  <section class="section ref-strip">
    <div class="container">
      <p class="eyebrow text-center">Referanslarımızdan</p>
      <h2 class="text-center ref-strip__title">Tamamlanan Projelerden Seçkiler</h2>
      <div class="ref-grid">
        {[
          { img:'/images/iksa-sistemleri.jpg', loc:'İstanbul, Kadıköy', type:'Fore Kazık + İksa', title:'Otel Bodrum Kat Genişletme' },
          { img:'/images/zemin-iyilestirme.jpg', loc:'Ankara, Çankaya',  type:'Jet Grout',       title:'Metro İstasyon Temeli' },
          { img:'/images/ankraj.jpg', loc:'İzmir, Bayraklı',  type:'Öngermeli Ankraj',title:'AVM Derin Kazısı' },
        ].map((p) => (
          <div class="ref-card">
            <img
              src={p.img}
              alt={p.title}
              loading="lazy" width="560" height="360"
            />
            <div class="ref-card__info">
              <span class="ref-card__type">{p.type}</span>
              <strong>{p.title}</strong>
              <p>{p.loc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top:var(--s-8)">
        <a href="/projelerimiz/" class="btn btn--ghost">Tüm Projeler</a>
      </div>
    </div>
  </section>

  <!-- ░░ NASIL ÇALIŞIYORUZ ░░ -->
  <section class="section section--alt process-section">
    <div class="container">
      <div class="sec-head text-center">
        <p class="eyebrow">Sürecimiz</p>
        <h2>Nasıl Çalışıyoruz?</h2>
        <p class="sec-head__sub">Projelerinizi 4 adımda teslim ediyoruz — saha keşfinden kalite testine kadar</p>
      </div>
      <div class="process__steps">
        <div class="process__step">
          <div class="process__badge" aria-hidden="true">1</div>
          <div class="process__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <circle cx="21" cy="21" r="12"/>
              <path d="M33 33l9 9" stroke-linecap="round"/>
              <path d="M17 21h8M21 17v8" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Ücretsiz Keşif</h3>
          <p>Saha ziyareti ve zemin değerlendirmesi</p>
        </div>
        <div class="process__step">
          <div class="process__badge" aria-hidden="true">2</div>
          <div class="process__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="16" y="4" width="6" height="30" rx="2"/>
              <path d="M10 34h16" stroke-linecap="round"/>
              <path d="M8 38h24" stroke-linecap="round"/>
              <path d="M6 42h28" stroke-linecap="round"/>
              <circle cx="34" cy="10" r="5"/>
              <path d="M34 6v8M30 10h8" stroke-linecap="round" stroke-width="1.4"/>
            </svg>
          </div>
          <h3>Zemin Etüdü</h3>
          <p>Sondaj ve laboratuvar analizleri</p>
        </div>
        <div class="process__step">
          <div class="process__badge" aria-hidden="true">3</div>
          <div class="process__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="8" y="6" width="28" height="36" rx="3"/>
              <path d="M15 15h18M15 21h18M15 27h12" stroke-linecap="round"/>
              <path d="M34 36l6-6-3-3-6 6v3h3z" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Proje Tasarımı</h3>
          <p>TBDY 2018 uyumlu mühendislik tasarımı</p>
        </div>
        <div class="process__step">
          <div class="process__badge" aria-hidden="true">4</div>
          <div class="process__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <circle cx="24" cy="24" r="18"/>
              <path d="M14 24l7 7 13-14" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2"/>
            </svg>
          </div>
          <h3>Uygulama & Teslim</h3>
          <p>ISO 9001 kalite kontrolü ile teslim</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ BLOG ░░ -->
  <section class="section section--alt">
    <div class="container">
      <div class="sec-head text-center">
        <p class="eyebrow">Teknik Blog</p>
        <h2>Zemin Mühendisliği Bilgi Merkezi</h2>
      </div>
      <div class="blog-grid">
        {blogPosts.map((post) => (
          <article class="blog-card">
            <a href={`/blog/${post.slug}/`} class="blog-card__img">
              <img src={post.image} alt={post.title} loading="lazy" width="480" height="300" />
              <span class="blog-card__cat">{post.category}</span>
            </a>
            <div class="blog-card__body">
              <p class="blog-card__meta">{post.date} · {post.readTime}</p>
              <h3 class="blog-card__title">
                <a href={`/blog/${post.slug}/`}>{post.title}</a>
              </h3>
              <p class="blog-card__excerpt">{post.excerpt}</p>
              <a href={`/blog/${post.slug}/`} class="blog-card__more">Devamını Oku →</a>
            </div>
          </article>
        ))}
      </div>
      <div class="text-center" style="margin-top:var(--s-8)">
        <a href="/blog/" class="btn btn--ghost">Tüm Yazılar</a>
      </div>
    </div>
  </section>

  <!-- ░░ FAQ ░░ -->
  <FAQAccordion items={faqItems} title="Geoteknik Mühendislik Hakkında Sık Sorulanlar" />

  <!-- ░░ CTA ░░ -->
  <section class="section">
    <div class="container">
      <CTABox />
    </div>
  </section>

</BaseLayout>

<style>
/* ── Eyebrow ── */
.eyebrow { font-size:var(--text-sm); font-weight:700; color:var(--color-highlight); text-transform:uppercase; letter-spacing:.08em; margin-bottom:var(--s-3); }
.sec-head { margin-bottom:var(--s-12); }
.sec-head h2 { margin-bottom:var(--s-4); }
.sec-head__sub { color:var(--color-text-muted); font-size:var(--text-lg); max-width:580px; margin-inline:auto; }

/* ── Premium Hero ── */
.premium-hero {
  position: relative;
  background-color: var(--color-navy-dark, #0a192f);
  margin-top: -110px;
  padding-block: 220px 140px;
  overflow: hidden;
  text-align: center;
}
.premium-hero__bg {
  position: absolute;
  inset: 0;
  background-image: url('/images/hero-main.jpg');
  background-size: cover;
  background-position: center;
  opacity: 0.25;
  mix-blend-mode: luminosity;
}
.premium-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(10, 25, 47, 0.8) 0%, rgba(10, 25, 47, 1) 100%);
}
.premium-hero__inner {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: center;
}
.premium-hero__content {
  max-width: 900px;
}
.eyebrow {
  display: inline-block;
  font-size: 0.85rem; 
  font-weight: 700; 
  color: var(--color-navy-light, #003366); 
  text-transform: uppercase; 
  letter-spacing: 0.1em; 
  margin-bottom: 1.5rem; 
  background: var(--color-gray-100, #f3f4f6);
  padding: 0.35rem 0.8rem;
  border-radius: 4px;
}
.eyebrow--gold {
  color: var(--color-navy-dark, #0a192f);
  background: var(--color-gold, #cfa856);
}
.text-gradient {
  background: linear-gradient(135deg, var(--color-gold, #cfa856) 0%, #ebb44d 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.shadow-glow {
  box-shadow: 0 4px 20px rgba(207, 168, 86, 0.4);
}
.btn--ghost-light {
  border-color: rgba(255,255,255,0.3);
  color: white;
}
.btn--ghost-light:hover {
  background: white;
  color: var(--color-navy-dark, #0a192f);
}
.premium-hero__title {
  color: white;
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  line-height: 1.1;
  margin-bottom: 1.5rem;
}
.premium-hero__sub {
  color: rgba(255, 255, 255, 0.85);
  font-size: 1.25rem;
  line-height: 1.7;
  max-width: 700px;
  margin: 0 auto 2.5rem auto;
}
.premium-hero__actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin-bottom: 3rem;
  flex-wrap: wrap;
}
.premium-hero__trust {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  flex-wrap: wrap;
}
.trust-item {
  color: rgba(255, 255, 255, 0.7);
  font-size: 0.9rem;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.trust-icon {
  color: var(--color-gold, #cfa856);
  font-weight: bold;
}
.premium-hero__wave {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 60px;
  z-index: 3;
  line-height: 0;
}
.premium-hero__wave svg { width: 100%; height: 100%; }

@media (max-width: 768px) {
  .premium-hero { padding-block: 160px 100px; }
  .premium-hero__trust { gap: 1rem; }
}

/* ── Services grid ── */
.services-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--s-6); }
.svc-card { background:var(--color-white); border-radius:var(--r-lg); overflow:hidden; border:1px solid var(--color-border); transition:transform var(--t-base), box-shadow var(--t-base); }
.svc-card:hover { transform:translateY(-5px); box-shadow:var(--shadow-lg); }
.svc-card__img-wrap { display:block; aspect-ratio:3/2; overflow:hidden; }
.svc-card__img-wrap img { width:100%; height:100%; object-fit:cover; transition:transform var(--t-slow); }
.svc-card:hover .svc-card__img-wrap img { transform:scale(1.05); }
.svc-card__body { padding:var(--s-5) var(--s-6) var(--s-6); }
.svc-card__cat { font-size:var(--text-xs); text-transform:uppercase; letter-spacing:.07em; color:var(--color-highlight); font-weight:600; margin-bottom:var(--s-2); }
.svc-card__title { font-size:var(--text-xl); margin-bottom:var(--s-3); }
.svc-card__title a { color:var(--color-primary); transition:color var(--t-fast); }
.svc-card__title a:hover { color:var(--color-highlight); }
.svc-card__excerpt { font-size:var(--text-sm); color:var(--color-text-muted); line-height:1.7; margin-bottom:var(--s-4); }
.svc-card__link { font-size:var(--text-sm); font-weight:600; color:var(--color-highlight); }
@media (max-width:900px) { .services-grid { grid-template-columns:repeat(2,1fr); } }
@media (max-width:560px) { .services-grid { grid-template-columns:1fr; } }

/* ── About ── */
.about__grid { display:grid; grid-template-columns:1fr 1fr; gap:var(--s-16); align-items:center; }
.about__imgs { position:relative; height:520px; }
.about__img-main { position:absolute; left:0; top:0; width:75%; height:100%; object-fit:cover; border-radius:var(--r-xl); box-shadow:var(--shadow-xl); }
.about__img-accent { position:absolute; right:0; bottom:var(--s-10); width:45%; border-radius:var(--r-lg); box-shadow:var(--shadow-lg); border:4px solid var(--color-white); }
.about__badge {
  position:absolute; left:50%; bottom:0; transform:translateX(-50%);
  background:var(--color-highlight); color:var(--color-white);
  padding:var(--s-4) var(--s-6); border-radius:var(--r-lg); text-align:center;
  box-shadow:var(--shadow-lg); white-space:nowrap;
}
.about__badge strong { display:block; font-size:var(--text-xl); font-weight:700; }
