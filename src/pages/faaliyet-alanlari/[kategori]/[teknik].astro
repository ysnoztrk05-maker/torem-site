---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceArticleLayout from '../../../layouts/ServiceArticleLayout.astro';
import CTABox from '../../../components/CTABox.astro';
import { kategoriler, teknikler, getKategori, getTeknik, getTekniklerByKategori } from '../../../data/faaliyet-alanlari';

export function getStaticPaths() {
  return teknikler.map((t) => ({
    params: { kategori: t.kategoriSlug, teknik: t.slug },
    props: { teknik: t },
  }));
}

const { teknik } = Astro.props;
const kategori = getKategori(teknik.kategoriSlug)!;
const isRich = teknik.content.length > 1000;

const ilgiliTeknikler = getTekniklerByKategori(teknik.kategoriSlug)
  .filter(t => t.slug !== teknik.slug)
  .slice(0, 4);

const siteUrl = 'https://www.toremzemin.com';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: teknik.title,
  description: teknik.excerpt,
  author: {
    '@type': 'Organization',
    name: 'Torem Zemin Mühendislik',
    url: siteUrl
  },
  publisher: {
    '@type': 'Organization',
    name: 'Torem Zemin Mühendislik',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/images/logo.svg` }
  },
  datePublished: '2026-03-15',
  dateModified: '2026-04-02',
  mainEntityOfPage: `${siteUrl}/faaliyet-alanlari/${teknik.kategoriSlug}/${teknik.slug}/`
};

const faqSchema = teknik.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: teknik.faq.map((item: {q: string, a: string}) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
} : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Faaliyet Alanları', item: `${siteUrl}/faaliyet-alanlari/` },
    { '@type': 'ListItem', position: 3, name: kategori.title, item: `${siteUrl}/faaliyet-alanlari/${kategori.slug}/` },
    { '@type': 'ListItem', position: 4, name: teknik.shortTitle }
  ]
};

const hasProcessSteps = teknik.content.includes('class="process-steps"');
const howToSchema = hasProcessSteps ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `${teknik.shortTitle} Nasıl Yapılır?`,
  description: teknik.excerpt,
  step: (() => {
    const stepMatches = teknik.content.match(/<div class="step">[\s\S]*?<h4>([\s\S]*?)<\/h4>[\s\S]*?<p>([\s\S]*?)<\/p>/g) || [];
    return stepMatches.map((s: string, i: number) => {
      const titleMatch = s.match(/<h4>([\s\S]*?)<\/h4>/);
      const textMatch = s.match(/<p>([\s\S]*?)<\/p>/);
      return {
        '@type': 'HowToStep',
        position: i + 1,
        name: titleMatch ? titleMatch[1].replace(/<[^>]*>/g, '') : `Adım ${i + 1}`,
        text: textMatch ? textMatch[1].replace(/<[^>]*>/g, '').substring(0, 300) : ''
      };
    });
  })()
} : null;

const pageSchemas = [articleSchema, faqSchema, breadcrumbSchema, howToSchema].filter(Boolean);
const ogImage = teknik.image && teknik.image !== '/og-default.jpg' ? teknik.image : '/og-default.jpg';
---

{isRich ? (
  <!-- Zengin içerikli sayfalar: ServiceArticleLayout (O layout da kendisi update edilebilir, ancak genelde core logic buradadır) -->
  <ServiceArticleLayout
    title={`${teknik.title} | Torem Zemin`}
    description={teknik.excerpt}
    category={kategori.title}
    categorySlug={kategori.slug}
    badges={['TBDY 2018', 'ISO 9001', kategori.title]}
    updateDate="Mart 2026"
    readTime={Math.ceil(teknik.content.split(/\s+/).length / 200)}
    wordCount={teknik.content.split(/\s+/).length}
    ogImage={ogImage}
    ogType="article"
    schema={pageSchemas}
    shortTitle={teknik.shortTitle}
    relatedTeknikler={ilgiliTeknikler.map(t => ({ slug: t.slug, kategoriSlug: t.kategoriSlug, shortTitle: t.shortTitle }))}
  >
    <div class="tz-readability-wrapper">
       <Fragment set:html={teknik.content} />
    </div>

    {teknik.steps && teknik.steps.length > 0 && (
      <div class="tz-section" style="max-width:800px;margin-inline:auto;padding-inline:var(--s-6,1.5rem);">
        <h2 class="tz-section-title">Uygulama Adımları — Özet</h2>
        <ol class="tz-steps">
          {teknik.steps.map((s) => (
            <li class="tz-step">
              <span class="tz-step__title">{s.title}</span>
              <p class="tz-step__desc">{s.desc}</p>
            </li>
          ))}
        </ol>
      </div>
    )}

    {teknik.params && teknik.params.length > 0 && (
      <div class="tz-section" style="max-width:800px;margin-inline:auto;padding-inline:var(--s-6,1.5rem);">
        <h2 class="tz-section-title">Teknik Parametreler</h2>
        <div class="tz-params-wrap">
          <table class="tz-params-table">
            <thead>
              <tr><th>Parametre</th><th>Tipik Değer</th><th>Açıklama</th></tr>
            </thead>
            <tbody>
              {teknik.params.map((p) => (
                <tr>
                  <td><strong>{p.name}</strong></td>
                  <td class="tz-params-table__value">{p.value}</td>
                  <td>{p.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    {teknik.zeminTurleri && teknik.zeminTurleri.length > 0 && (
      <div class="tz-section" style="max-width:800px;margin-inline:auto;padding-inline:var(--s-6,1.5rem);">
        <h2 class="tz-section-title">Uygun Zemin Türleri</h2>
        <div class="tz-zemin-chips">
          {teknik.zeminTurleri.map((z) => (
            <span class="tz-zemin-chip">{z}</span>
          ))}
        </div>
      </div>
    )}

    {ilgiliTeknikler.length > 0 && (
      <div class="tz-related-container" style="margin-top: 4rem;">
        <h2 class="tz-section-title">{kategori.title} Kapsamındaki Diğer Yöntemler</h2>
        <div class="tz-related-grid">
          {ilgiliTeknikler.map((t) => (
            <a href={`/faaliyet-alanlari/${t.kategoriSlug}/${t.slug}/`} class="tz-related-card">
              <img src={t.image} alt={t.title} loading="lazy" width="320" height="200" />
              <div class="tz-related-card__body">
                {t.badge && <span class="tz-related-card__badge">{t.badge}</span>}
                <h3>{t.shortTitle}</h3>
                <p>{t.excerpt.slice(0, 80)}…</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </ServiceArticleLayout>
) : (
  <!-- Kısa içerikli sayfalar: BaseLayout ile V2.0 Premium Readability Deneyimi -->
  <BaseLayout
    title={`${teknik.title} | Torem Zemin`}
    description={teknik.excerpt}
    ogImage={ogImage}
    ogType="article"
    schema={pageSchemas}
  >
    <!-- PREMIUM V2 HERO -->
    <header class="tz-article-hero">
      <div class="tz-hero-pattern"></div>
      <div class="container tz-hero-inner">
        <nav class="tz-breadcrumb" aria-label="Breadcrumb">
          <ol itemscope itemtype="https://schema.org/BreadcrumbList">
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a itemprop="item" href="/"><span itemprop="name">Ana Sayfa</span></a>
              <meta itemprop="position" content="1" />
            </li>
            <li>/</li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a itemprop="item" href="/faaliyet-alanlari/"><span itemprop="name">Faaliyet Alanları</span></a>
              <meta itemprop="position" content="2" />
            </li>
            <li>/</li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a itemprop="item" href={`/faaliyet-alanlari/${kategori.slug}/`}><span itemprop="name">{kategori.title}</span></a>
              <meta itemprop="position" content="3" />
            </li>
            <li>/</li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
              <span itemprop="name" style="color:var(--gold);">{teknik.shortTitle}</span>
              <meta itemprop="position" content="4" />
            </li>
          </ol>
        </nav>

        <span class="tz-badge-gold">{kategori.title} Yöntemi</span>
        <h1>{teknik.title}</h1>
        <p class="tz-hero-excerpt">{teknik.excerpt}</p>
      </div>

      <div class="tz-hero-wave" aria-hidden="true">
        <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
          <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,115.11,192.5,102.7c54.74-11,109.9-38.35,164.71-36.4C366.5,67,344.6,60.77,321.39,56.44Z" class="shape-fill"></path>
        </svg>
      </div>
    </header>

    <main class="tz-article-main">
      <div class="container tz-content-container">
        <div class="tz-content-grid">

          <!-- ░░ ANA İÇERİK ░░ -->
          <div class="tz-content-main">

            <!-- YAZI İÇERİĞİ -->
            <article class="tz-readability-wrapper tz-article-body" set:html={teknik.content} />

            <!-- UYGULAMA ADIMLARI -->
            {teknik.steps && teknik.steps.length > 0 && (
              <div class="tz-section">
                <h2 class="tz-section-title">Uygulama Adımları</h2>
                <ol class="tz-steps">
                  {teknik.steps.map((s) => (
                    <li class="tz-step">
                      <span class="tz-step__title">{s.title}</span>
                      <p class="tz-step__desc">{s.desc}</p>
                    </li>
                  ))}
                </ol>
              </div>
            )}

            <!-- TEKNİK PARAMETRELER -->
            {teknik.params && teknik.params.length > 0 && (
              <div class="tz-section">
                <h2 class="tz-section-title">Teknik Parametreler</h2>
                <div class="tz-params-wrap">
                  <table class="tz-params-table">
                    <thead>
                      <tr>
                        <th>Parametre</th>
                        <th>Tipik Değer</th>
                        <th>Açıklama</th>
                      </tr>
                    </thead>
                    <tbody>
                      {teknik.params.map((p) => (
                        <tr>
                          <td><strong>{p.name}</strong></td>
                          <td class="tz-params-table__value">{p.value}</td>
                          <td>{p.desc}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            <!-- UYGUN ZEMİN TÜRLERİ -->
            {teknik.zeminTurleri && teknik.zeminTurleri.length > 0 && (
              <div class="tz-section">
                <h2 class="tz-section-title">Uygun Zemin Türleri</h2>
                <div class="tz-zemin-chips">
                  {teknik.zeminTurleri.map((z) => (
                    <span class="tz-zemin-chip">{z}</span>
                  ))}
                </div>
              </div>
            )}

            <!-- SIK SORULAN SORULAR -->
            {teknik.faq.length > 0 && (
              <div class="tz-article-faq">
                <h2>{teknik.shortTitle} Hakkında Merak Edilenler</h2>
                <div class="tz-faq-group">
                  {teknik.faq.map((item) => (
                    <details class="tz-faq-item">
                      <summary>{item.q}
                         <svg class="tz-faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>
                      </summary>
                      <div class="tz-faq-body">
                         <p>{item.a}</p>
                      </div>
                    </details>
                  ))}
                </div>
              </div>
            )}

          </div><!-- /tz-content-main -->

          <!-- ░░ STICKY SIDEBAR ░░ -->
          <aside class="tz-sidebar">

            <!-- CTA Kutusu -->
            <div class="tz-sidebar__cta">
              <p class="tz-sidebar__eyebrow">Ücretsiz Keşif</p>
              <h3 class="tz-sidebar__title">{teknik.shortTitle} için teklif alın</h3>
              <p class="tz-sidebar__desc">Sahadaki uzman mühendisimiz projenizi değerlendirsin.</p>
              <a href="/iletisim/" class="btn btn--primary" style="width:100%;text-align:center;display:block;">Teklif İste</a>
              <a href="tel:+905316594636" class="tz-sidebar__tel">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .94h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                +90 531 659 46 36
              </a>
            </div>

            <!-- İlgili Teknikler -->
            {ilgiliTeknikler.length > 0 && (
              <div class="tz-sidebar__related">
                <h4 class="tz-sidebar__related-title">{kategori.title} Yöntemleri</h4>
                <ul class="tz-sidebar__related-list">
                  {ilgiliTeknikler.map((t) => (
                    <li>
                      <a href={`/faaliyet-alanlari/${t.kategoriSlug}/${t.slug}/`} class="tz-sidebar__related-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M9 18l6-6-6-6"/></svg>
                        {t.shortTitle}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Güven Sinyalleri -->
            <div class="tz-sidebar__trust">
              <div class="tz-sidebar__trust-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span>ISO 9001:2015 Kalite</span>
              </div>
              <div class="tz-sidebar__trust-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span>TBDY 2018 Uyumlu</span>
              </div>
              <div class="tz-sidebar__trust-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span>350+ Tamamlanan Proje</span>
              </div>
            </div>

          </aside><!-- /tz-sidebar -->

        </div><!-- /tz-content-grid -->
      </div>
    </main>
    
    {ilgiliTeknikler.length > 0 && (
      <div class="container tz-related-container">
        <h2 class="tz-section-title">{kategori.title} Kapsamındaki Diğer Yöntemler</h2>
        <div class="tz-related-grid">
          {ilgiliTeknikler.map((t) => (
            <a href={`/faaliyet-alanlari/${t.kategoriSlug}/${t.slug}/`} class="tz-related-card">
              <img src={t.image} alt={t.title} loading="lazy" width="320" height="200" />
              <div class="tz-related-card__body">
                {t.badge && <span class="tz-related-card__badge">{t.badge}</span>}
                <h3>{t.shortTitle}</h3>
                <p>{t.excerpt.slice(0, 80)}…</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="container" style="padding-bottom: 80px;">
      <CTABox title={`${teknik.shortTitle} Çözümleri İçin Uzmanlarımızla Görüşün`} />
    </div>

  </BaseLayout>
)}

<style is:global>
/* =========================================================================
   TOREM ZEMİN V2.0 - MAKALE & TEKNİK YAZI (READABILITY) STİLLERİ
   (is:global çünkü Astro set:html ile gelen içeriklerde local scope çalışmaz)
   ========================================================================= */

:root {
    --navy-deep: #001530;
    --navy: #002147;
    --navy-light: #003366;
    --gold: #d4af37;
    --bg-cream: #fafaf7;
    --text-article: #33333e; /* Salt siyah yerine daha yumuşak, okunabilir bir ton */
    --text-muted: #5a5a70;
}

.tz-article-hero {
    background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%);
    /* Topbar (~38px) + header (72px) = 110px */
    padding: 165px 0 90px;
    position: relative;
    text-align: center;
    color: #fff;
    margin-top: -110px;
    overflow: hidden;
}
.tz-hero-pattern {
    position: absolute; inset: 0; opacity: 0.05;
    background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px);
    background-size: 30px 30px; z-index: 1;
}

.tz-hero-inner { position: relative; z-index: 2; max-width: 860px; margin: 0 auto; }

.tz-breadcrumb ol { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 8px; list-style: none; padding: 0; font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-bottom: 25px; }
.tz-breadcrumb a { color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s; }
.tz-breadcrumb a:hover { color: var(--gold); }

.tz-badge-gold {
    display: inline-block; background: rgba(212, 175, 55, 0.15); color: var(--gold);
    padding: 6px 16px; border-radius: 30px; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; margin-bottom: 20px;
    border: 1px solid rgba(212, 175, 55, 0.3);
}

/* Spesifik selector — global.css h1 { color: var(--color-primary) } override */
header.tz-article-hero h1 { font-size: clamp(2.2rem, 4.5vw, 3.5rem); font-weight: 800; line-height: 1.25; margin-bottom: 24px; color: #ffffff; text-wrap: balance; }
.tz-hero-excerpt { font-size: clamp(1.1rem, 2vw, 1.25rem); color: rgba(255,255,255,0.85); line-height: 1.7; font-weight: 300; max-width: 720px; margin: 0 auto; }

.tz-hero-wave { position: absolute; bottom: 0; left: 0; width: 100%; line-height: 0; transform: translateY(1px); }
.tz-hero-wave svg { display: block; width: calc(100% + 1.3px); height: 60px; }
/* global.css --color-bg: #fafaf7 — wave geçişi tam eşleşir */
.tz-hero-wave .shape-fill { fill: var(--color-bg, #fafaf7); }

.tz-article-main { background-color: var(--color-bg, #fafaf7); padding: 50px 0 60px; }
.tz-content-container { max-width: 1220px; margin: 0 auto; padding: 0 var(--s-6); }
.tz-content-grid { display: grid; grid-template-columns: 1fr 300px; gap: var(--s-12); align-items: start; }
.tz-content-main { min-width: 0; }

/* Sidebar */
.tz-sidebar { position: sticky; top: 96px; display: flex; flex-direction: column; gap: var(--s-5); }
.tz-sidebar__cta { background: var(--color-primary); border-radius: var(--r-xl); padding: var(--s-7) var(--s-6); }
.tz-sidebar__eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-highlight); margin-bottom: var(--s-2); }
.tz-sidebar__title { font-family: var(--font-serif); font-size: 1.2rem; color: var(--color-white); margin-bottom: var(--s-3); line-height: 1.3; }
.tz-sidebar__desc { font-size: var(--text-sm); color: rgba(255,255,255,0.7); margin-bottom: var(--s-5); }
.tz-sidebar__tel { display: flex; align-items: center; gap: var(--s-2); margin-top: var(--s-4); font-size: var(--text-sm); font-weight: 600; color: var(--color-highlight); text-decoration: none; }
.tz-sidebar__tel:hover { color: var(--color-white); }
.tz-sidebar__related { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--r-xl); padding: var(--s-5) var(--s-5); }
.tz-sidebar__related-title { font-size: var(--text-sm); font-weight: 700; color: var(--color-primary); margin-bottom: var(--s-3); text-transform: uppercase; letter-spacing: 0.08em; }
.tz-sidebar__related-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--s-1); }
.tz-sidebar__related-link { display: flex; align-items: center; gap: var(--s-2); font-size: var(--text-sm); color: var(--color-text); text-decoration: none; padding: var(--s-2) 0; border-bottom: 1px solid var(--color-border); transition: color var(--t-fast); }
.tz-sidebar__related-link:last-child { border-bottom: none; }
.tz-sidebar__related-link:hover { color: var(--color-accent); }
.tz-sidebar__related-link svg { color: var(--color-highlight); flex-shrink: 0; }
.tz-sidebar__trust { background: var(--color-bg-alt); border-radius: var(--r-xl); padding: var(--s-5); display: flex; flex-direction: column; gap: var(--s-3); }
.tz-sidebar__trust-item { display: flex; align-items: center; gap: var(--s-3); font-size: var(--text-sm); color: var(--color-text-muted); }
.tz-sidebar__trust-item svg { color: var(--color-accent); flex-shrink: 0; }

/* Sidebar responsive */
@media (max-width: 1100px) {
  .tz-content-grid { grid-template-columns: 1fr; gap: var(--s-8); }
  .tz-sidebar { position: static; }
  .tz-sidebar__cta, .tz-sidebar__related, .tz-sidebar__trust { width: 100%; box-sizing: border-box; }
}

/* --- TYPOGRAPHY (READABILITY STANDARTLARI) --- */
.tz-readability-wrapper {
    font-size: 1.1rem; /* 17.6px */
    line-height: 1.85; /* Optik akışkanlık için geniş line-height */
    color: var(--text-article);
    font-family: inherit;
}

.tz-readability-wrapper p { margin-bottom: 1.5rem; }
.tz-readability-wrapper p strong { font-weight: 700; color: var(--navy); }

.tz-readability-wrapper h2 {
