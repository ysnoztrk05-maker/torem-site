---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CTABox from '../../../components/CTABox.astro';
import { kategoriler, getTekniklerByKategori } from '../../../data/faaliyet-alanlari';

export function getStaticPaths() {
  return kategoriler.map((k) => ({
    params: { kategori: k.slug },
    props: { kategori: k },
  }));
}

const { kategori } = Astro.props;
const teknikler = getTekniklerByKategori(kategori.slug);
const hasComparison = teknikler.some(t => t.comparison);

function suIcon(val: string) {
  if (val === 'Tam') return '✅ Tam';
  if (val === 'Kısmi') return '⚠️ Kısmi';
  return '❌ ' + val;
}

function kaliciIcon(val: string) {
  if (val === 'Evet') return '✅ Evet';
  if (val === 'Geçici') return '❌ Geçici';
  return '⚠️ ' + val;
}
---

<BaseLayout
  title={`${kategori.title} | Torem Zemin`}
  description={kategori.description}
>
  <!-- 1. Hero -->
  <section class="kat-hero">
    <div class="kat-hero__bg" aria-hidden="true"></div>
    <div class="container kat-hero__inner">
      <p class="eyebrow">Faaliyet Alanları</p>
      <h1>{kategori.title}</h1>
      <p>{kategori.description}</p>
    </div>
  </section>

  <!-- 2. Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="bc" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a itemprop="item" href="/"><span itemprop="name">Ana Sayfa</span></a>
          <meta itemprop="position" content="1" />
        </li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a itemprop="item" href="/faaliyet-alanlari/"><span itemprop="name">Faaliyet Alanları</span></a>
          <meta itemprop="position" content="2" />
        </li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
          <span itemprop="name">{kategori.title}</span>
          <meta itemprop="position" content="3" />
        </li>
      </ol>
    </div>
  </nav>

  <!-- 3. AEO Özet Kutusu -->
  {kategori.aeoSummary && (
    <section class="section">
      <div class="container">
        <div class="aeo-summary">
          <h2>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C8873A" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
            {kategori.title.replace('İksa Sistemleri', 'İksa')} Nedir?
            <span class="badge">Özet</span>
          </h2>
          <p>{kategori.aeoSummary}</p>
        </div>
      </div>
    </section>
  )}

  <!-- 4. Karar Yardımcısı -->
  {kategori.kararKartlari.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="sec-head sec-head--center">
          <h2>Hangi {kategori.title.split(' ')[0]} Yöntemi Size Uygun?</h2>
          <p>Projenizin koşullarını seçin — en uygun yöntemleri görelim</p>
        </div>
        <div class="karar-grid">
          {kategori.kararKartlari.map((k) => (
            <div class="karar-card">
              <div class="karar-card__icon">{k.icon}</div>
              <h3>{k.title}</h3>
              <p>{k.description}</p>
              <span class="karar-card__rec">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                {k.recommendation}
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 5. Zenginleştirilmiş Teknik Kartlar -->
  <section class="section">
    <div class="container">
      <div class="sec-head">
        <h2>{kategori.title} Çözümlerimiz</h2>
        <p class="sec-head__sub">{teknikler.length} farklı yöntem ve uygulama</p>
      </div>
      <div class="tek-grid">
        {teknikler.map((t) => (
          <article class="tcard">
            <a href={`/faaliyet-alanlari/${kategori.slug}/${t.slug}/`} class="tcard__img-wrap">
              <img src={t.image} alt={t.shortTitle} loading="lazy" width="480" height="320" />
              {t.badge && (
                <div class="tcard__badges">
                  <span class={`tcard__badge tcard__badge--${t.badgeType}`}>{t.badge}</span>
                </div>
              )}
            </a>
            <div class="tcard__body">
              <h3 class="tcard__title">
                <a href={`/faaliyet-alanlari/${kategori.slug}/${t.slug}/`}>{t.shortTitle}</a>
              </h3>
              <p class="tcard__excerpt">{t.excerpt}</p>
              {t.metrics && t.metrics.length > 0 && (
                <div class="tcard__metrics">
                  {t.metrics.map((m) => (
                    <div class="tcard__metric">
                      <strong>{m.value}</strong> {m.label}
                    </div>
                  ))}
                </div>
              )}
              <a href={`/faaliyet-alanlari/${kategori.slug}/${t.slug}/`} class="tcard__link">
                Detaylı Bilgi
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. Karşılaştırma Tablosu -->
  {hasComparison && (
    <section class="section section--alt">
      <div class="container">
        <div class="sec-head sec-head--center">
          <h2>{kategori.title} Karşılaştırması</h2>
          <p>{teknikler.filter(t => t.comparison).length} yöntem — 5 kritik parametre üzerinden görsel karşılaştırma</p>
        </div>
        <div class="comp-table-wrap">
          <table class="comp-table">
            <thead>
              <tr>
                <th>Yöntem</th>
                <th>Maks. Derinlik</th>
                <th>Göreceli Maliyet</th>
                <th>Su Geçirimsizlik</th>
                <th>Kalıcı Kullanım</th>
              </tr>
            </thead>
            <tbody>
              {teknikler.filter(t => t.comparison).map((t) => (
                <tr>
                  <td>{t.shortTitle}</td>
                  <td>
                    <div class="bar-wrap">
                      <div class="bar"><div class="bar__fill bar__fill--blue" style={`width:${t.comparison!.derinlikBar}%`}></div></div>
                      <span class="bar-label">{t.comparison!.maxDerinlik}</span>
                    </div>
                  </td>
                  <td>
                    <div class="bar-wrap">
                      <div class="bar"><div class="bar__fill bar__fill--orange" style={`width:${t.comparison!.maliyetBar}%`}></div></div>
                      <span class="bar-label">{t.comparison!.maliyetLabel}</span>
                    </div>
                  </td>
                  <td style="text-align:center;">{suIcon(t.comparison!.suGecirimsizlik)}</td>
                  <td style="text-align:center;">{kaliciIcon(t.comparison!.kaliciKullanim)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- 7. Saha Notları -->
  {kategori.sahaNotlari.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="sec-head sec-head--center">
          <h2>Sahadan Notlar</h2>
          <p>Deneyimle öğrenilen bilgiler — kitaplarda yazmaz</p>
        </div>
        <div class="saha-notlari-grid">
          {kategori.sahaNotlari.map((n) => (
            <div class="saha-notu">
              <strong>{n.icon} {n.title}:</strong>
              <p>{n.content}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 8. FAQ Accordion -->
  {kategori.categoryFaq.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="sec-head sec-head--center">
          <h2>{kategori.title} Sık Sorulan Sorular</h2>
          <p>Projeleriniz için merak ettikleriniz</p>
        </div>
        <div class="faq-list">
          {kategori.categoryFaq.map((f) => (
            <details class="faq-item">
              <summary>{f.q}</summary>
              <div class="faq-body">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 9. CTA -->
  <section class="section">
    <div class="container">
      <CTABox title={`${kategori.title} Projeleriniz İçin Teklif Alın`} />
    </div>
  </section>

  <!-- FAQPage Schema -->
  {kategori.categoryFaq.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": kategori.categoryFaq.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    })} />
  )}
</BaseLayout>

<style>
/* ─── HERO ─────────────────────────────────────────────── */
.eyebrow { font-size:var(--text-sm); font-weight:700; color:#E8A85A; text-transform:uppercase; letter-spacing:.08em; margin-bottom:var(--s-3); }
.kat-hero {
  background:linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  padding-block:var(--s-20) var(--s-16); color:var(--color-white);
  position:relative; overflow:hidden; text-align:center;
}
.kat-hero__bg { position:absolute; inset:0; background:radial-gradient(ellipse at 60% 40%, rgba(74,127,165,.25) 0%, transparent 55%); pointer-events:none; }
.kat-hero__inner { position:relative; z-index:1; max-width:640px; margin-inline:auto; }
.kat-hero h1 { color:var(--color-white); font-size:var(--text-5xl); margin-bottom:var(--s-4); }
.kat-hero p { color:rgba(255,255,255,.75); font-size:var(--text-lg); }

/* ─── BREADCRUMB ───────────────────────────────────────── */
.breadcrumb-bar { background:var(--color-white); border-bottom:1px solid var(--color-border); padding-block:var(--s-3); }
.bc { display:flex; flex-wrap:wrap; gap:var(--s-1); font-size:var(--text-sm); color:var(--color-text-muted); list-style:none; }
.bc li+li::before { content:'›'; margin-right:var(--s-1); }
.bc a { color:var(--color-accent); }
.bc a:hover { color:var(--color-highlight); }

/* ─── SECTIONS ─────────────────────────────────────────── */
.section--alt { background:var(--color-white); }
.sec-head { margin-bottom:var(--s-10); }
.sec-head h2 { font-size:var(--text-3xl); margin-bottom:var(--s-2); }
.sec-head__sub { color:var(--color-text-muted); }
.sec-head p { color:var(--color-text-muted); }
.sec-head--center { text-align:center; }

/* ─── AEO SUMMARY ─────────────────────────────────────── */
.aeo-summary {
  background:var(--color-white); border-radius:var(--r-xl); padding:32px;
  box-shadow:var(--shadow-md); border-left:5px solid var(--color-highlight);
  margin-bottom:48px; max-width:900px; margin-inline:auto;
}
.aeo-summary h2 { font-size:var(--text-xl); color:var(--color-primary); margin-bottom:var(--s-3); display:flex; align-items:center; gap:10px; }
.aeo-summary h2 .badge { background:var(--color-highlight); color:var(--color-white); font-size:11px; font-weight:700; padding:3px 10px; border-radius:20px; text-transform:uppercase; letter-spacing:.04em; }
.aeo-summary p { color:var(--color-text-muted); font-size:var(--text-base); line-height:1.75; }

/* ─── KARAR YARDIMCISI ─────────────────────────────────── */
.karar-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px; }
.karar-card {
  background:var(--color-white); border-radius:var(--r-lg); padding:24px;
  border:2px solid var(--color-border); transition:all .25s ease; cursor:default; text-align:center;
}
.karar-card:hover { border-color:var(--color-highlight); transform:translateY(-3px); box-shadow:var(--shadow-lg); }
.karar-card__icon {
  width:56px; height:56px; background:rgba(200,135,58,.1); border-radius:50%;
  display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:24px;
}
.karar-card h3 { font-size:15px; color:var(--color-primary); margin-bottom:8px; font-weight:700; }
.karar-card p { font-size:13px; color:var(--color-text-muted); margin-bottom:12px; line-height:1.6; }
.karar-card__rec {
  display:inline-flex; align-items:center; gap:6px;
  background:rgba(200,135,58,.1); color:var(--color-highlight);
  font-size:12px; font-weight:700; padding:6px 14px; border-radius:20px;
}

/* ─── TEKNIK KARTLAR ───────────────────────────────────── */
.tek-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--s-6); margin-bottom:var(--s-16); }
.tcard { background:var(--color-white); border-radius:var(--r-lg); overflow:hidden; border:1px solid var(--color-border); transition:transform var(--t-base), box-shadow var(--t-base); display:flex; flex-direction:column; }
.tcard:hover { transform:translateY(-5px); box-shadow:var(--shadow-lg); }
.tcard__img-wrap { display:block; aspect-ratio:3/2; overflow:hidden; position:relative; }
.tcard__img-wrap img { width:100%; height:100%; object-fit:cover; transition:transform var(--t-slow); }
.tcard:hover .tcard__img-wrap img { transform:scale(1.05); }
.tcard__badges { position:absolute; top:12px; left:12px; display:flex; gap:6px; flex-wrap:wrap; }
.tcard__badge { font-size:10px; font-weight:700; padding:4px 10px; border-radius:20px; text-transform:uppercase; letter-spacing:.03em; }
.tcard__badge--popular { background:var(--color-highlight); color:var(--color-white); }
.tcard__badge--ekonomik { background:#2a9d8f; color:var(--color-white); }
.tcard__badge--premium { background:var(--color-secondary); color:var(--color-white); }
.tcard__badge--ozel { background:#6b5ce7; color:var(--color-white); }
.tcard__body { padding:var(--s-5) var(--s-6) var(--s-6); flex:1; display:flex; flex-direction:column; }
.tcard__title { font-size:var(--text-xl); margin-bottom:var(--s-3); }
.tcard__title a { color:var(--color-primary); transition:color var(--t-fast); }
.tcard__title a:hover { color:var(--color-highlight); }
.tcard__excerpt { font-size:var(--text-sm); color:var(--color-text-muted); line-height:1.7; margin-bottom:var(--s-4); flex:1; }
.tcard__metrics { display:grid; grid-template-columns:1fr 1fr; gap:8px; padding-top:16px; border-top:1px solid var(--color-border); margin-bottom:16px; }
.tcard__metric { font-size:12px; color:var(--color-text-muted); }
.tcard__metric strong { display:block; font-size:14px; color:var(--color-primary); font-weight:700; }
.tcard__link { display:inline-flex; align-items:center; gap:var(--s-2); font-size:var(--text-sm); font-weight:600; color:var(--color-highlight); transition:gap var(--t-fast); }
.tcard__link:hover { gap:var(--s-3); }

/* ─── KARŞILAŞTIRMA TABLOSU ────────────────────────────── */
.comp-table-wrap { overflow-x:auto; background:var(--color-white); border-radius:var(--r-xl); box-shadow:var(--shadow-md); margin-bottom:48px; }
.comp-table { width:100%; border-collapse:collapse; font-size:14px; min-width:800px; }
.comp-table th { text-align:left; padding:16px 20px; background:var(--color-primary); color:var(--color-white); font-weight:600; font-size:13px; text-transform:uppercase; letter-spacing:.04em; white-space:nowrap; }
.comp-table th:first-child { border-radius:var(--r-xl) 0 0 0; }
.comp-table th:last-child { border-radius:0 var(--r-xl) 0 0; }
.comp-table td { padding:14px 20px; border-bottom:1px solid var(--color-border); vertical-align:middle; }
.comp-table tr:last-child td { border-bottom:none; }
.comp-table tr:hover td { background:rgba(200,135,58,.1); }
.comp-table td:first-child { font-weight:600; color:var(--color-primary); white-space:nowrap; }
.bar-wrap { display:flex; align-items:center; gap:10px; }
.bar { height:8px; border-radius:4px; background:var(--color-border); flex:1; overflow:hidden; }
.bar__fill { height:100%; border-radius:4px; }
.bar__fill--blue { background:var(--color-accent); }
.bar__fill--orange { background:var(--color-highlight); }
.bar-label { font-size:12px; color:var(--color-text-muted); min-width:42px; text-align:right; }

/* ─── SAHA NOTLARI ─────────────────────────────────────── */
.saha-notlari-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:48px; }
.saha-notu {
  background:rgba(200,135,58,.1); border-left:4px solid var(--color-highlight);
  padding:24px 28px; border-radius:0 var(--r-lg) var(--r-lg) 0; line-height:1.75;
}
.saha-notu strong:first-child { color:var(--color-highlight); display:block; margin-bottom:8px; font-size:15px; }
.saha-notu p { font-size:14px; color:var(--color-text); margin:0; }

/* ─── FAQ ACCORDION ────────────────────────────────────── */
.faq-list { max-width:800px; margin:0 auto; }
.faq-item { border:1px solid var(--color-border); border-radius:var(--r-lg); margin-bottom:12px; overflow:hidden; background:var(--color-white); }
.faq-item summary { padding:18px 24px; font-weight:600; font-size:var(--text-base); cursor:pointer; list-style:none; display:flex; align-items:center; justify-content:space-between; color:var(--color-primary); }
.faq-item summary::after { content:'+'; font-size:22px; color:var(--color-highlight); flex-shrink:0; margin-left:16px; }
.faq-item[open] summary::after { content:'−'; }
.faq-item[open] summary { border-bottom:1px solid var(--color-border); }
.faq-item .faq-body { padding:16px 24px 20px; color:var(--color-text-muted); font-size:15px; line-height:1.75; }

/* ─── RESPONSIVE ───────────────────────────────────────── */
@media (max-width:900px) {
  .karar-grid { grid-template-columns:repeat(2,1fr); }
  .tek-grid { grid-template-columns:repeat(2,1fr); }
  .saha-notlari-grid { grid-template-columns:1fr; }
}
@media (max-width:560px) {
  .karar-grid { grid-template-columns:1fr; }
  .tek-grid { grid-template-columns:1fr; }
}
</style>
