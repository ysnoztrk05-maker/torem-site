---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CTABox from '../../../components/CTABox.astro';
import { kategoriler, getTekniklerByKategori } from '../../../data/faaliyet-alanlari';

export function getStaticPaths() {
  return kategoriler.map((k) => ({
    params: { kategori: k.slug },
    props: { kategori: k },
  }));
}

const { kategori } = Astro.props;
const teknikler = getTekniklerByKategori(kategori.slug);
const hasComparison = teknikler.some(t => t.comparison);

function suIcon(val: string) {
  if (val === 'Tam') return '✅ Tam';
  if (val === 'Kısmi') return '⚠️ Kısmi';
  return '❌ ' + val;
}

function kaliciIcon(val: string) {
  if (val === 'Evet') return '✅ Evet';
  if (val === 'Geçici') return '❌ Geçici';
  return '⚠️ ' + val;
}
---

<BaseLayout
  title={`${kategori.title} | Torem Zemin`}
  description={kategori.description}
>

  <!-- 1. PREMIUM HERO SECTION -->
  <header class="tz-hero">
    <div class="tz-hero-pattern"></div>
    <div class="container tz-hero-content">
      <nav class="tz-breadcrumb" aria-label="Breadcrumb">
        <ol itemscope itemtype="https://schema.org/BreadcrumbList">
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a itemprop="item" href="/"><span itemprop="name">Ana Sayfa</span></a>
            <meta itemprop="position" content="1" />
          </li>
          <li>/</li>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a itemprop="item" href="/faaliyet-alanlari/"><span itemprop="name">Faaliyet Alanları</span></a>
            <meta itemprop="position" content="2" />
          </li>
          <li>/</li>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
            <span itemprop="name">{kategori.title}</span>
            <meta itemprop="position" content="3" />
          </li>
        </ol>
      </nav>

      <span class="tz-badge-gold">Özel Çözümler</span>
      <h1>{kategori.title}</h1>
      <p>{kategori.description}</p>
    </div>
    
    <div class="tz-hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
        <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,115.11,192.5,102.7c54.74-11,109.9-38.35,164.71-36.4C366.5,67,344.6,60.77,321.39,56.44Z" class="shape-fill"></path>
      </svg>
    </div>
  </header>

  <!-- 2. AEO ÖZET & GENEL BAKIŞ (OVERVIEW) -->
  <section class="tz-overview">
    <div class="container tz-overview-container">
      <div class="tz-overview-content">
        <h2 class="tz-section-title">{kategori.title} Hakkında</h2>
        <p>Projenizin zemin koşulları ve yapısal yük dağılımları göz önüne alınarak tasarlanan <strong>{kategori.title}</strong> çözümleri, projenin güvenlik, performans ve ekonomi dengesini kuran temel adımlardan biridir.</p>
        <p>Uzman mühendislik ekibimiz, en karmaşık coğrafi ve topoğrafik şartlarda bile kalıcı ve estetik geoteknik çözümler üretir.</p>
      </div>

      {kategori.aeoSummary && (
        <aside class="tz-aeo-box">
          <div class="tz-aeo-header">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
            <h3>Hızlı Özet (AEO)</h3>
          </div>
          <div class="tz-aeo-body">
            <p><strong>{kategori.title} Nedir?</strong></p>
            <p>{kategori.aeoSummary}</p>
          </div>
        </aside>
      )}
    </div>
  </section>

  <!-- 3. KARAR YARDIMCISI KARTLARI -->
  {kategori.kararKartlari.length > 0 && (
    <section class="tz-section-alt">
      <div class="container">
        <div class="tz-center-header">
          <h2>Hangi {kategori.title.split(' ')[0]} Yöntemi Size Uygun?</h2>
          <p>Projenizin koşullarını baz alarak en verimli karar ağacını değerlendirin.</p>
        </div>
        <div class="tz-decision-grid">
          {kategori.kararKartlari.map((k) => (
            <div class="tz-decision-card">
              <div class="tz-decision-icon">{k.icon}</div>
              <h3>{k.title}</h3>
              <p>{k.description}</p>
              <div class="tz-decision-match">
                 <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                {k.recommendation}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 4. TEKNİKLER / HİZMET DETAY GRID'İ -->
  <section class="tz-section">
    <div class="container">
      <div class="tz-center-header">
        <h2>Uyguladığımız {kategori.title.split(' ')[0]} Yöntemleri</h2>
        <p>{teknikler.length} Farklı teknik — Projeniz için inovatif ve ekonomik yaklaşımlar</p>
      </div>
      
      <div class="tz-technical-grid">
        {teknikler.map((t) => (
          <article class="tz-tech-card">
            <a href={`/faaliyet-alanlari/${kategori.slug}/${t.slug}/`} class="tz-tech-img">
               <img src={t.image} alt={t.shortTitle} loading="lazy" />
               {t.badge && (
                 <span class="tz-tech-badge">{t.badge}</span>
               )}
            </a>
            <div class="tz-tech-content">
              <h3><a href={`/faaliyet-alanlari/${kategori.slug}/${t.slug}/`}>{t.shortTitle}</a></h3>
              <p>{t.excerpt}</p>
              
              {t.metrics && t.metrics.length > 0 && (
                <div class="tz-tech-stats">
                  {t.metrics.map((m) => (
                    <div class="tz-stat-col">
                      <span class="tz-s-val">{m.value}</span>
                      <span class="tz-s-lbl">{m.label}</span>
                    </div>
                  ))}
                </div>
              )}
              
              <a href={`/faaliyet-alanlari/${kategori.slug}/${t.slug}/`} class="tz-link-arrow">
                Teknik Detayları İncele
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. PROGRESS BAR'LI KARŞILAŞTIRMA TABLOSU -->
  {hasComparison && (
    <section class="tz-section-alt">
      <div class="container">
        <div class="tz-center-header">
          <h2>Tekniklerin Karşılaştırılması</h2>
          <p>Hangi yöntemin avantajlı olduğunu temel mühendislik parametrelerine göre değerlendirin.</p>
        </div>
        
        <div class="tz-table-wrapper">
          <table class="tz-modern-table">
            <thead>
              <tr>
                <th>Sistem/Yöntem</th>
                <th>Maks. Derinlik</th>
                <th>Maliyet Endeksi</th>
                <th>Su Geçirimsizlik</th>
                <th>Kalıcılık</th>
              </tr>
            </thead>
            <tbody>
              {teknikler.filter(t => t.comparison).map((t) => (
                <tr>
                  <td><strong>{t.shortTitle}</strong></td>
                  <td>
                    <div class="tz-bar-box">
                      <div class="tz-progress-track"><div class="tz-progress-fill" style={`width:${t.comparison!.derinlikBar}%`}></div></div>
                      <span class="tz-bar-text">{t.comparison!.maxDerinlik}</span>
                    </div>
                  </td>
                  <td>
                    <div class="tz-bar-box">
                      <div class="tz-progress-track"><div class="tz-progress-fill tz-fill-gold" style={`width:${t.comparison!.maliyetBar}%`}></div></div>
                      <span class="tz-bar-text">{t.comparison!.maliyetLabel}</span>
                    </div>
                  </td>
                  <td class="tz-t-center">{suIcon(t.comparison!.suGecirimsizlik)}</td>
                  <td class="tz-t-center">{kaliciIcon(t.comparison!.kaliciKullanim)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- 6. SAHA NOTLARI (Şantiyeden Gerçek Deneyimler) -->
  {kategori.sahaNotlari.length > 0 && (
    <section class="tz-field-notes-section">
      <div class="container">
        <div class="tz-center-header">
           <span class="tz-badge-gold">Şantiye Günlüğü</span>
           <h2 style="color:var(--navy); margin-top:10px;">Uzmanlardan Saha Notları</h2>
           <p style="color:var(--text-secondary)">Kitaplarda yazmayan, doğrudan uygulamanın içinden süzülmüş gerçek tecrübeler.</p>
        </div>
        <div class="tz-field-grid">
           {kategori.sahaNotlari.map((n) => (
             <div class="tz-field-note-card">
               <div class="tz-note-icon">{n.icon}</div>
               <div class="tz-note-content">
                  <h4>{n.title}</h4>
                  <p>{n.content}</p>
               </div>
             </div>
           ))}
        </div>
      </div>
    </section>
  )}

  <!-- 7. SIK SORULAN SORULAR (CSS-ONLy FAQ) -->
  {kategori.categoryFaq.length > 0 && (
    <section class="tz-section">
      <div class="container">
        <div class="tz-center-header">
          <h2>Sık Sorulan Sorular</h2>
          <p>{kategori.title} ile ilgili en çok merak edilen mühendislik detayları.</p>
        </div>
        
        <div class="tz-faq-container">
           {kategori.categoryFaq.map((f) => (
             <details class="tz-faq-item">
               <summary>{f.q} 
                 <svg class="tz-faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>
               </summary>
               <div class="tz-faq-body">
                 <p>{f.a}</p>
               </div>
             </details>
           ))}
        </div>
      </div>
    </section>
  )}

  <!-- 8. CALL TO ACTION -->
  <div class="container" style="padding: 40px 0 80px 0;">
    <CTABox title={`${kategori.title} Projeniz İçin Teknik Destek Alın`} />
  </div>

  <!-- FAQPage Schema.org SEO Entegrasyonu -->
  {kategori.categoryFaq.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": kategori.categoryFaq.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    })} />
  )}
</BaseLayout>

<style>
/* =========================================================================
   TOREM ZEMİN V2.0 - LADING PAGE SCOPED CSS (Kategori Detay)
   ========================================================================= */

:root {
    --navy-deep: #001530;
    --navy: #002147;
    --gold: #d4af37;
    --bg-cream: #fafaf7;
    --text-main: #333333;
    --text-secondary: #4a4a6a;
    --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.container { margin: 0 auto; max-width: 1200px; padding: 0 20px; }

/* 1. HERO SECTION */
.tz-hero {
    position: relative; background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 100%);
    /* Topbar (~38px) + sticky header (72px) = 110px */
    padding: 165px 0 90px; color: #fff; text-align: center; overflow: hidden; margin-top: -110px;
}
.tz-hero-pattern {
    position: absolute; inset: 0; opacity: 0.05;
    background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px);
    background-size: 30px 30px; z-index: 1;
}
.tz-hero-content { position: relative; z-index: 2; max-width: 800px; margin: 0 auto; }

.tz-breadcrumb { margin-bottom: 30px; }
.tz-breadcrumb ol { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 10px; list-style: none; padding: 0; margin: 0; font-size: 0.85rem; color: rgba(255,255,255,0.6); }
.tz-breadcrumb a { color: rgba(255,255,255,0.8); text-decoration: none; transition: color 0.2s; }
.tz-breadcrumb a:hover { color: var(--gold); }

.tz-badge-gold {
    display: inline-block; background: rgba(212, 175, 55, 0.15); color: var(--gold);
    padding: 6px 16px; border-radius: 30px; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; margin-bottom: 20px;
    border: 1px solid rgba(212, 175, 55, 0.3);
}

/* Spesifik selector — global.css h1 { color: var(--color-primary) } override */
header.tz-hero h1 { font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 800; line-height: 1.15; margin-bottom: 24px; color: #ffffff; }
header.tz-hero p { font-size: clamp(1.1rem, 2vw, 1.25rem); color: rgba(255,255,255,0.85); font-weight: 300; line-height: 1.6; }

.tz-hero-wave { position: absolute; bottom: 0; left: 0; width: 100%; overflow: hidden; line-height: 0; transform: translateY(1px); }
.tz-hero-wave svg { display: block; width: calc(100% + 1.3px); height: 60px; }
/* Overview section background = #F5F2ED krem — tam eşleşme */
.tz-hero-wave .shape-fill { fill: var(--color-bg, #fafaf7); }

/* 2. OVERVIEW & AEO */
.tz-overview { padding: 60px 0; background-color: var(--color-bg, #F5F2ED); }
.tz-overview-container { display: grid; grid-template-columns: 3fr 2fr; gap: 60px; align-items: center; }
.tz-section-title { font-size: clamp(1.8rem, 3vw, 2.5rem); color: var(--navy); font-weight: 800; margin-bottom: 24px; }
.tz-overview-content p { font-size: 1.05rem; color: var(--text-secondary); line-height: 1.8; margin-bottom: 16px; }

.tz-aeo-box {
    background: #fff; border-radius: 12px; border: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 10px 30px rgba(0,33,71,0.08); overflow: hidden; position: relative;
}
.tz-aeo-box::before { content:''; position:absolute; top:0; left:0; width:4px; height:100%; background:var(--gold); }
.tz-aeo-header { display: flex; align-items: center; gap: 12px; padding: 20px 24px; background: rgba(0,33,71,0.03); border-bottom: 1px solid rgba(0,0,0,0.05); }
.tz-aeo-header h3 { font-size: 1.1rem; color: var(--navy); margin: 0; font-weight: 700; }
.tz-aeo-header stroke { color: var(--gold); }
.tz-aeo-body { padding: 24px; }
.tz-aeo-body p { margin-bottom: 15px; font-size: 0.95rem; line-height: 1.7; color: var(--text-secondary); }
.tz-aeo-body strong { color: var(--text-main); font-weight: 700; }

/* 3. SECTIONS COMMON */
.tz-section { padding: 80px 0; background-color: #ffffff; }
.tz-section-alt { padding: 80px 0; background-color: var(--color-bg, #F5F2ED); border-top: 1px solid rgba(0,0,0,0.03); border-bottom: 1px solid rgba(0,0,0,0.03); }
.tz-center-header { text-align: center; max-width: 700px; margin: 0 auto 50px; }
.tz-center-header h2 { font-size: clamp(2rem, 3vw, 2.5rem); color: var(--navy); font-weight: 800; margin-bottom: 15px; }
.tz-center-header p { font-size: 1.1rem; color: var(--text-secondary); line-height: 1.6; }

/* 4. DECISION GRID (KARAR YARDIMCISI) */
.tz-decision-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; }
.tz-decision-card {
    background: #fff; border-radius: 12px; padding: 30px 24px; text-align: center;
    border: 1px solid rgba(0,0,0,0.06); transition: var(--transition);
}
.tz-decision-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); border-color: rgba(212, 175, 55, 0.4); }
.tz-decision-icon { font-size: 2.5rem; margin-bottom: 20px; display: inline-flex; justify-content: center; align-items: center; width: 70px; height: 70px; border-radius: 50%; background: var(--bg-cream); border: 2px solid rgba(0,0,0,0.03); }
.tz-decision-card h3 { font-size: 1.25rem; color: var(--navy); margin-bottom: 12px; font-weight: 700; }
.tz-decision-card p { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 20px; }
.tz-decision-match {
    display: inline-flex; align-items: center; gap: 8px; font-size: 0.85rem; font-weight: 700;
    color: #1e8e3e; background: rgba(30, 142, 62, 0.1); padding: 8px 16px; border-radius: 20px;
}

/* 5. TECHNICAL GRID (HİZMETLER) */
.tz-technical-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 30px; }
.tz-tech-card {
    background: #fff; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.06);
    box-shadow: 0 4px 15px rgba(0,0,0,0.03); transition: var(--transition); display: flex; flex-direction: column;
}
.tz-tech-card:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,33,71,0.08); }
.tz-tech-img { display: block; position: relative; aspect-ratio: 16/10; overflow: hidden; }
.tz-tech-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.tz-tech-card:hover .tz-tech-img img { transform: scale(1.05); }
.tz-tech-badge {
    position: absolute; top: 15px; left: 15px; background: var(--navy); color: var(--gold);
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 6px 12px; border-radius: 4px; box-shadow: 0 4px 10px rgba(0,0,0,0.2);
}
.tz-tech-content { padding: 25px; flex-grow: 1; display: flex; flex-direction: column; }
.tz-tech-content h3 { font-size: 1.3rem; font-weight: 700; margin-bottom: 12px; line-height: 1.3; }
.tz-tech-content h3 a { color: var(--navy); text-decoration: none; transition: color 0.2s; }
.tz-tech-content h3 a:hover { color: var(--gold); }
.tz-tech-content p { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 24px; flex-grow: 1; }

.tz-tech-stats { display: flex; gap: 20px; padding: 15px 0; border-top: 1px solid rgba(0,0,0,0.06); border-bottom: 1px solid rgba(0,0,0,0.06); margin-bottom: 20px; }
.tz-stat-col { display: flex; flex-direction: column; }
.tz-s-val { font-size: 1.1rem; font-weight: 800; color: var(--navy); }
.tz-s-lbl { font-size: 0.75rem; text-transform: uppercase; color: var(--text-secondary); font-weight: 600; letter-spacing: 0.5px; }

.tz-link-arrow {
    display: inline-flex; align-items: center; gap: 8px; font-size: 0.9rem; font-weight: 700;
    color: var(--navy); text-decoration: none; text-transform: uppercase; transition: var(--transition);
}
.tz-tech-card:hover .tz-link-arrow { color: var(--gold); }
.tz-link-arrow svg { transition: transform 0.3s; }
.tz-tech-card:hover .tz-link-arrow svg { transform: translateX(5px); }


/* 6. COMPARISON TABLE */
.tz-table-wrapper { overflow-x: auto; background: #fff; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
.tz-modern-table { width: 100%; border-collapse: collapse; min-width: 800px; }
.tz-modern-table th {
    background: var(--navy); color: #fff; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;
    padding: 18px 20px; text-align: left; white-space: nowrap; font-weight: 600;
}
.tz-modern-table td { padding: 16px 20px; border-bottom: 1px solid rgba(0,0,0,0.05); vertical-align: middle; color: var(--text-secondary); font-size: 0.95rem; }
.tz-modern-table tr:last-child td { border-bottom: none; }
.tz-modern-table tr:hover td { background-color: rgba(212, 175, 55, 0.05); }
.tz-modern-table td:first-child { font-weight: 700; color: var(--navy); }

.tz-bar-box { display: flex; align-items: center; gap: 12px; }
.tz-progress-track { flex-grow: 1; height: 8px; background: rgba(0,0,0,0.05); border-radius: 4px; overflow: hidden; min-width: 100px; }
.tz-progress-fill { height: 100%; background: var(--navy); border-radius: 4px; }
.tz-fill-gold { background: var(--gold); }
.tz-bar-text { font-size: 0.85rem; font-weight: 600; min-width: 45px; text-align: right; }
.tz-t-center { text-align: center; }

/* 7. FIELD NOTES (SAHA NOTLARI) */
.tz-field-notes-section { padding: 80px 0; background: #fff; }
.tz-field-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 30px; }
.tz-field-note-card {
    display: flex; gap: 20px; background: var(--bg-cream); padding: 30px; border-radius: 12px;
    border-left: 4px solid var(--gold); box-shadow: 0 4px 15px rgba(0,0,0,0.02); transition: transform 0.3s;
}
.tz-field-note-card:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
.tz-note-icon { font-size: 2rem; flex-shrink: 0; line-height: 1; }
.tz-note-content h4 { font-size: 1.15rem; color: var(--navy); margin-bottom: 10px; font-weight: 700; }
.tz-note-content p { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.6; margin: 0; }

/* 8. FAQ ACCORDION (CSS ONLY) */
.tz-faq-container { max-width: 800px; margin: 0 auto; }
.tz-faq-item {
    background: #fff; border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; margin-bottom: 15px;
    overflow: hidden; transition: box-shadow 0.3s;
}
.tz-faq-item:hover { box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
.tz-faq-item summary {
    display: flex; justify-content: space-between; align-items: center; padding: 20px 24px;
    font-size: 1.05rem; font-weight: 700; color: var(--navy); cursor: pointer; list-style: none; user-select: none;
}
.tz-faq-item summary::-webkit-details-marker { display: none; }
