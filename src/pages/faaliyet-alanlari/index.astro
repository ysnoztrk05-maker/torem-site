---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABox from '../../components/CTABox.astro';
import { kategoriler, getTekniklerByKategori } from '../../data/faaliyet-alanlari';
---

<BaseLayout
  title="Faaliyet Alanları | Torem Zemin Mühendislik"
  description="Kazıklı temeller, iksa sistemleri, zemin iyileştirme, ankraj, şev stabilitesi ve geoteknik proje hizmetleri. 8 uzmanlık alanında 45+ teknik çözüm."
>

    <!-- HERO BÖLÜMÜ -->
    <header class="tz-category-hero">
        <div class="tz-hero-pattern"></div>
        <div class="container tz-category-hero-content">
            <span class="tz-badge-gold">Hizmetlerimiz</span>
            <h1>Güvenilir Zeminler, <span>Sağlam Yapılar</span></h1>
            <p>Torem Zemin olarak derin kazılardan zemin iyileştirmeye kadar tüm geoteknik mühendislik ihtiyaçlarınız için uzman çözümler sunuyoruz. 8 farklı mühendislik disiplininde projelerinize değer katıyoruz.</p>
        </div>
        
        <!-- Dalga SVG (Wave Transition) -->
        <div class="tz-hero-wave" aria-hidden="true">
            <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,115.11,192.5,102.7c54.74-11,109.9-38.35,164.71-36.4C366.5,67,344.6,60.77,321.39,56.44Z" class="shape-fill"></path>
            </svg>
        </div>
    </header>

    <!-- HİZMETLER GRID -->
    <section class="tz-services-section">
        <div class="container tz-services-grid">
            
            {kategoriler.map((k) => {
              const teknikler = getTekniklerByKategori(k.slug);
              // Kartta göstereceğimiz maksimum alt teknik sayısı:
              const listTeknikler = teknikler.slice(0, 4);

              return (
                <a href={`/faaliyet-alanlari/${k.slug}/`} class="tz-service-card">
                    <div class="tz-card-image">
                        <img src={k.image} alt={k.title} loading="lazy" width="800" height="500" />
                        <div class="tz-card-title-overlay">
                            <h2>
                                <svg class="tz-card-icon" fill="none" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d={k.icon} />
                                </svg>
                                {k.title}
                            </h2>
                        </div>
                    </div>
                    <div class="tz-card-content">
                        <p class="tz-card-desc">{k.description}</p>
                        
                        {listTeknikler.length > 0 && (
                            <ul class="tz-sub-services">
                                {listTeknikler.map((t) => (
                                    <li>{t.shortTitle || t.title}</li>
                                ))}
                                {teknikler.length > 4 && (
                                    <li class="tz-sub-more">+ {teknikler.length - 4} Özel Sistem Daha</li>
                                )}
                            </ul>
                        )}

                        <div class="tz-card-footer">
                            <span class="tz-technique-count">{teknikler.length} Teknik</span>
                            <div class="tz-card-action">
                                Detaylı İncele 
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                        </div>
                    </div>
                </a>
              );
            })}

        </div>
    </section>

    <!-- METRİKLER (Güven ve KPI) -->
    <section class="tz-stats-section">
        <div class="container tz-stats-grid">
            <div class="tz-stat-item">
                <h3>20<span>+</span></h3>
                <p>Yıllık Mühendislik Tecrübesi</p>
            </div>
            <div class="tz-stat-item">
                <h3>5k<span>+</span></h3>
                <p>Tamamlanan Kazık ve İyileştirme</p>
            </div>
            <div class="tz-stat-item">
                <h3>ISO<span>9001</span></h3>
                <p>Uluslararası Kalite Sertifikası</p>
            </div>
            <div class="tz-stat-item">
                <h3>%<span>100</span></h3>
                <p>Teslimat ve Zemin Güveni</p>
            </div>
        </div>
    </section>

    <div class="container" style="margin-top: 80px; margin-bottom: 80px;">
        <CTABox title="Projenize Özel Geoteknik Çözüm İster misiniz?" />
    </div>

</BaseLayout>

<style>
/* =========================================================================
   TOREM ZEMİN V2.0 - FAALİYETLER SCOPED CSS
   ========================================================================= */

.container { margin: 0 auto; max-width: var(--max-width, 1200px); padding: 0 var(--s-5); }

/* 1. HERO SECTION */
.tz-category-hero {
    position: relative;
    background: linear-gradient(135deg, var(--color-primary) 0%, rgba(10, 25, 47, 0.95) 100%);
    padding: 100px 0 80px;
    color: #fff;
    text-align: center;
    overflow: hidden;
    /* Topbar (~38px) + sticky header (72px) = 110px — negatif margin ile header altına tam oturur */
    margin-top: -110px;
    padding-top: 155px; /* -margin + orijinal padding = içerik yerinde kalır */
}

.tz-hero-wave {
    position: absolute; bottom: 0; left: 0; width: 100%; overflow: hidden; line-height: 0; transform: translateY(1px);
}
.tz-hero-wave svg { display: block; width: calc(100% + 1.3px); height: 60px; }
/* var(--color-bg) = #fafaf7 — global body background ile tam eşleşme */
.tz-hero-wave .shape-fill { fill: var(--color-bg, #fafaf7); }

.tz-hero-pattern {
    position: absolute; inset: 0; opacity: 0.15;
    background-image: url('/images/kurumsal-bg.jpg');
    background-size: cover;
    background-position: center;
    mix-blend-mode: luminosity;
    z-index: 1;
}

.tz-category-hero-content {
    position: relative; z-index: 2; max-width: 800px; margin: 0 auto;
}

.tz-badge-gold {
    display: inline-block; background: rgba(255, 120, 0, 0.15); color: var(--color-accent);
    padding: 8px 18px; border-radius: 30px; font-size: 0.85rem; font-weight: 700;
    letter-spacing: 1px; text-transform: uppercase; margin-bottom: 20px;
    border: 1px solid rgba(255, 120, 0, 0.3);
}

/* Spesifik selectors — global.css h1/h2/h3 { color: var(--color-primary) } kuralını override eder */
header.tz-category-hero h1 {
    font-size: clamp(2.2rem, 4vw, 3.5rem); font-weight: 700; line-height: 1.15; margin-bottom: 24px; color: #ffffff;
}
header.tz-category-hero h1 span {
    color: var(--color-highlight);
}
header.tz-category-hero p {
    font-size: clamp(1.1rem, 2vw, 1.25rem); color: rgba(255,255,255,0.85); font-weight: 400; line-height: 1.6;
}

/* 2. SERVICES GRID */
.tz-services-section {
    background-color: var(--color-bg); /* global.css --color-bg: #fafaf7 ile senkron */
    padding: 20px 0 80px;
}

.tz-services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 40px;
}

.tz-service-card {
    background: #fff; border-radius: 16px; overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex; flex-direction: column; border: 1px solid #e2e8f0;
    text-decoration: none; color: inherit; position: relative;
}
.tz-service-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.08); border-color: #cbd5e1; }
.tz-service-card::before {
    content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    transform: scaleX(0); transform-origin: left; transition: transform 0.4s ease; z-index: 10;
}
.tz-service-card:hover::before { transform: scaleX(1); }

.tz-card-image { position: relative; height: 260px; overflow: hidden; }
.tz-card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
.tz-service-card:hover .tz-card-image img { transform: scale(1.05); }

.tz-card-image::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,21,48,0.9) 0%, rgba(0,21,48,0) 80%);
}

.tz-card-title-overlay {
    position: absolute; bottom: 20px; left: 24px; right: 24px; z-index: 2;
}
.tz-card-title-overlay h2 {
    color: #fff; font-size: 1.5rem; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 10px;
}
.tz-card-icon { width: 24px; height: 24px; stroke: var(--color-accent); }

.tz-card-content { padding: 30px 24px; flex-grow: 1; display: flex; flex-direction: column; }
.tz-card-desc { color: #475569; font-size: 0.95rem; line-height: 1.6; margin-bottom: 24px; }

.tz-sub-services { list-style: none; margin-bottom: 30px; flex-grow: 1; padding: 0; }
.tz-sub-services li {
    position: relative; padding-left: 24px; margin-bottom: 12px; font-size: 0.95rem; color: var(--color-primary); font-weight: 600;
}
.tz-sub-services li.tz-sub-more {
    font-style: italic; color: #64748b; font-size: 0.85rem; padding-left: 0; margin-top: 15px; font-weight: 400;
}
.tz-sub-services li:not(.tz-sub-more)::before {
    content: '→'; position: absolute; left: 0; top: 0; color: var(--color-accent); font-weight: bold;
}

.tz-card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 20px; border-top: 1px solid rgba(0,0,0,0.05); }
.tz-technique-count { font-size: 0.8rem; font-weight: 700; color: var(--color-primary); background: rgba(10, 25, 47, 0.05); padding: 5px 12px; border-radius: 12px; }

.tz-card-action {
    display: flex; align-items: center; color: var(--color-primary); font-weight: 700; font-size: 0.95rem;
    text-transform: uppercase; letter-spacing: 0.5px; transition: all 0.3s ease;
}
.tz-card-action svg { margin-left: 6px; transition: transform 0.3s; }
.tz-service-card:hover .tz-card-action { color: var(--color-accent); }
.tz-service-card:hover .tz-card-action svg { transform: translateX(5px); }

/* 3. STATS */
.tz-stats-section { background-color: #fff; padding: 70px 0; border-top: 1px solid rgba(0,0,0,0.05); border-bottom: 1px solid rgba(0,0,0,0.05); }
.tz-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; text-align: center; }
.tz-stat-item h3 { font-size: clamp(2rem, 3vw, 3rem); font-weight: 700; color: var(--color-primary); line-height: 1; margin: 0 0 10px 0; }
.tz-stat-item h3 span { color: var(--color-accent); }
.tz-stat-item p { color: #64748b; font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5em; margin: 0; }

@media (max-width: 900px) {
    .tz-stats-grid { grid-template-columns: repeat(2, 1fr); gap: 40px 30px; }
}
@media (max-width: 600px) {
    .tz-services-grid { grid-template-columns: 1fr; }
}
</style>
