<script>
  // ── Arama + View Toggle + Sıralama ──
  const state = { q: '' };

  const grid       = document.getElementById('mpGrid')!;
  const list       = document.getElementById('mpList') as HTMLDivElement;
  const empty      = document.getElementById('mpEmpty') as HTMLDivElement;
  const resetBtn   = document.getElementById('mpReset') as HTMLButtonElement;
  const searchEl   = document.getElementById('mpSearch') as HTMLInputElement;
  const viewBtns   = document.querySelectorAll<HTMLButtonElement>('.mp-view-btn');
  const cards      = document.querySelectorAll<HTMLElement>('.mp-card');
  const groupHeads = document.querySelectorAll<HTMLElement>('.mp-group-head');
  const grids      = document.querySelectorAll<HTMLElement>('.mp-grid');
  const tableBlocks = document.querySelectorAll<HTMLElement>('#mpList .mp-list-wrap');
  const rows       = document.querySelectorAll<HTMLTableRowElement>('#mpList tbody tr');
  const sortHdrs   = document.querySelectorAll<HTMLTableCellElement>('th.sortable');

  function entryUygun(el: HTMLElement): boolean {
    const q = state.q.toLocaleLowerCase('tr').trim();
    return !q || (el.dataset.search ?? '').includes(q);
  }

  function uygulaFiltre() {
    let totalVisible = 0;
    // Kart bazlı görünürlük + her grup için ayrı sayım
    const visibleByGroup: Record<string, number> = { 'ana-makine': 0, 'yardimci-ekipman': 0 };
    cards.forEach((c) => {
      if (entryUygun(c)) {
        c.removeAttribute('data-hidden');
        totalVisible++;
        const g = c.dataset.grup ?? '';
        visibleByGroup[g] = (visibleByGroup[g] ?? 0) + 1;
      } else c.setAttribute('data-hidden', 'true');
    });
    // Liste satırları
    rows.forEach((r) => {
      if (entryUygun(r)) r.removeAttribute('data-hidden');
      else r.setAttribute('data-hidden', 'true');
    });
    // Grup başlıklarını ve grid bloklarını boş ise gizle
    groupHeads.forEach((h) => {
      const g = h.dataset.group ?? '';
      h.hidden = g in visibleByGroup ? visibleByGroup[g] === 0 : false;
    });
    grids.forEach((gr, i) => {
      // İlk grid ana-makine, ikincisi yardimci-ekipman
      const groupKey = i === 0 ? 'ana-makine' : 'yardimci-ekipman';
      gr.hidden = visibleByGroup[groupKey] === 0;
    });
    empty.hidden = totalVisible > 0;
  }

  // Arama
  searchEl.addEventListener('input', () => { state.q = searchEl.value; uygulaFiltre(); });

  // Reset (empty state'te kullanılır)
  resetBtn.addEventListener('click', () => {
    state.q = '';
    searchEl.value = '';
    uygulaFiltre();
  });

  // View toggle
  viewBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const view = btn.dataset.view as 'grid' | 'list';
      viewBtns.forEach((b) => b.classList.toggle('mp-view-btn--active', b === btn));
      if (view === 'grid') { grid.hidden = false; list.hidden = true; }
      else                 { grid.hidden = true;  list.hidden = false; }
    });
  });

  // Sıralama (liste mode'da sütun başlığı tıklanır)
  // Aynı sütun her iki tabloda (Ana / Yardımcı) ayrı ayrı sıralanır.
  sortHdrs.forEach((hdr) => {
    hdr.addEventListener('click', () => {
      const key = hdr.dataset.sort as 'isim' | 'tip' | 'marka' | 'yil';
      const cur = hdr.dataset.direction;
      const dir = cur === 'asc' ? 'desc' : 'asc';
      // Sadece bu sütun başlığı için işaretlemeyi sıfırla, diğer tabloyu etkileme
      const ownTable = hdr.closest('table');
      ownTable?.querySelectorAll<HTMLTableCellElement>('th.sortable')
        .forEach((h) => h.removeAttribute('data-direction'));
      hdr.dataset.direction = dir;

      const tbody = ownTable?.querySelector('tbody') as HTMLTableSectionElement;
      const tableRows = [...tbody.querySelectorAll('tr')];
      tableRows.sort((a, b) => {
        let va: string | number = a.dataset[key] ?? '';
        let vb: string | number = b.dataset[key] ?? '';
        if (key === 'yil') { va = Number(va); vb = Number(vb); }
        if (va < vb) return dir === 'asc' ? -1 :  1;
        if (va > vb) return dir === 'asc' ?  1 : -1;
        return 0;
      });
      tableRows.forEach((r) => tbody.appendChild(r));
    });
  });
</script>
