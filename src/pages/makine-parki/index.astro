---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABox from '../../components/CTABox.astro';
import {
  makineler,
  makineSayisi,
  anaMakineler,
  yardimciEkipmanlar,
  anaMakineSayisi,
  yardimciEkipmanSayisi,
  benzersizMarkalar,
  filoMaksKazikCap,
  filoMaksDelgiDerinligi,
  filoMarkaUlkeleri,
  enYeniMakine,
  sirket,
} from '../../data/sirket';

const canonical = 'https://www.toremzemin.com/makine-parki/';

// Toplam birim sayısı (çoklu adetli makinelerle birlikte)
const toplamBirim = makineler.reduce((acc, m) => acc + m.adet, 0);

// Görsel için AVIF + WebP + (orijinal) kaynak yollarını üretir.
// `gorsel` .jpg ise raster üçlü (avif+webp+jpg), .svg ise tek kaynak döner.
function imgSources(gorsel: string) {
  if (gorsel.endsWith('.svg')) {
    return { isSvg: true, fallback: gorsel };
  }
  const base = gorsel.replace(/\.(jpe?g|png|webp)$/i, '');
  return {
    isSvg: false,
    avif: `${base}.avif`,
    webp: `${base}.webp`,
    fallback: gorsel,
  };
}

// Schema.org ItemList — her makine bir Product entity'sine
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Torem Zemin Mühendislik — Geoteknik Makine Parkı',
  numberOfItems: makineSayisi,
  itemListElement: makineler.map((m, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: m.isim,
      brand: { '@type': 'Brand', name: m.marka },
      model: m.model,
      category: m.tip,
      ...(m.yil > 0 ? { releaseDate: String(m.yil) } : {}),
      description: m.aciklama,
    },
  })),
};
---

<BaseLayout
  title={`Saha Kapasitesi — Mühendislik, Makine Parkı, Sevkiyat | Torem Zemin`}
  description={`Torem Zemin'in saha operasyon kapasitesi: ${anaMakineSayisi} ana makine + ${yardimciEkipmanSayisi} yardımcı ekipmanlık geoteknik filo, geoteknik mühendis kadrosu, 81 il sevkiyat ağı ve TBDY 2018 / ISO 9001 sertifikalı kalite sistemleri.`}
  canonical={canonical}
  schema={itemListSchema}
>
  <!-- ░░ HERO — FİLO MANİFESTOSU ░░ -->
  <section class="mp-hero">
    <div class="mp-hero__bg" aria-hidden="true"></div>
    <div class="mp-hero__grid-pattern" aria-hidden="true"></div>
    <div class="container mp-hero__inner">
      <p class="eyebrow">Saha Operasyon Kapasitesi</p>
      <h1>Mühendislik, Filo, Sevkiyat — <span class="accent">Aynı Operasyon Hattında</span></h1>
      <p class="mp-hero__lead">
        Geoteknik mühendis kadromuz, kendi makine parkımız, 81 il sevkiyat ağımız ve sertifikalı kalite sistemlerimiz tek bir operasyon hattında çalışır. Sahadaki aksaklığı minimize eden şey, bu dört bileşenin aynı çatı altında olmasıdır.
      </p>

      <!-- 4 mikro-stat -->
      <div class="mp-hero__stats">
        <div class="mp-stat">
          <span class="mp-stat__num">12+</span>
          <span class="mp-stat__lbl">Yıl Saha Pratiği<br/>Mühendis Kadrosu</span>
        </div>
        <div class="mp-stat">
          <span class="mp-stat__num">{anaMakineSayisi}+{yardimciEkipmanSayisi}</span>
          <span class="mp-stat__lbl">Ana Makine +<br/>Yardımcı Ekipman</span>
        </div>
        <div class="mp-stat">
          <span class="mp-stat__num">{sirket.hizmetAgiIl}</span>
          <span class="mp-stat__lbl">İl Sevkiyat<br/>Ağı</span>
        </div>
        <div class="mp-stat">
          <span class="mp-stat__num">ISO</span>
          <span class="mp-stat__lbl">9001 + TBDY 2018<br/>Sertifikalı</span>
        </div>
      </div>
    </div>
    <div class="mp-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,30 C360,60 720,0 1080,30 C1260,45 1380,40 1440,35 L1440,60 L0,60 Z" fill="var(--color-bg)" />
      </svg>
    </div>
  </section>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="bc">
        <li><a href="/">Ana Sayfa</a></li>
        <li aria-current="page">Saha Kapasitesi</li>
      </ol>
    </div>
  </nav>

  <!-- ░░ 4 OPERASYON SÜTUNU — Mühendis · Filo · Sevkiyat · Standart ░░ -->
  <section class="section pillars-section">
    <div class="container">
      <div class="pillars-grid">
        <article class="pillar">
          <div class="pillar__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <span class="pillar__num">01</span>
          <h2 class="pillar__title">Mühendislik Kadrosu</h2>
          <p class="pillar__desc">Geoteknik ve inşaat mühendisi ekibimiz ortalama 12+ yıl saha pratiğine sahiptir. Etüt-tasarım hattını <strong>May Geoteknik</strong> ortaklığımızla, uygulamayı kendi mühendis kadromuzla yürütürüz.</p>
          <ul class="pillar__list">
            <li>Geoteknik mühendisi denetimi her sahada</li>
            <li>Etüt → tasarım → uygulama tek hat</li>
            <li>Saha revizyonunu yerinde üretebilen kadro</li>
          </ul>
        </article>

        <article class="pillar pillar--gold">
          <div class="pillar__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6">
              <rect x="2" y="7" width="20" height="13" rx="2"/>
              <path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/>
              <path d="M2 13h20"/>
            </svg>
          </div>
          <span class="pillar__num">02</span>
          <h2 class="pillar__title">Makine Parkı</h2>
          <p class="pillar__desc"><strong>{anaMakineSayisi} ana makine + {yardimciEkipmanSayisi} yardımcı ekipman</strong> tamamen Torem Zemin'in mülkiyetindedir. Soilmec, Casagrande, Bauer, XCMG markaları — kiralık ekipman kuyruğuna bağımlı değiliz.</p>
          <ul class="pillar__list">
            <li>Kendi mülkiyetinde geoteknik filo</li>
            <li>{benzersizMarkalar.length} farklı üretici markası</li>
            <li>Pendik üzerinden anında sevkiyat</li>
          </ul>
          <a href="#filo" class="pillar__cta">Filoyu İncele ↓</a>
        </article>

        <article class="pillar">
          <div class="pillar__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6">
              <circle cx="12" cy="10" r="3"/>
              <path d="M12 22s-7-7-7-12a7 7 0 0114 0c0 5-7 12-7 12z"/>
            </svg>
          </div>
          <span class="pillar__num">03</span>
          <h2 class="pillar__title">Saha Sevkiyat Ağı</h2>
          <p class="pillar__desc">Pendik/İstanbul operasyon merkezimizden <strong>{sirket.hizmetAgiIl} il geneline</strong> mühendis ve ekipman sevki yapılır. Yedi coğrafi bölgenin tamamında saha tecrübemiz vardır.</p>
          <ul class="pillar__list">
            <li>Pendik merkez + Türkiye geneli</li>
            <li>7 coğrafi bölge — Marmara'dan Doğu'ya</li>
            <li>Mobil ekip — saha yerinde mühendislik</li>
          </ul>
          <a href="/referanslar/" class="pillar__cta">Coğrafi Kapsamı Gör →</a>
        </article>

        <article class="pillar">
          <div class="pillar__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="M9 12l2 2 4-4"/>
            </svg>
          </div>
          <span class="pillar__num">04</span>
          <h2 class="pillar__title">Kalite & Standartlar</h2>
          <p class="pillar__desc">Tüm uygulamalarımız <strong>TBDY 2018</strong> ve ilgili TS EN standartlarına uygun olarak yürütülür. <strong>ISO 9001:2015</strong> kalite yönetim sistemi çerçevesinde çalışıyoruz.</p>
          <ul class="pillar__list">
            <li>ISO 9001:2015 Kalite Yönetimi</li>
            <li>TBDY 2018 Deprem Yönetmeliği</li>
            <li>TS EN 1536, 1537, 12716, 14199</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ░░ SMART TOOLBAR — Arama + View Toggle ░░ -->
  <div class="mp-toolbar-wrap" id="filo">
    <div class="container">
      <div class="mp-toolbar">
        <div class="mp-search">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/>
          </svg>
          <input
            type="search"
            id="mpSearch"
            placeholder="Makine, marka veya tip ara — örn. Soilmec, Bauer, Jet Grout..."
            autocomplete="off"
            aria-label="Makine arama"
          />
        </div>

        <div class="mp-view-toggle" role="group" aria-label="Görünüm modu">
          <button class="mp-view-btn mp-view-btn--active" data-view="grid" aria-label="Grid görünümü">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            <span>Grid</span>
          </button>
          <button class="mp-view-btn" data-view="list" aria-label="Liste görünümü">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            <span>Liste</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ░░ MAKİNE LİSTESİ — 2 BÖLÜM: Ana Makineler + Yardımcı Ekipmanlar ░░ -->
  <section class="section section--no-pad-top">
    <div class="container">

      <!-- ══ GRID VIEW ══ -->
      <div id="mpGrid">
        <!-- Ana Makineler -->
        <header class="mp-group-head" data-group="ana-makine">
          <div>
            <p class="mp-group-eyebrow">Üretim Hattının Çekirdeği</p>
            <h2 class="mp-group-title">Ana Makineler <span class="mp-group-count">{anaMakineSayisi}</span></h2>
          </div>
          <p class="mp-group-desc">Fore kazık, jet grout, ankraj ve mini kazık delgilerini bizzat yapan ana üretim makineleri.</p>
        </header>

        <div class="mp-grid">
          {anaMakineler.map((m) => (
            <article
              class="mp-card"
              data-grup="ana-makine"
              data-tip={m.tip}
              data-marka={m.marka}
              data-search={`${m.isim} ${m.marka} ${m.model} ${m.tip}`.toLocaleLowerCase('tr')}
            >
              <div class="mp-card__visual">
                {(() => {
                  const s = imgSources(m.gorsel);
                  if (s.isSvg) {
                    return <img src={s.fallback} alt={`${m.isim} — ${m.tip}`} loading="lazy" decoding="async" width="400" height="400" />;
                  }
                  return (
                    <picture>
                      <source srcset={s.avif} type="image/avif" />
                      <source srcset={s.webp} type="image/webp" />
                      <img src={s.fallback} alt={`${m.isim} — ${m.tip}`} loading="lazy" decoding="async" width="400" height="400" />
                    </picture>
                  );
                })()}
                <span class="mp-card__tip-badge">{m.tip}</span>
                {m.yil > 0 && (
                  <span class="mp-card__yil-badge" title={`Model yılı ${m.yil}`}>
                    <span class="mp-card__yil-badge__lbl">Model</span>{m.yil}
                  </span>
                )}
                {m.adet > 1 && <span class="mp-card__adet-badge">{m.adet} birim</span>}
              </div>
              <div class="mp-card__body">
                <div class="mp-card__head">
                  <span class="mp-card__marka">{m.marka}</span>
                </div>
                <h3 class="mp-card__isim">{m.isim}</h3>
                <p class="mp-card__desc">{m.aciklama}</p>
                <div class="mp-spec-grid">
                  {m.ozellikler.map((s) => (
                    <div class="mp-spec">
                      <span class="mp-spec__l">{s.l}</span>
                      <span class="mp-spec__v">{s.v}</span>
                    </div>
                  ))}
                </div>
              </div>
              <a href="/iletisim/" class="mp-card__cta">Bu Makine Hakkında Bilgi Al →</a>
            </article>
          ))}
        </div>

        <!-- Yardımcı Ekipmanlar -->
        <header class="mp-group-head mp-group-head--secondary" data-group="yardimci-ekipman">
          <div>
            <p class="mp-group-eyebrow mp-group-eyebrow--earth">Operasyonu Destekleyen Donanım</p>
            <h2 class="mp-group-title">Yardımcı Ekipmanlar <span class="mp-group-count">{yardimciEkipmanSayisi}</span></h2>
          </div>
          <p class="mp-group-desc">Kompresör, enjeksiyon pompası, vibratör, püskürtme makinesi ve germe krikosu — ana makinelere hizmet eden destek donanımı.</p>
        </header>

        <div class="mp-grid mp-grid--secondary">
          {yardimciEkipmanlar.map((m) => (
            <article
              class="mp-card mp-card--secondary"
              data-grup="yardimci-ekipman"
              data-tip={m.tip}
              data-marka={m.marka}
              data-search={`${m.isim} ${m.marka} ${m.model} ${m.tip}`.toLocaleLowerCase('tr')}
            >
              <div class="mp-card__visual">
                {(() => {
                  const s = imgSources(m.gorsel);
                  if (s.isSvg) {
                    return <img src={s.fallback} alt={`${m.isim} — ${m.tip}`} loading="lazy" decoding="async" width="400" height="400" />;
                  }
                  return (
                    <picture>
                      <source srcset={s.avif} type="image/avif" />
                      <source srcset={s.webp} type="image/webp" />
                      <img src={s.fallback} alt={`${m.isim} — ${m.tip}`} loading="lazy" decoding="async" width="400" height="400" />
                    </picture>
                  );
                })()}
                <span class="mp-card__tip-badge mp-card__tip-badge--earth">{m.tip}</span>
                {m.yil > 0 && (
                  <span class="mp-card__yil-badge" title={`Model yılı ${m.yil}`}>
                    <span class="mp-card__yil-badge__lbl">Model</span>{m.yil}
                  </span>
                )}
                {m.adet > 1 && <span class="mp-card__adet-badge">{m.adet} birim</span>}
              </div>
              <div class="mp-card__body">
                <div class="mp-card__head">
                  <span class="mp-card__marka">{m.marka}</span>
                </div>
                <h3 class="mp-card__isim">{m.isim}</h3>
                <p class="mp-card__desc">{m.aciklama}</p>
                <div class="mp-spec-grid">
                  {m.ozellikler.map((s) => (
                    <div class="mp-spec">
                      <span class="mp-spec__l">{s.l}</span>
                      <span class="mp-spec__v">{s.v}</span>
                    </div>
                  ))}
                </div>
              </div>
              <a href="/iletisim/" class="mp-card__cta">Bu Ekipman Hakkında Bilgi Al →</a>
            </article>
          ))}
        </div>
      </div>

      <!-- ══ LIST VIEW (varsayılan gizli) ══ -->
      <div id="mpList" hidden>
        <!-- Ana Makineler tablosu -->
        <header class="mp-group-head">
          <div>
            <p class="mp-group-eyebrow">Üretim Hattının Çekirdeği</p>
            <h2 class="mp-group-title">Ana Makineler <span class="mp-group-count">{anaMakineSayisi}</span></h2>
          </div>
        </header>
        <div class="mp-list-wrap">
          <table class="mp-list-table">
            <thead>
              <tr>
                <th class="sortable" data-sort="isim">Makine</th>
                <th class="sortable" data-sort="tip">Tip</th>
                <th class="sortable" data-sort="marka">Marka</th>
                <th class="sortable" data-sort="yil">Yıl</th>
                <th>Ana Özellikler</th>
                <th>Adet</th>
              </tr>
            </thead>
            <tbody id="mpListBodyAna">
              {anaMakineler.map((m) => (
                <tr
                  data-grup="ana-makine"
                  data-tip={m.tip}
                  data-marka={m.marka}
                  data-yil={m.yil}
                  data-isim={m.isim}
                  data-search={`${m.isim} ${m.marka} ${m.model} ${m.tip}`.toLocaleLowerCase('tr')}
                >
                  <td><strong>{m.isim}</strong></td>
                  <td><span class="mp-tip-pill">{m.tip}</span></td>
                  <td>{m.marka}</td>
                  <td>{m.yil > 0 ? m.yil : '—'}</td>
                  <td class="mp-list-spec">
                    {m.ozellikler.slice(0, 2).map((s) => (
                      <span class="mp-list-spec__item"><b>{s.l}:</b> {s.v}</span>
                    ))}
                  </td>
                  <td><span class="mp-adet">{m.adet}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Yardımcı Ekipmanlar tablosu -->
        <header class="mp-group-head mp-group-head--secondary">
          <div>
            <p class="mp-group-eyebrow mp-group-eyebrow--earth">Operasyonu Destekleyen Donanım</p>
            <h2 class="mp-group-title">Yardımcı Ekipmanlar <span class="mp-group-count">{yardimciEkipmanSayisi}</span></h2>
          </div>
        </header>
        <div class="mp-list-wrap">
          <table class="mp-list-table">
            <thead>
              <tr>
                <th class="sortable" data-sort="isim">Ekipman</th>
                <th class="sortable" data-sort="tip">Tip</th>
                <th class="sortable" data-sort="marka">Marka</th>
                <th class="sortable" data-sort="yil">Yıl</th>
                <th>Ana Özellikler</th>
                <th>Adet</th>
              </tr>
            </thead>
            <tbody id="mpListBodyYardimci">
              {yardimciEkipmanlar.map((m) => (
                <tr
                  data-grup="yardimci-ekipman"
                  data-tip={m.tip}
                  data-marka={m.marka}
                  data-yil={m.yil}
                  data-isim={m.isim}
                  data-search={`${m.isim} ${m.marka} ${m.model} ${m.tip}`.toLocaleLowerCase('tr')}
                >
                  <td><strong>{m.isim}</strong></td>
                  <td><span class="mp-tip-pill mp-tip-pill--earth">{m.tip}</span></td>
                  <td>{m.marka}</td>
                  <td>{m.yil > 0 ? m.yil : '—'}</td>
                  <td class="mp-list-spec">
                    {m.ozellikler.slice(0, 2).map((s) => (
                      <span class="mp-list-spec__item"><b>{s.l}:</b> {s.v}</span>
                    ))}
                  </td>
                  <td><span class="mp-adet">{m.adet}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Empty state -->
      <div class="mp-empty" id="mpEmpty" hidden>
        <p>Bu filtrelere uyan makine yok.</p>
        <button class="mp-empty__reset" id="mpReset">Filtreleri Sıfırla</button>
      </div>

    </div>
  </section>

  <!-- ░░ FİLO KAPASİTE ÖZETİ — Numerik (pozitif tonda, kapasite vurgusu) ░░ -->
  <section class="mp-summary section">
    <div class="container">
      <div class="mp-summary__head">
        <p class="mp-summary__eyebrow">Filo Kapasitesi</p>
        <h2 class="mp-summary__title">Üretim Çıtamızı Belirleyen Sayılar</h2>
      </div>
      <div class="mp-summary__grid">
        <div class="mp-summary__item">
          <span class="mp-summary__num">{anaMakineSayisi}</span>
          <span class="mp-summary__lbl">Ana Üretim Makinesi</span>
        </div>
        <div class="mp-summary__item">
          <span class="mp-summary__num">{yardimciEkipmanSayisi}</span>
          <span class="mp-summary__lbl">Yardımcı Ekipman</span>
        </div>
        <div class="mp-summary__item">
          <span class="mp-summary__num">Ø{filoMaksKazikCap} <span class="mp-summary__unit">cm</span></span>
          <span class="mp-summary__lbl">Maks Kazık Çapı</span>
        </div>
        <div class="mp-summary__item">
          <span class="mp-summary__num">{filoMaksDelgiDerinligi} <span class="mp-summary__unit">m</span></span>
          <span class="mp-summary__lbl">Maks Delgi Derinliği</span>
        </div>
        <div class="mp-summary__item">
          <span class="mp-summary__num">{filoMarkaUlkeleri.length}</span>
          <span class="mp-summary__lbl">Üretici Ülkesi<br/><span class="mp-summary__sublbl">Avrupa · Asya entegre</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="section container">
    <CTABox title="Projeniz İçin Doğru Makineyi Birlikte Seçelim" />
  </div>
</BaseLayout>

<style>
/* ── HERO — FİLO MANİFESTOSU ── */
.mp-hero {
  position:relative;
  margin-top:-110px;
  padding-block:calc(var(--s-20) + 110px) calc(var(--s-16) + 60px);
  background:
