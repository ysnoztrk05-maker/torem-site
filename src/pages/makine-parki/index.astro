---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABox from '../../components/CTABox.astro';

/* Unsplash fallback'ler */
const uf = {
  drill: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&q=80',
  anchor: 'https://images.unsplash.com/photo-1590577976322-3d2d6e2130d5?w=800&q=80',
  equip: 'https://images.unsplash.com/photo-1581094794329-c8112a89af12?w=800&q=80',
  aux: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80',
};

const foreKazik = [
  {
    name: 'Soilmec SR-40', year: '2009', category: 'Fore Kazık',
    desc: 'Kazıklı temeller, iksa ve zemin iyileştirme projelerinde ana üretim makinesi.',
    image: '/images/makineler/soilmec-sr40.webp',
    specs: [{ l:'Çap', v:'Ø150 cm' }, { l:'Derinlik', v:'36 m' }, { l:'Ağırlık', v:'50 ton' }, { l:'Boyut', v:'19×6×5 m' }],
  },
  {
    name: 'XCMG-220RD', year: '2016', category: 'Fore Kazık',
    desc: 'Yüksek kapasiteli, büyük çaplı ve derin kazık projeleri için tasarlanmış büyük tonajlı makine.',
    image: '/images/makineler/soilmec-sr40-saha.jpg',
    specs: [{ l:'Çap', v:'Ø200 cm' }, { l:'Derinlik', v:'45 m' }, { l:'Ağırlık', v:'85 ton' }, { l:'Boyut', v:'22×9×5 m' }],
  },
  {
    name: 'Casagrande B200 XP', year: '2012', category: 'Fore Kazık',
    desc: 'Derin kazık uygulamaları için geliştirilmiş İtalyan teknolojisi. Metro ve altyapı projelerinde tercih edilir.',
    image: '/images/makineler/casagrande-b200xp.jpg',
    specs: [{ l:'Çap', v:'Ø200 cm' }, { l:'Derinlik', v:'48 m' }, { l:'Ağırlık', v:'75 ton' }, { l:'Boyut', v:'22×8×5 m' }],
  },
  {
    name: 'Soilmec CM-40', year: '2006', category: 'Fore Kazık',
    desc: 'Orta ölçekli kazık projelerinde kullanılan kompakt fore kazık makinesi.',
    image: '/images/hero-main.jpg',
    specs: [{ l:'Çap', v:'Ø120 cm' }, { l:'Derinlik', v:'25 m' }, { l:'Ağırlık', v:'40 ton' }, { l:'Boyut', v:'18×7×5 m' }],
  },
  {
    name: 'Bauer BG 18H', year: '2005', category: 'Fore Kazık',
    desc: 'Alman mühendisliği ile üretilen güçlü performanslı fore kazık makinesi.',
    image: '/images/makineler/bauer-bg20.jpg',
    specs: [{ l:'Çap', v:'Ø200 cm' }, { l:'Derinlik', v:'36 m' }, { l:'Ağırlık', v:'70 ton' }, { l:'Boyut', v:'20×6×5 m' }],
  },
];

const ankrajJg = [
  {
    name: 'Soilmec SM-400', year: '2005', category: 'Jet Grout',
    desc: 'Jet grout, mikro kazık ve zemin iyileştirme uygulamalarında kullanılan çok amaçlı makine. 2 adet mevcut.',
    image: '/images/zemin-iyilestirme.jpg',
    specs: [{ l:'Derinlik', v:'48 m' }, { l:'Kolon', v:'Ø40 cm' }, { l:'Ağırlık', v:'16 ton' }, { l:'Adet', v:'2 birim' }],
  },
  {
    name: 'YMC-TR Ankraj', year: '2016', category: 'Ankraj',
    desc: 'Yüksek kapasiteli öngermeli ankraj, kalıcı ankraj ve zemin çivisi uygulamalarında kullanılır.',
    image: '/images/makineler/ankraj-makinesi.jpg',
    specs: [{ l:'Tork', v:'1800 kNm' }, { l:'Ağırlık', v:'18 ton' }, { l:'Boyut', v:'9×7×3 m' }, { l:'Alan', v:'İksa & Ankraj' }],
  },
  {
    name: 'Casagrande C6', year: '2007', category: 'Mini Kazık',
    desc: 'Sınırlı alanlarda mikro kazık, ankraj ve sondaj uygulamalarında kullanılan kompakt makine.',
    image: '/images/makineler/mini-kazik-makinesi.jpg',
    specs: [{ l:'Tork', v:'1600 kNm' }, { l:'Ağırlık', v:'15 ton' }, { l:'Boyut', v:'8×6×3 m' }, { l:'Alan', v:'Mini Kazık' }],
  },
  {
    name: 'Furukawa HCR1200-DS', year: '2007', category: 'Zemin Çivisi',
    desc: 'İksa sistemleri, zemin çivisi ve ankraj uygulamalarında kullanılan çok amaçlı sondaj makinesi.',
    image: '/images/ankraj.jpg',
    specs: [{ l:'Derinlik', v:'25 m' }, { l:'Çap', v:'Ø150 mm' }, { l:'Ağırlık', v:'25 ton' }, { l:'Boyut', v:'8×7×3 m' }],
  },
];

const yardimci = [
  {
    name: 'PTC 30HD Vibro', year: '', category: 'Vibratör',
    desc: 'Palplanş ve çelik kazık çakma/sökme işlemlerinde kullanılan hidrolik vibratör.',
    image: '/images/makineler/ptc-vibro.jpg',
    specs: [{ l:'Kapasite', v:'30 ton' }, { l:'Güç', v:'300 kW' }, { l:'Frekans', v:'23–38 Hz' }, { l:'Tip', v:'Çakma & Söküm' }],
  },
  {
    name: 'Tecnipwell TW-352', year: '2005', category: 'Enjeksiyon',
    desc: 'Jet grout besleme, zemin iyileştirme ve mikro kazık için yüksek basınçlı enjeksiyon pompası.',
    image: '/images/makineler/enjeksiyon-seti.jpg',
    specs: [{ l:'Basınç', v:'550 bar' }, { l:'Tip', v:'JG Pompası' }, { l:'Zemin İyl.', v:'Evet' }, { l:'Mikro Kazık', v:'Evet' }],
  },
  {
    name: 'Atlas Copco XAVS 307', year: '2010', category: 'Kompresör',
    desc: 'Sondaj, püskürtme beton ve jet grouting işlemlerinde hava ihtiyacını karşılayan mobil kompresör.',
    image: uf.aux,
    specs: [{ l:'Basınç', v:'14 bar' }, { l:'Debi', v:'18,5 m³/dk' }, { l:'Tip', v:'Mobil Dizel' }, { l:'Marka', v:'Atlas Copco' }],
  },
  {
    name: 'Shotcrete MC-260', year: '2015', category: 'Püskürtme Beton',
    desc: 'Şev stabilitesi, tünel desteği ve yapı güçlendirme uygulamalarında kuru beton püskürtme.',
    image: '/images/puskurtme-beton.jpg',
    specs: [{ l:'Kapasite', v:'5–7 m³/s' }, { l:'Sistem', v:'Kuru Tip' }, { l:'Alan', v:'Şev & Tünel' }, { l:'Adet', v:'1 birim' }],
  },
  {
    name: 'Pistonlu Enjeksiyon Seti', year: '2014', category: 'Enjeksiyon',
    desc: 'Zemin iyileştirme, su yalıtımı, çatlak doldurma ve mikro kazık uygulamalarında enjeksiyon sistemi.',
    image: uf.equip,
    specs: [{ l:'Basınç', v:'150 bar' }, { l:'Adet', v:'2 birim' }, { l:'Alan', v:'Zemin Enj.' }, { l:'Mikro Kazık', v:'Evet' }],
  },
  {
    name: 'Germe Krikosu', year: '2015', category: 'Ankraj',
    desc: 'Öngermeli ve kalıcı ankraj uygulamalarında çelik halatları proje yüküne germe.',
    image: uf.anchor,
    specs: [{ l:'Kapasite', v:'80 ton' }, { l:'Tip', v:'Hidromekanik' }, { l:'Alan', v:'Ankraj Germe' }, { l:'Hassasiyet', v:'Yüksek' }],
  },
];

const gruplar = [
  { title: 'Fore Kazık Makineleri', items: foreKazik },
  { title: 'Mini Kazık / Ankraj / Jet Grout', items: ankrajJg },
  { title: 'Yardımcı Makine ve Ekipmanlar', items: yardimci },
];

const stats = [
  { num: '40+', label: 'İş Makinesi' },
  { num: '5', label: 'Fore Kazık Makinesi' },
  { num: '4', label: 'JG & Ankraj Makinesi' },
  { num: '7/24', label: 'Teknik Destek' },
];
---

<BaseLayout
  title="Makine Parkı | Fore Kazık ve Geoteknik Ekipmanlar | Torem Zemin"
  description="Soilmec SR-40, Casagrande B200 XP, Bauer BG18H, XCMG-220RD fore kazık makineleri, Soilmec SM-400 jet grout ve ankraj ekipmanları. 40+ modern geoteknik iş makinesi."
>
  <!-- Hero -->
  <section class="mp-hero">
    <div class="mp-hero__bg" aria-hidden="true"></div>
    <div class="container mp-hero__inner">
      <p class="eyebrow">Ekipman Filosu</p>
      <h1>Modern Makine<br><span>Parkımız</span></h1>
      <p>40'ı aşkın modern geoteknik iş makinesiyle Türkiye genelinde hizmet. Soilmec, Casagrande, Bauer ve XCMG markaları ile güvenilir performans.</p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="bc">
        <li><a href="/">Ana Sayfa</a></li>
        <li aria-current="page">Makine Parkı</li>
      </ol>
    </div>
  </nav>

  <!-- Stats -->
  <section class="section section--dark">
    <div class="container">
      <div class="mp-stats">
        {stats.map((s) => (
          <div class="mpstat">
            <span class="mpstat__num">{s.num}</span>
            <span class="mpstat__lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Makine Grupları — 3 Sütun Kart Grid -->
  {gruplar.map((g) => (
    <section class="section">
      <div class="container">
        <h2 class="grup-title">{g.title}</h2>
        <div class="mk-grid">
          {g.items.map((m) => (
            <article class="mk">
              <div class="mk__visual">
                <img src={m.image} alt={m.name} loading="lazy" width="800" height="500" />
                <span class="mk__cat">{m.category}</span>
              </div>
              <div class="mk__body">
                <h3 class="mk__name">{m.name}</h3>
                {m.year && <span class="mk__year">{m.year}</span>}
                <p class="mk__desc">{m.desc}</p>
                <div class="mk__specs">
                  {m.specs.map((s) => (
                    <div class="sp">
                      <span class="sp__v">{s.v}</span>
                      <span class="sp__l">{s.l}</span>
                    </div>
                  ))}
                </div>
                <a href="/iletisim/" class="mk__cta">Teklif Al →</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <div class="section container">
    <CTABox title="Makine Parkımız Hakkında Bilgi Alın" />
  </div>
</BaseLayout>

<style>
.eyebrow { font-size:var(--text-sm); font-weight:700; color:#E8A85A; text-transform:uppercase; letter-spacing:.08em; margin-bottom:var(--s-3); }

/* ── Hero ── */
.mp-hero {
  background:linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  padding-block:var(--s-20) var(--s-16); color:var(--color-white);
  position:relative; overflow:hidden; text-align:center;
}
.mp-hero__bg { position:absolute; inset:0; background:radial-gradient(ellipse at 40% 60%, rgba(74,127,165,.3) 0%, transparent 55%); pointer-events:none; }
.mp-hero__inner { position:relative; z-index:1; max-width:640px; margin-inline:auto; }
.mp-hero h1 { color:var(--color-white); font-size:var(--text-5xl); margin-bottom:var(--s-4); }
.mp-hero h1 span { color:#E8A85A; }
.mp-hero p { color:rgba(255,255,255,.75); font-size:var(--text-lg); }

/* ── Breadcrumb ── */
.breadcrumb-bar { background:var(--color-white); border-bottom:1px solid var(--color-border); padding-block:var(--s-3); }
.bc { display:flex; flex-wrap:wrap; gap:var(--s-1); font-size:var(--text-sm); color:var(--color-text-muted); list-style:none; }
.bc li+li::before { content:'›'; margin-right:var(--s-1); }
.bc a { color:var(--color-accent); }
.bc a:hover { color:var(--color-highlight); }

/* ── Stats ── */
.section--dark { background:var(--color-primary); }
.mp-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--s-6); }
.mpstat { text-align:center; padding:var(--s-6); }
.mpstat__num { display:block; font-size:var(--text-4xl); font-weight:700; color:var(--color-highlight); }
.mpstat__lbl { font-size:var(--text-sm); color:rgba(255,255,255,.65); text-transform:uppercase; letter-spacing:.05em; }

/* ── Grup Başlık ── */
.grup-title {
  font-size:var(--text-2xl); font-weight:700; color:var(--color-primary);
  margin-bottom:var(--s-8); padding-bottom:var(--s-3);
  border-bottom:3px solid var(--color-highlight); display:inline-block;
}

/* ── 3 Sütun Kart Grid ── */
.mk-grid {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:var(--s-6);
}

/* ── Kart ── */
.mk {
  background:var(--color-white);
  border-radius:var(--r-xl);
  overflow:hidden;
  border:1px solid var(--color-border);
  display:flex; flex-direction:column;
  transition:transform var(--t-base), box-shadow var(--t-base);
}
.mk:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }

/* Görsel: sabit 220px */
.mk__visual {
  position:relative;
  height:220px;
  overflow:hidden;
}
.mk__visual img {
  position:absolute; inset:0;
  width:100%; height:100%;
  object-fit:cover;
  transition:transform var(--t-slow);
}
.mk:hover .mk__visual img { transform:scale(1.05); }
.mk__cat {
  position:absolute; top:var(--s-3); left:var(--s-3); z-index:1;
  background:#C8873A; color:#fff;
  font-size:10px; font-weight:700;
  padding:.25rem .65rem; border-radius:999px;
  text-transform:uppercase; letter-spacing:.04em;
}

/* Body */
.mk__body {
  padding:var(--s-5); display:flex; flex-direction:column; flex:1;
}
.mk__name {
  font-size:var(--text-lg); font-weight:700; color:var(--color-primary);
  line-height:1.25; margin-bottom:var(--s-1);
}
.mk__year {
  font-size:var(--text-xs); color:var(--color-accent); font-weight:600;
  margin-bottom:var(--s-3);
}
.mk__desc {
  font-size:var(--text-sm); color:var(--color-text-muted); line-height:1.65;
  margin-bottom:var(--s-4);
  display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;
}

/* Spec 2x2 grid */
.mk__specs {
  display:grid; grid-template-columns:1fr 1fr; gap:var(--s-2);
  margin-bottom:var(--s-4); margin-top:auto;
}
.sp {
  background:var(--color-bg); border:1px solid var(--color-border);
  border-radius:var(--r-sm); padding:var(--s-2); text-align:center;
}
.sp__v { display:block; font-size:var(--text-sm); font-weight:700; color:var(--color-primary); line-height:1.2; }
.sp__l { font-size:9px; color:var(--color-text-muted); text-transform:uppercase; letter-spacing:.03em; }

/* CTA Buton */
.mk__cta {
  display:block; text-align:center;
  background:var(--color-highlight); color:#fff;
  font-size:var(--text-sm); font-weight:600;
  padding:var(--s-3); border-radius:var(--r-md);
  transition:background var(--t-fast);
}
.mk__cta:hover { background:#b5762f; }

/* ── Responsive ── */
@media (max-width:1024px) { .mk-grid { grid-template-columns:repeat(2,1fr); } }
@media (max-width:640px) {
  .mk-grid { grid-template-columns:1fr; }
  .mp-stats { grid-template-columns:repeat(2,1fr); }
}
</style>
