---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABox from '../../components/CTABox.astro';

const makineler = [
  {
    name: 'Soilmec SR-40',
    type: 'Fore Kazık Makinesi',
    specs: ['Maks. delgi çapı: Ø1200 mm', 'Maks. derinlik: 43 m', 'Tork: 160 kNm', 'Ağırlık: 52 ton'],
    desc: 'Orta-büyük ölçekli fore kazık projelerinde ana üretim makinesi. Yüksek tork kapasitesi ile sert formasyonlarda etkili delgi.',
    image: '/images/makine-parki.webp',
    category: 'Fore Kazık',
  },
  {
    name: 'Casagrande B200 XP',
    type: 'Fore Kazık Makinesi',
    specs: ['Maks. delgi çapı: Ø1500 mm', 'Maks. derinlik: 56 m', 'Tork: 200 kNm', 'Ağırlık: 65 ton'],
    desc: 'Büyük çaplı ve derin fore kazık imalatı için yüksek kapasiteli rotary delgi makinesi. Metro ve altyapı projelerinde tercih edilir.',
    image: '/images/kazikli-temeller.jpg',
    category: 'Fore Kazık',
  },
  {
    name: 'Bauer BG 20',
    type: 'Fore Kazık Makinesi',
    specs: ['Maks. delgi çapı: Ø1200 mm', 'Maks. derinlik: 46 m', 'Tork: 200 kNm', 'Ağırlık: 60 ton'],
    desc: 'Alman mühendisliği ile üretilen güvenilir fore kazık makinesi. Kelly bar ve CFA uygulamaları için modüler konfigürasyon.',
    image: '/images/hero-main.jpg',
    category: 'Fore Kazık',
  },
  {
    name: 'Soilmec SM-400',
    type: 'Ankraj / Jet Grout Makinesi',
    specs: ['Maks. derinlik: 50 m', 'Ankraj çapı: Ø90–200 mm', 'Jet grout basıncı: 400 bar', 'Ağırlık: 18 ton'],
    desc: 'Çok amaçlı geoteknik makinesi. Öngermeli ankraj, zemin çivisi, jet grout ve mikro kazık uygulamalarında kullanılır.',
    image: '/images/ankraj.jpg',
    category: 'Ankraj & Jet Grout',
  },
  {
    name: 'Mini Kazık Makineleri',
    type: 'Mikro Kazık / Enjeksiyon',
    specs: ['Çap: Ø114–300 mm', 'Derinlik: 25 m', 'Düşük tavan: min. 2,5 m', 'Kompakt boyut'],
    desc: 'Sınırlı alanlarda ve mevcut yapı içinde uygulanabilen kompakt delgi üniteleri. Bodrum kat güçlendirme ve mikro kazık imalatında kullanılır.',
    image: '/images/fore-kazik-saha.jpg',
    category: 'Mini Kazık',
  },
  {
    name: 'Enjeksiyon Seti',
    type: 'Çimento Enjeksiyon Ünitesi',
    specs: ['Basınç: 0–100 bar', 'Debi: 0–200 lt/dk', 'Karıştırıcı: 500 lt', 'Dijital kontrol'],
    desc: 'Zemin enjeksiyonu, ankraj enjeksiyonu ve jet grout besleme sistemi. Dijital basınç ve debi kontrolü ile hassas uygulama.',
    image: '/images/zemin-iyilestirme.jpg',
    category: 'Enjeksiyon',
  },
  {
    name: 'Püskürtme Beton Makinesi',
    type: 'Shotcrete Robotu',
    specs: ['Kapasite: 20 m³/saat', 'Menzil: 30 m', 'Robotik kol erişimi: 8 m', 'Kuru/yaş sistem'],
    desc: 'İksa yüzeyi kaplama, tünel destekleme ve şev koruma uygulamalarında kullanılan yüksek kapasiteli shotcrete makinesi.',
    image: '/images/puskurtme-beton.jpg',
    category: 'Püskürtme Beton',
  },
  {
    name: 'Kompresör & Yardımcı Ekipman',
    type: 'Destek Ekipmanları',
    specs: ['Atlas Copco kompresörler', 'Jeneratörler', 'Vinçler ve ekskavatörler', 'Beton pompaları'],
    desc: 'Tüm geoteknik uygulamaları destekleyen kompresör, jeneratör, vinç ve beton pompası filosu.',
    image: '/images/geoteknik-test.jpg',
    category: 'Destek',
  },
];

const stats = [
  { num: '40+', label: 'İş Makinesi' },
  { num: '8', label: 'Fore Kazık Makinesi' },
  { num: '6', label: 'Ankraj/Jet Grout Makinesi' },
  { num: '7/24', label: 'Teknik Destek' },
];
---

<BaseLayout
  title="Makine Parkı | Fore Kazık ve Geoteknik Ekipmanlar | Torem Zemin"
  description="Soilmec SR-40, Casagrande B200 XP, Bauer BG20 fore kazık makineleri ve Soilmec SM-400 ankraj/jet grout makinesi. 40+ modern geoteknik ekipman filosu."
>
  <!-- Hero -->
  <section class="mp-hero">
    <div class="mp-hero__bg" aria-hidden="true"></div>
    <div class="container mp-hero__inner">
      <p class="eyebrow">Ekipman Filosu</p>
      <h1>Modern Makine<br><span>Parkımız</span></h1>
      <p>40'ı aşkın modern geoteknik iş makinesiyle Türkiye genelinde hizmet. Soilmec, Casagrande ve Bauer markaları ile güvenilir performans.</p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="bc">
        <li><a href="/">Ana Sayfa</a></li>
        <li aria-current="page">Makine Parkı</li>
      </ol>
    </div>
  </nav>

  <!-- İstatistikler -->
  <section class="section section--dark">
    <div class="container">
      <div class="mp-stats">
        {stats.map((s) => (
          <div class="mpstat">
            <span class="mpstat__num">{s.num}</span>
            <span class="mpstat__lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Makine Grid -->
  <section class="section">
    <div class="container">
      <div class="mp-grid">
        {makineler.map((m) => (
          <article class="mcard">
            <div class="mcard__img-wrap">
              <img src={m.image} alt={m.name} loading="lazy" width="600" height="400" />
              <span class="mcard__cat">{m.category}</span>
            </div>
            <div class="mcard__body">
              <h2 class="mcard__name">{m.name}</h2>
              <p class="mcard__type">{m.type}</p>
              <p class="mcard__desc">{m.desc}</p>
              <ul class="mcard__specs">
                {m.specs.map((s) => <li>{s}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>

      <CTABox title="Makine Parkımız Hakkında Bilgi Alın" />
    </div>
  </section>
</BaseLayout>

<style>
.eyebrow { font-size:var(--text-sm); font-weight:700; color:#E8A85A; text-transform:uppercase; letter-spacing:.08em; margin-bottom:var(--s-3); }

.mp-hero {
  background:linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  padding-block:var(--s-20) var(--s-16); color:var(--color-white);
  position:relative; overflow:hidden; text-align:center;
}
.mp-hero__bg { position:absolute; inset:0; background:radial-gradient(ellipse at 40% 60%, rgba(74,127,165,.3) 0%, transparent 55%); pointer-events:none; }
.mp-hero__inner { position:relative; z-index:1; max-width:640px; margin-inline:auto; }
.mp-hero h1 { color:var(--color-white); font-size:var(--text-5xl); margin-bottom:var(--s-4); }
.mp-hero h1 span { color:#E8A85A; }
.mp-hero p { color:rgba(255,255,255,.75); font-size:var(--text-lg); }

.breadcrumb-bar { background:var(--color-white); border-bottom:1px solid var(--color-border); padding-block:var(--s-3); }
.bc { display:flex; flex-wrap:wrap; gap:var(--s-1); font-size:var(--text-sm); color:var(--color-text-muted); list-style:none; }
.bc li+li::before { content:'›'; margin-right:var(--s-1); }
.bc a { color:var(--color-accent); }
.bc a:hover { color:var(--color-highlight); }

.section--dark { background:var(--color-primary); }
.mp-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--s-6); }
.mpstat { text-align:center; padding:var(--s-6); }
.mpstat__num { display:block; font-size:var(--text-4xl); font-weight:700; color:var(--color-highlight); }
.mpstat__lbl { font-size:var(--text-sm); color:rgba(255,255,255,.65); text-transform:uppercase; letter-spacing:.05em; }

.mp-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:var(--s-7); margin-bottom:var(--s-16); }
.mcard { background:var(--color-white); border-radius:var(--r-xl); overflow:hidden; border:1px solid var(--color-border); transition:transform var(--t-base), box-shadow var(--t-base); }
.mcard:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }
.mcard__img-wrap { position:relative; aspect-ratio:3/2; overflow:hidden; }
.mcard__img-wrap img { width:100%; height:100%; object-fit:cover; transition:transform var(--t-slow); }
.mcard:hover .mcard__img-wrap img { transform:scale(1.04); }
.mcard__cat { position:absolute; top:var(--s-3); left:var(--s-3); background:var(--color-highlight); color:white; font-size:var(--text-xs); font-weight:600; padding:.2rem .7rem; border-radius:999px; text-transform:uppercase; }
.mcard__body { padding:var(--s-5) var(--s-6) var(--s-6); }
.mcard__name { font-size:var(--text-xl); font-weight:700; color:var(--color-primary); margin-bottom:var(--s-1); }
.mcard__type { font-size:var(--text-sm); color:var(--color-highlight); font-weight:600; margin-bottom:var(--s-3); }
.mcard__desc { font-size:var(--text-sm); color:var(--color-text-muted); line-height:1.7; margin-bottom:var(--s-4); }
.mcard__specs { list-style:none; display:grid; grid-template-columns:1fr 1fr; gap:var(--s-2); }
.mcard__specs li { font-size:var(--text-xs); color:var(--color-text-muted); background:var(--color-bg); padding:var(--s-2) var(--s-3); border-radius:var(--r-sm); display:flex; align-items:center; gap:var(--s-2); }
.mcard__specs li::before { content:'⚙'; font-size:.7em; }

@media (max-width:900px) { .mp-grid { grid-template-columns:1fr; } .mp-stats { grid-template-columns:repeat(2,1fr); } }
@media (max-width:560px) { .mp-stats { grid-template-columns:1fr 1fr; } }
</style>
