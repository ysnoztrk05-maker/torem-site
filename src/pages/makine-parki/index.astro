---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABox from '../../components/CTABox.astro';

const makineler = [
  {
    name: 'Soilmec SR-40',
    type: 'Fore Kazık Makinesi',
    specs: [
      { label: 'Maks. Çap', value: 'Ø1200 mm' },
      { label: 'Maks. Derinlik', value: '43 m' },
      { label: 'Tork', value: '160 kNm' },
      { label: 'Ağırlık', value: '52 ton' },
    ],
    desc: 'Orta-büyük ölçekli fore kazık projelerinde ana üretim makinesi. Yüksek tork kapasitesi ile sert formasyonlarda etkili delgi sağlar.',
    image: '/images/makineler/soilmec-sr40.webp',
    category: 'Fore Kazık',
  },
  {
    name: 'Soilmec SR-40 (Saha)',
    type: 'Fore Kazık Makinesi',
    specs: [
      { label: 'Kelly Bar', value: '4 parça' },
      { label: 'Kılıflı Delgi', value: 'Evet' },
      { label: 'Gürültü', value: 'Düşük' },
      { label: 'Kentsel Kullanım', value: 'Uygun' },
    ],
    desc: 'Kentsel derin kazı projelerinde sınırlı alanlarda çalışabilen konfigürasyon. Kılıflı (casing) delgi ile gevşek formasyonlarda güvenli imalat.',
    image: '/images/makineler/soilmec-sr40-saha.jpg',
    category: 'Fore Kazık',
  },
  {
    name: 'Casagrande B200 XP',
    type: 'Fore Kazık Makinesi',
    specs: [
      { label: 'Maks. Çap', value: 'Ø1500 mm' },
      { label: 'Maks. Derinlik', value: '56 m' },
      { label: 'Tork', value: '200 kNm' },
      { label: 'Ağırlık', value: '65 ton' },
    ],
    desc: 'Büyük çaplı ve derin fore kazık imalatı için yüksek kapasiteli rotary delgi makinesi. Metro, köprü ve altyapı projelerinde tercih edilir.',
    image: '/images/makineler/casagrande-b200xp.jpg',
    category: 'Fore Kazık',
  },
  {
    name: 'Bauer BG 20',
    type: 'Fore Kazık Makinesi',
    specs: [
      { label: 'Maks. Çap', value: 'Ø1200 mm' },
      { label: 'Maks. Derinlik', value: '46 m' },
      { label: 'Tork', value: '200 kNm' },
      { label: 'Ağırlık', value: '60 ton' },
    ],
    desc: 'Alman mühendisliği ile üretilen güvenilir fore kazık makinesi. Kelly bar ve CFA uygulamaları için modüler konfigürasyon imkânı.',
    image: '/images/makineler/bauer-bg20.jpg',
    category: 'Fore Kazık',
  },
  {
    name: 'Ankraj / Jet Grout Makinesi',
    type: 'Çok Amaçlı Geoteknik',
    specs: [
      { label: 'Maks. Derinlik', value: '50 m' },
      { label: 'Ankraj Çapı', value: 'Ø90–200 mm' },
      { label: 'JG Basıncı', value: '400 bar' },
      { label: 'Ağırlık', value: '18 ton' },
    ],
    desc: 'Öngermeli ankraj, zemin çivisi, jet grout ve mikro kazık uygulamalarında kullanılan çok amaçlı geoteknik makinesi.',
    image: '/images/makineler/ankraj-makinesi.jpg',
    category: 'Ankraj & Jet Grout',
  },
  {
    name: 'PTC Vibro 30HD',
    type: 'Vibratör / Çakma Ekipmanı',
    specs: [
      { label: 'Santrifüj Kuvveti', value: '750 kN' },
      { label: 'Frekans', value: '23–38 Hz' },
      { label: 'Güç', value: '330 kW' },
      { label: 'Ağırlık', value: '8,5 ton' },
    ],
    desc: 'Palplanş ve çelik kazık çakma/çekmede kullanılan yüksek frekanslı hidrolik vibratör. Geri kazanımlı söküm için de ideal.',
    image: '/images/makineler/ptc-vibro.jpg',
    category: 'Vibratör',
  },
  {
    name: 'Çimento Enjeksiyon Seti',
    type: 'Enjeksiyon Ünitesi',
    specs: [
      { label: 'Basınç', value: '0–100 bar' },
      { label: 'Debi', value: '0–200 lt/dk' },
      { label: 'Karıştırıcı', value: '500 lt' },
      { label: 'Kontrol', value: 'Dijital' },
    ],
    desc: 'Zemin enjeksiyonu, ankraj enjeksiyonu ve jet grout besleme sistemi. Dijital basınç ve debi kontrolü ile hassas uygulama.',
    image: '/images/makineler/enjeksiyon-seti.jpg',
    category: 'Enjeksiyon',
  },
  {
    name: 'Mini Kazık Makinesi',
    type: 'Mikro Kazık / Sondaj',
    specs: [
      { label: 'Çap', value: 'Ø114–300 mm' },
      { label: 'Derinlik', value: '25 m' },
      { label: 'Min. Tavan', value: '2,5 m' },
      { label: 'Erişim', value: 'Kompakt' },
    ],
    desc: 'Sınırlı alanlarda ve mevcut yapı içinde uygulanabilen kompakt delgi ünitesi. Bodrum kat güçlendirme ve GES enerji projelerinde kullanılır.',
    image: '/images/makineler/mini-kazik-makinesi.jpg',
    category: 'Mini Kazık',
  },
];

const stats = [
  { num: '40+', label: 'İş Makinesi' },
  { num: '8', label: 'Fore Kazık Makinesi' },
  { num: '6', label: 'Ankraj / JG Makinesi' },
  { num: '7/24', label: 'Teknik Destek' },
];
---

<BaseLayout
  title="Makine Parkı | Fore Kazık ve Geoteknik Ekipmanlar | Torem Zemin"
  description="Soilmec SR-40, Casagrande B200 XP, Bauer BG20 fore kazık makineleri ve ankraj/jet grout ekipmanları. 40+ modern geoteknik iş makinesi filosu."
>
  <!-- Hero -->
  <section class="mp-hero">
    <div class="mp-hero__bg" aria-hidden="true"></div>
    <div class="container mp-hero__inner">
      <p class="eyebrow">Ekipman Filosu</p>
      <h1>Modern Makine<br><span>Parkımız</span></h1>
      <p>40'ı aşkın modern geoteknik iş makinesiyle Türkiye genelinde hizmet. Soilmec, Casagrande ve Bauer markaları ile güvenilir performans.</p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="container">
      <ol class="bc">
        <li><a href="/">Ana Sayfa</a></li>
        <li aria-current="page">Makine Parkı</li>
      </ol>
    </div>
  </nav>

  <!-- İstatistikler -->
  <section class="section section--dark">
    <div class="container">
      <div class="mp-stats">
        {stats.map((s) => (
          <div class="mpstat">
            <span class="mpstat__num">{s.num}</span>
            <span class="mpstat__lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Makine Listesi — Yatay Düzen -->
  <section class="section">
    <div class="container">
      <div class="mp-list">
        {makineler.map((m, i) => (
          <article class={`mrow ${i % 2 === 1 ? 'mrow--reverse' : ''}`}>
            <div class="mrow__img">
              <img src={m.image} alt={m.name} loading="lazy" width="800" height="533" />
              <span class="mrow__cat">{m.category}</span>
            </div>
            <div class="mrow__info">
              <p class="mrow__type">{m.type}</p>
              <h2 class="mrow__name">{m.name}</h2>
              <p class="mrow__desc">{m.desc}</p>
              <div class="mrow__specs">
                {m.specs.map((s) => (
                  <div class="spec">
                    <span class="spec__val">{s.value}</span>
                    <span class="spec__lbl">{s.label}</span>
                  </div>
                ))}
              </div>
              <a href="/iletisim/" class="btn btn--primary">Teklif İste →</a>
            </div>
          </article>
        ))}
      </div>

      <CTABox title="Makine Parkımız Hakkında Bilgi Alın" />
    </div>
  </section>
</BaseLayout>

<style>
.eyebrow { font-size:var(--text-sm); font-weight:700; color:#E8A85A; text-transform:uppercase; letter-spacing:.08em; margin-bottom:var(--s-3); }

/* ── Hero ── */
.mp-hero {
  background:linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  padding-block:var(--s-20) var(--s-16); color:var(--color-white);
  position:relative; overflow:hidden; text-align:center;
}
.mp-hero__bg { position:absolute; inset:0; background:radial-gradient(ellipse at 40% 60%, rgba(74,127,165,.3) 0%, transparent 55%); pointer-events:none; }
.mp-hero__inner { position:relative; z-index:1; max-width:640px; margin-inline:auto; }
.mp-hero h1 { color:var(--color-white); font-size:var(--text-5xl); margin-bottom:var(--s-4); }
.mp-hero h1 span { color:#E8A85A; }
.mp-hero p { color:rgba(255,255,255,.75); font-size:var(--text-lg); }

/* ── Breadcrumb ── */
.breadcrumb-bar { background:var(--color-white); border-bottom:1px solid var(--color-border); padding-block:var(--s-3); }
.bc { display:flex; flex-wrap:wrap; gap:var(--s-1); font-size:var(--text-sm); color:var(--color-text-muted); list-style:none; }
.bc li+li::before { content:'›'; margin-right:var(--s-1); }
.bc a { color:var(--color-accent); }
.bc a:hover { color:var(--color-highlight); }

/* ── Stats ── */
.section--dark { background:var(--color-primary); }
.mp-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--s-6); }
.mpstat { text-align:center; padding:var(--s-6); }
.mpstat__num { display:block; font-size:var(--text-4xl); font-weight:700; color:var(--color-highlight); }
.mpstat__lbl { font-size:var(--text-sm); color:rgba(255,255,255,.65); text-transform:uppercase; letter-spacing:.05em; }

/* ── Makine Satırları — Yatay Düzen ── */
.mp-list { display:flex; flex-direction:column; gap:var(--s-12); margin-bottom:var(--s-16); }

.mrow {
  display:grid;
  grid-template-columns:55% 45%;
  gap:0;
  background:var(--color-white);
  border-radius:var(--r-xl);
  overflow:hidden;
  border:1px solid var(--color-border);
  transition:box-shadow var(--t-base);
}
.mrow:hover { box-shadow:var(--shadow-lg); }

.mrow--reverse { direction:rtl; }
.mrow--reverse > * { direction:ltr; }

/* Sol: Fotoğraf %55 */
.mrow__img {
  position:relative;
  overflow:hidden;
  min-height:360px;
}
.mrow__img img {
  width:100%; height:100%;
  object-fit:cover;
  transition:transform var(--t-slow);
}
.mrow:hover .mrow__img img { transform:scale(1.04); }
.mrow__cat {
  position:absolute; top:var(--s-4); left:var(--s-4);
  background:var(--color-highlight); color:white;
  font-size:var(--text-xs); font-weight:700;
  padding:.3rem .8rem; border-radius:999px;
  text-transform:uppercase; letter-spacing:.04em;
}

/* Sağ: Bilgi %45 */
.mrow__info {
  padding:var(--s-8) var(--s-8) var(--s-6);
  display:flex; flex-direction:column; justify-content:center;
}
.mrow__type {
  font-size:var(--text-xs); font-weight:600;
  color:var(--color-highlight); text-transform:uppercase;
  letter-spacing:.06em; margin-bottom:var(--s-2);
}
.mrow__name {
  font-size:var(--text-2xl); font-weight:700;
  color:var(--color-primary); margin-bottom:var(--s-4);
  line-height:1.2;
}
.mrow__desc {
  font-size:var(--text-sm); color:var(--color-text-muted);
  line-height:1.75; margin-bottom:var(--s-6);
}

/* Spec Grid */
.mrow__specs {
  display:grid; grid-template-columns:1fr 1fr;
  gap:var(--s-3); margin-bottom:var(--s-6);
}
.spec {
  background:var(--color-bg);
  border:1px solid var(--color-border);
  border-radius:var(--r-md);
  padding:var(--s-3) var(--s-4);
  text-align:center;
}
.spec__val {
  display:block; font-size:var(--text-base);
  font-weight:700; color:var(--color-primary);
  margin-bottom:2px;
}
.spec__lbl {
  font-size:var(--text-xs);
  color:var(--color-text-muted);
  text-transform:uppercase; letter-spacing:.04em;
}

/* ── Responsive ── */
@media (max-width:900px) {
  .mrow { grid-template-columns:1fr; }
  .mrow--reverse { direction:ltr; }
  .mrow__img { min-height:260px; }
  .mrow__info { padding:var(--s-6); }
  .mp-stats { grid-template-columns:repeat(2,1fr); }
}
@media (max-width:560px) {
  .mrow__specs { grid-template-columns:1fr 1fr; }
  .mp-stats { grid-template-columns:1fr 1fr; }
}
</style>
