---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AuthorBox from '../../components/AuthorBox.astro';
import CTABox from '../../components/CTABox.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { hizmetler, getHizmet } from '../../data/content';

export function getStaticPaths() {
  return hizmetler.map((h) => ({ params: { slug: h.slug } }));
}

const { slug } = Astro.params;
const hizmet = getHizmet(slug);
if (!hizmet) return Astro.redirect('/hizmetlerimiz/');

const canonical = `https://www.toremzemin.com/hizmetlerimiz/${slug}/`;
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: hizmet.title,
  description: hizmet.excerpt,
  provider: { '@type': 'ProfessionalService', name: 'Torem Zemin Mühendislik', url: 'https://www.toremzemin.com' },
  areaServed: 'Türkiye',
  url: canonical,
};

const otherServices = hizmetler.filter((h) => h.slug !== slug).slice(0, 5);
---

<BaseLayout
  title={`${hizmet.title} | Torem Zemin`}
  description={hizmet.excerpt}
  canonical={canonical}
  ogImage={hizmet.heroImage}
  schema={serviceSchema}
>
  <!-- Wave Hero -->
  <header class="hizmet-hero">
    <div class="hizmet-hero__bg" aria-hidden="true"></div>
    <div class="container hizmet-hero__inner">
      <nav class="hizmet-hero__bc" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Ana Sayfa</a></li>
          <li><a href="/hizmetlerimiz/">Hizmetlerimiz</a></li>
          <li>{hizmet.shortTitle}</li>
        </ol>
      </nav>
      <span class="gold-badge">{hizmet.category}</span>
      <h1>{hizmet.title}</h1>
      <p class="hizmet-hero__excerpt">{hizmet.excerpt}</p>
    </div>
    <div class="hizmet-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,30 C360,60 720,0 1080,30 C1260,45 1380,40 1440,35 L1440,60 L0,60 Z" fill="var(--color-bg)" />
      </svg>
    </div>
  </header>

  <article class="section">
    <div class="container hizmet-layout">

      <!-- Ana içerik -->
      <div class="hizmet-main">
        <AuthorBox date="Mart 2026" />
        <div class="prose" set:html={hizmet.content} />
        <FAQAccordion items={hizmet.faq.map(f => ({ question: f.q, answer: f.a }))} title={`${hizmet.shortTitle} Hakkında Sık Sorulanlar`} />
        <CTABox />
      </div>

      <!-- Sidebar -->
      <aside class="hizmet-sidebar">
        <div class="sbar-box sbar-box--cta">
          <h4>Hızlı Teklif Alın</h4>
          <p>Projeniz için ücretsiz keşif ve maliyet tahmini.</p>
          <a href="/iletisim/" class="btn btn--primary" style="width:100%;justify-content:center">İletişim Formu</a>
          <a href="tel:+905316594636" class="btn btn--outline" style="width:100%;justify-content:center;margin-top:var(--s-3)">+90 531 659 46 36</a>
        </div>

        <div class="sbar-box">
          <h4>Diğer Hizmetler</h4>
          <ul class="sbar-links">
            {otherServices.map((s) => (
              <li>
                <a href={`/hizmetlerimiz/${s.slug}/`}>
                  <span>{s.shortTitle}</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sbar-box sbar-box--info">
          <h4>İletişim</h4>
          <ul class="sbar-contact">
            <li><strong>Tel 1:</strong> <a href="tel:+905316594636">+90 531 659 46 36</a></li>
            <li><strong>Tel 2:</strong> <a href="tel:+902163793310">+90 216 379 33 10</a></li>
            <li><strong>E-posta:</strong> <a href="mailto:info@toremzemin.com">info@toremzemin.com</a></li>
            <li><strong>Adres:</strong> Pendik / İstanbul</li>
          </ul>
        </div>
      </aside>

    </div>
  </article>
</BaseLayout>

<style>
/* Wave Hero */
.hizmet-hero {
  background:linear-gradient(135deg, var(--color-navy-dark, #001530) 0%, var(--color-primary) 100%);
  margin-top:-110px;
  padding-block:calc(var(--s-20) + 110px) calc(var(--s-16) + 60px);
  color:var(--color-white); text-align:center;
  position:relative; overflow:hidden;
}
.hizmet-hero__bg {
  position:absolute; inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size:30px 30px; pointer-events:none; z-index:1;
}
.hizmet-hero__inner { position:relative; z-index:2; max-width:700px; margin-inline:auto; }
.hizmet-hero h1 { color:var(--color-white); font-size:var(--text-5xl); margin-bottom:var(--s-4); margin-top:var(--s-3); }
.hizmet-hero__excerpt { color:rgba(255,255,255,.78); font-size:var(--text-lg); line-height:1.7; max-width:580px; margin-inline:auto; }
.hizmet-hero__wave { position:absolute; bottom:0; left:0; right:0; height:60px; z-index:3; line-height:0; }
.hizmet-hero__wave svg { width:100%; height:100%; }
/* Breadcrumb in hero */
.hizmet-hero__bc ol { display:flex; flex-wrap:wrap; gap:var(--s-2); justify-content:center; list-style:none; margin-bottom:var(--s-5); font-size:var(--text-sm); }
.hizmet-hero__bc li { color:rgba(255,255,255,.5); }
.hizmet-hero__bc li:not(:last-child)::after { content:'›'; margin-left:var(--s-2); }
.hizmet-hero__bc a { color:rgba(255,255,255,.7); transition:color var(--t-fast); }
.hizmet-hero__bc a:hover { color:var(--color-highlight); }

/* Layout */
.hizmet-layout { display:grid; grid-template-columns:1fr 300px; gap:var(--s-10); align-items:start; }

/* Prose */
.prose :global(h2) { font-size:var(--text-3xl); margin-top:var(--s-10); margin-bottom:var(--s-4); padding-bottom:var(--s-3); border-bottom:2px solid var(--color-bg-alt); }
.prose :global(h3) { font-size:var(--text-2xl); margin-top:var(--s-8); margin-bottom:var(--s-3); }
.prose :global(p)  { line-height:1.85; margin-bottom:var(--s-4); }
.prose :global(ul),.prose :global(ol) { padding-left:var(--s-6); margin-bottom:var(--s-5); }
.prose :global(ul) { list-style:disc; }
.prose :global(ol) { list-style:decimal; }
.prose :global(li) { margin-bottom:var(--s-2); line-height:1.7; }
.prose :global(strong) { font-weight:600; }
.prose :global(table) { width:100%; border-collapse:collapse; margin-block:var(--s-6); font-size:var(--text-sm); }
.prose :global(th) { background:var(--color-primary); color:white; padding:var(--s-3) var(--s-4); text-align:left; }
.prose :global(td) { padding:var(--s-3) var(--s-4); border:1px solid var(--color-border); }
.prose :global(tr:nth-child(even)) { background:var(--color-bg-alt); }
.prose :global(.aeo-box) { background:var(--color-bg-alt); border-left:4px solid var(--color-highlight); padding:var(--s-4) var(--s-5); border-radius:var(--r-sm); font-weight:500; color:var(--color-primary); margin-block:var(--s-5); }

/* Sidebar */
.hizmet-sidebar { display:flex; flex-direction:column; gap:var(--s-5); }
.sbar-box { background:var(--color-white); border:1px solid var(--color-border); border-radius:var(--r-lg); padding:var(--s-6); position:sticky; top:calc(var(--header-h) + var(--s-4)); }
.sbar-box h4 { font-size:var(--text-base); margin-bottom:var(--s-4); color:var(--color-primary); }
.sbar-box--cta { background:linear-gradient(145deg, var(--color-secondary), var(--color-primary)); border-color:transparent; }
.sbar-box--cta h4,.sbar-box--cta p { color:var(--color-white); }
.sbar-box--cta p { font-size:var(--text-sm); opacity:.8; margin-bottom:var(--s-4); }
.sbar-links { display:flex; flex-direction:column; }
.sbar-links li { border-bottom:1px solid var(--color-border); }
.sbar-links li:last-child { border-bottom:none; }
.sbar-links a { display:flex; justify-content:space-between; align-items:center; padding:var(--s-3) 0; font-size:var(--text-sm); color:var(--color-accent); transition:color var(--t-fast); }
.sbar-links a:hover { color:var(--color-highlight); }
.sbar-links svg { opacity:.5; }
.sbar-contact { list-style:none; display:flex; flex-direction:column; gap:var(--s-3); font-size:var(--text-sm); }
.sbar-contact strong { color:var(--color-text-muted); font-weight:600; font-size:var(--text-xs); text-transform:uppercase; letter-spacing:.05em; margin-right:var(--s-2); }
.sbar-contact a { color:var(--color-accent); }
.sbar-contact a:hover { color:var(--color-highlight); }

@media (max-width:900px) {
  .hizmet-layout { grid-template-columns:1fr; }
  .hizmet-sidebar { order:-1; }
  .sbar-box { position:static; }
}
</style>
