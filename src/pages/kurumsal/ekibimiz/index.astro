---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CTABox from '../../../components/CTABox.astro';

const canonical = 'https://www.toremzemin.com/kurumsal/ekibimiz/';

const kurucular = [
  {
    ad: 'Yasin Öztürk',
    slug: 'yasin-ozturk',
    unvan: 'Kurucu Ortak & Genel Müdür',
    rol: 'Saha Takibi · İş Geliştirme · Teknik Yönetim',
    brans: 'Jeoloji Yüksek Mühendisi',
    egitim: 'Lisans — Karadeniz Teknik Üniversitesi (Jeoloji Müh.) · Yüksek Lisans — İstanbul Medeniyet Üniversitesi',
    deneyim: '15+ yıl',
    ozet: 'Proje görüşmelerinden şantiye sahibinin son imzasına kadar; işin uygulanabilirliğini saha gözüyle değerlendirir, mühendislik kararlarını birebir izler.',
  },
  {
    ad: 'Ali Osman Aksu',
    slug: 'ali-osman-aksu',
    unvan: 'Kurucu Ortak & Genel Müdür',
    rol: 'Finans · Satın Alma · Hakediş Takibi',
    brans: 'İnşaat Mühendisi',
    egitim: 'Uludağ Üniversitesi (İnşaat Mühendisliği)',
    deneyim: '15+ yıl',
    ozet: 'Finansal disiplin, malzeme ve ekipman tedariki, iş programı-hakediş dengesi. Projelerin ekonomik yürüyüşünden sorumlu.',
  },
];

const yonetim = [
  {
    ad: 'Murat Erden',
    slug: 'murat-erden',
    unvan: 'Genel Koordinatör',
    rol: 'Teknik İşler · Proje Takibi · Hakediş Hazırlama · Koordinasyon',
    brans: 'İnşaat Yüksek Mühendisi',
    egitim: 'İstanbul Kültür Üniversitesi (Yüksek Lisans)',
  },
  {
    ad: 'Hatice Özdoğan',
    slug: 'hatice-ozdogan',
    unvan: 'Ofis Yöneticisi',
    rol: 'Sekreterya · Fatura & Ofis İşleri',
    brans: 'İşletme',
    egitim: 'İşletme mezunu',
  },
];

const sorumluMuhendis = {
  ad: 'Kadir Karadayı',
  slug: 'kadir-karadayi',
  unvan: 'Tüm Şantiyelerin Sorumlu Mühendisi',
  rol: 'Aynı anda yürüyen projelerin saha denetimi · Formenler arası koordinasyon · Günlük raporlama',
  brans: 'İnşaat Mühendisi',
};

const formenler = [
  {
    ad: 'Abdulkadir Aksu',
    slug: 'abdulkadir-aksu',
    unvan: 'Ankraj Grubu Formeni',
    rol: 'Öngermeli ve geçici ankraj imalatları · Saha ekibi liderliği',
  },
  {
    ad: 'Ramazan Karahan',
    slug: 'ramazan-karahan',
    unvan: 'Fore Kazık Grubu Formeni',
    rol: 'Fore kazık imalatı · Beton dökümü · Kazık teknisyenleri liderliği',
  },
];

const danismanlar = [
  {
    ad: 'Emre Gül',
    unvan: 'Mali Müşavir',
    rol: 'Finansal denetim, vergi ve mevzuat uyumu',
    ikon: 'finans',
  },
  {
    ad: 'Yusuf Akçay',
    unvan: 'Hukuk Danışmanı',
    rol: 'Sözleşme yönetimi ve hukuki mütalaa',
    ikon: 'hukuk',
  },
];

const sahaEkibi = [
  { sayi: '3', rol: 'Saha Mühendisi', desc: 'Şantiyelerde imalat denetimi ve günlük raporlama' },
  { sayi: '15', rol: 'Teknik Uygulama Ekibi', desc: 'Fore kazık, ankraj ve iksa imalatlarında uzman saha personeli' },
];
---

<BaseLayout
  title="Ekibimiz | Torem Zemin Mühendislik"
  description="Torem Zemin kadrosu: 2 kurucu ortak, mühendislik ve saha ekibi. Her projede kurucu ortakların bizzat dahil olduğu odaklı yapı."
  canonical={canonical}
>
  <!-- HERO -->
  <section class="ekip-hero">
    <div class="ekip-hero__bg" aria-hidden="true"></div>
    <div class="container ekip-hero__inner">
      <span class="eyebrow eyebrow--gold">Ekibimiz</span>
      <h1>Sizi <span>Tanıyan</span><br>Bir Ekip</h1>
      <p>Torem Zemin'i iki kurucu ortak ve saha kadrosu yürütüyor. Görüştüğünüz kişi, sahada bizzat olan kişi — araya giren katmanlar yok.</p>
    </div>
    <div class="ekip-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none"><path d="M0,30 C360,60 720,0 1080,30 C1260,45 1380,40 1440,35 L1440,60 L0,60 Z" fill="var(--color-bg)"/></svg>
    </div>
  </section>

  <Breadcrumb items={[{ label: 'Kurumsal', href: '/kurumsal/' }, { label: 'Ekibimiz' }]} />

  <!-- KURUCU ORTAKLAR -->
  <section class="section ekip-section">
    <div class="container">
      <div class="ekip-section__head">
        <span class="ekip-eyebrow">Kurucu Ortaklar</span>
        <h2>İşi Kuranlar, İşi Takip Ediyor</h2>
        <p>İki kurucu ortak, şirketin günlük operasyonunda doğrudan görevli. Her projede en az biri bizzat takiptedir.</p>
      </div>

      <div class="kurucu-grid">
        {kurucular.map((k) => (
          <article class="kurucu-card">
            <div class="kurucu-card__photo" aria-hidden="true">
              <img src={`/images/ekibimiz/${k.slug}.jpg`}
                   alt={`${k.ad} — ${k.unvan}`}
                   onerror="this.style.display='none'; this.parentElement.classList.add('kurucu-card__photo--placeholder')"
                   loading="lazy" width="340" height="400" />
              <svg class="kurucu-card__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <div class="kurucu-card__body">
              <span class="kurucu-card__unvan">{k.unvan}</span>
              <h3 class="kurucu-card__ad">{k.ad}</h3>
              <p class="kurucu-card__rol">{k.rol}</p>
              <div class="kurucu-card__meta">
                <div class="kurucu-card__meta-row"><strong>Branş:</strong><span>{k.brans}</span></div>
                <div class="kurucu-card__meta-row"><strong>Eğitim:</strong><span>{k.egitim}</span></div>
                <div class="kurucu-card__meta-row"><strong>Deneyim:</strong><span>{k.deneyim}</span></div>
              </div>
              <p class="kurucu-card__ozet">{k.ozet}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- YÖNETİM & KOORDİNASYON -->
  <section class="section section--alt ekip-section">
    <div class="container">
      <div class="ekip-section__head">
        <span class="ekip-eyebrow">Yönetim & Koordinasyon</span>
        <h2>Günlük Operasyonu Yürütenler</h2>
        <p>Teknik koordinasyon, hakediş takibi ve ofis yönetimi bu iki isme emanet.</p>
      </div>

      <div class="yonetim-grid">
        {yonetim.map((k) => (
          <article class="yonetim-card">
            <div class="yonetim-card__photo" aria-hidden="true">
              <img src={`/images/ekibimiz/${k.slug}.jpg`}
                   alt={`${k.ad} — ${k.unvan}`}
                   onerror="this.style.display='none'; this.parentElement.classList.add('yonetim-card__photo--placeholder')"
                   loading="lazy" width="200" height="200" />
              <svg class="yonetim-card__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <div class="yonetim-card__body">
              <h3>{k.ad}</h3>
              <span class="yonetim-card__unvan">{k.unvan}</span>
              <p class="yonetim-card__rol">{k.rol}</p>
              <p class="yonetim-card__edu"><strong>{k.brans}</strong> · {k.egitim}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SAHA LİDERLİĞİ — Sorumlu Mühendis + Formenler -->
  <section class="section ekip-section">
    <div class="container">
      <div class="ekip-section__head">
        <span class="ekip-eyebrow">Saha Ekibi</span>
        <h2>Sahadan Sorumlu Olanlar</h2>
        <p>Şantiyelerin ana sorumlusu ve uygulama grubu formenlerimiz — kazık ve ankraj sahalarının günlük akışı bu kişilerde buluşuyor.</p>
      </div>

      <!-- Sorumlu Mühendis — hiyerarşik üst -->
      <div class="sorumlu-muh-wrap">
        <article class="sorumlu-muh-card">
          <div class="sorumlu-muh-card__photo" aria-hidden="true">
            <img src={`/images/ekibimiz/${sorumluMuhendis.slug}.jpg`}
                 alt={`${sorumluMuhendis.ad} — ${sorumluMuhendis.unvan}`}
                 onerror="this.style.display='none'; this.parentElement.classList.add('sorumlu-muh-card__photo--placeholder')"
                 loading="lazy" width="120" height="120" />
            <svg class="sorumlu-muh-card__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <div class="sorumlu-muh-card__body">
            <h3>{sorumluMuhendis.ad}</h3>
            <span class="sorumlu-muh-card__unvan">{sorumluMuhendis.unvan}</span>
            <p class="sorumlu-muh-card__brans"><strong>{sorumluMuhendis.brans}</strong></p>
            <p class="sorumlu-muh-card__rol">{sorumluMuhendis.rol}</p>
          </div>
        </article>
      </div>

      <!-- Grup formenleri alt başlık -->
      <p class="alt-baslik">Uygulama grubu formenleri</p>

      <div class="formen-grid">
        {formenler.map((k) => (
          <article class="formen-card">
            <div class="formen-card__photo" aria-hidden="true">
              <img src={`/images/ekibimiz/${k.slug}.jpg`}
                   alt={`${k.ad} — ${k.unvan}`}
                   onerror="this.style.display='none'; this.parentElement.classList.add('formen-card__photo--placeholder')"
                   loading="lazy" width="140" height="140" />
              <svg class="formen-card__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <div class="formen-card__body">
              <h3>{k.ad}</h3>
              <span class="formen-card__unvan">{k.unvan}</span>
              <p>{k.rol}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SAHA EKİBİ (SAYISAL) -->
  <section class="section section--alt ekip-section">
    <div class="container">
      <div class="ekip-section__head">
        <span class="ekip-eyebrow">Saha Ekibi</span>
        <h2>Şantiyelerde Bizzat Çalışan Kadro</h2>
        <p>Mühendisinden işçisine kadar — Torem Zemin imalatlarını yürüten ekip.</p>
      </div>

      <div class="saha-grid">
        {sahaEkibi.map((s) => (
          <div class="saha-card">
            <span class="saha-card__num">{s.sayi}</span>
            <div class="saha-card__body">
              <strong>{s.rol}</strong>
              <p>{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DANIŞMANLAR -->
  <section class="section ekip-section">
    <div class="container">
      <div class="ekip-section__head">
        <span class="ekip-eyebrow">Dış Uzman Desteği</span>
        <h2>Mali ve Hukuki Danışmanlarımız</h2>
        <p>Finansal disiplin ve hukuki uyum; alanında uzman iki bağımsız danışmanla yürütülür.</p>
      </div>

      <div class="danisman-grid">
        {danismanlar.map((d) => (
          <div class="danisman-card">
            <div class="danisman-card__icon" aria-hidden="true">
              {d.ikon === 'finans' ? (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <line x1="12" y1="1" x2="12" y2="23"/>
                  <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                </svg>
              ) : (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M9 11l3 3L22 4"/>
                  <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
                </svg>
              )}
            </div>
            <div class="danisman-card__body">
              <strong>{d.ad}</strong>
              <span>{d.unvan}</span>
              <p>{d.rol}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="section container">
    <CTABox title="Kurucu ortağımızla Doğrudan Görüşün" />
  </div>
</BaseLayout>

<style>
/* ============================ */
/* HERO                         */
/* ============================ */
.ekip-hero {
  position: relative;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-navy-dark) 100%);
  color: #fff;
  padding: 10rem 0 8rem;
  margin-top: -110px;
  text-align: center;
  overflow: hidden;
}
.ekip-hero__bg {
  position: absolute;
  inset: 0;
  background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  opacity: 0.6;
}
.ekip-hero__inner { position: relative; z-index: 2; max-width: 820px; margin: 0 auto; padding: 0 var(--s-6); }
.ekip-hero h1 {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 4vw, 3.2rem);
  color: #fff;
  line-height: 1.2;
  margin-bottom: 1.5rem;
  font-weight: 700;
}
.ekip-hero h1 span {
  color: var(--color-highlight);
  font-style: italic;
  font-weight: 500;
}
.ekip-hero p {
  color: rgba(255,255,255,0.78);
  font-size: 1.1rem;
  line-height: 1.7;
  max-width: 680px;
  margin: 0 auto;
}
.eyebrow--gold {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-highlight);
  background: rgba(212,175,55,0.1);
  padding: 0.4rem 1rem;
  border-radius: 999px;
  border: 1px solid rgba(212,175,55,0.3);
  margin-bottom: 1.5rem;
}
.ekip-hero__wave {
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 100%;
  line-height: 0;
}
.ekip-hero__wave svg { display: block; width: 100%; height: 60px; }

/* ============================ */
/* SECTION BAŞLIKLARI           */
/* ============================ */
.ekip-section__head {
  text-align: center;
  max-width: 680px;
  margin: 0 auto 3rem;
}
.ekip-eyebrow {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-earth);
  margin-bottom: 0.75rem;
}
.ekip-section__head h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.7rem, 2.8vw, 2.2rem);
  color: var(--color-primary);
  line-height: 1.25;
  margin-bottom: 0.75rem;
}
.ekip-section__head p {
  color: var(--color-text-muted);
  font-size: 1.02rem;
  line-height: 1.7;
}

/* ============================ */
/* KURUCU KARTLARI              */
/* ============================ */
.kurucu-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
}
.kurucu-card {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: 20px;
  overflow: hidden;
  display: grid;
  grid-template-columns: 220px 1fr;
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
}
.kurucu-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 50px rgba(0, 33, 71, 0.08);
  border-color: var(--color-highlight);
}
.kurucu-card__photo {
  position: relative;
  background: var(--color-bg-alt);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.kurucu-card__photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.kurucu-card__placeholder-icon {
  width: 80px;
  height: 80px;
  color: var(--color-text-muted);
  opacity: 0.3;
  display: none;
}
.kurucu-card__photo--placeholder .kurucu-card__placeholder-icon { display: block; }

.kurucu-card__body {
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.kurucu-card__unvan {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-highlight);
}
.kurucu-card__ad {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-primary);
  margin: 0;
  letter-spacing: -0.01em;
}
.kurucu-card__rol {
  font-size: 0.92rem;
  color: var(--color-text);
  font-weight: 600;
  margin: 0 0 0.5rem;
}
.kurucu-card__meta {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  padding: 0.75rem 0;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}
.kurucu-card__meta-row {
  display: grid;
  grid-template-columns: 72px 1fr;
  gap: 0.5rem;
  font-size: 0.82rem;
  line-height: 1.5;
}
.kurucu-card__meta-row strong {
  color: var(--color-text-muted);
  font-weight: 600;
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding-top: 2px;
}
.kurucu-card__meta-row span { color: var(--color-text); }
.kurucu-card__ozet {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--color-text-muted);
  font-style: italic;
}

/* ============================ */
/* YÖNETİM KARTLARI             */
/* ============================ */
.yonetim-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  max-width: 880px;
  margin: 0 auto;
}
.yonetim-card {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: 16px;
  padding: 1.75rem;
  display: flex;
  gap: 1.25rem;
  align-items: flex-start;
  transition: transform 0.3s, box-shadow 0.3s;
}
.yonetim-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 30px rgba(0,33,71,0.06);
}
.yonetim-card__photo {
  width: 88px;
  height: 88px;
  border-radius: 50%;
  background: var(--color-bg-alt);
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--color-border);
  position: relative;
}
.yonetim-card__photo img { width: 100%; height: 100%; object-fit: cover; }
.yonetim-card__placeholder-icon {
  width: 40px;
  height: 40px;
  color: var(--color-text-muted);
  opacity: 0.35;
  display: none;
}
.yonetim-card__photo--placeholder .yonetim-card__placeholder-icon { display: block; }

.yonetim-card__body { flex: 1; }
.yonetim-card__body h3 {
  font-family: var(--font-serif);
  font-size: 1.2rem;
  color: var(--color-primary);
  margin: 0 0 0.25rem;
  font-weight: 700;
}
.yonetim-card__unvan {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-highlight);
  margin-bottom: 0.6rem;
}
.yonetim-card__rol {
  font-size: 0.9rem;
  color: var(--color-text);
  line-height: 1.55;
  margin: 0 0 0.6rem;
}
.yonetim-card__edu {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  margin: 0;
  padding-top: 0.5rem;
  border-top: 1px solid var(--color-border);
}
.yonetim-card__edu strong { color: var(--color-primary); font-weight: 600; }

/* ============================ */
/* SORUMLU MÜHENDİS (Kademe 1)  */
/* ============================ */
.sorumlu-muh-wrap {
  max-width: 720px;
  margin: 0 auto;
}
.sorumlu-muh-card {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: 16px;
  padding: 1.75rem;
  display: flex;
  gap: 1.5rem;
  align-items: center;
  transition: transform 0.3s, box-shadow 0.3s;
}
.sorumlu-muh-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 14px 34px rgba(0,33,71,0.09);
}
.sorumlu-muh-card__photo {
  width: 110px;
  height: 110px;
  border-radius: 50%;
  background: var(--color-bg-alt);
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3px solid var(--color-primary);
  position: relative;
}
.sorumlu-muh-card__photo img { width: 100%; height: 100%; object-fit: cover; }
