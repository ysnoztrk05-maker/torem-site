---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABox from '../../components/CTABox.astro';

const canonical = 'https://www.toremzemin.com/kurumsal/';

const certs = [
  { label: 'ISO 9001:2015', desc: 'Kalite Yönetim Sistemi' },
  { label: 'CE Belgeli', desc: 'Avrupa Standartlarına Uygunluk' },
  { label: 'TSEK Onaylı', desc: 'Türk Standartları Enstitüsü' },
  { label: 'TBDY 2018', desc: 'Türkiye Bina Deprem Yönetmeliği Uyumu' },
];
---

<BaseLayout
  title="Kurumsal | Torem Zemin Mühendislik"
  description="Torem Zemin Mühendislik — 20+ yıllık geoteknik deneyim, 600+ tamamlanan proje, İstanbul merkezli profesyonel zemin mühendisliği firması."
  canonical={canonical}
>
  <!-- Hero -->
  <section class="kurumsal-hero">
    <div class="kurumsal-hero__bg" aria-hidden="true"></div>
    <div class="container kurumsal-hero__inner">
      <p class="eyebrow">Kurumsal</p>
      <h1>20 Yıllık Deneyim,<br><span>Güvenilir Mühendislik</span></h1>
      <p>Torem Zemin, İstanbul merkezli geoteknik mühendislik firmasıdır. Fore kazık, jet grout, ankraj ve zemin iyileştirme alanlarında anahtar teslim çözümler sunmaktadır.</p>
    </div>
  </section>

  <Breadcrumb items={[{ label: 'Kurumsal' }]} />

  <!-- Hakkımızda -->
  <section class="section">
    <div class="container about-grid">
      <div class="about-text">
        <p class="eyebrow-sm">Biz Kimiz</p>
        <h2>Türkiye'nin Önde Gelen<br>Geoteknik Firması</h2>
        <p>2004 yılında kurulan Torem Zemin Mühendislik, başta İstanbul olmak üzere Türkiye genelinde konut, ticari, altyapı ve endüstriyel projelere geoteknik çözümler sunmaktadır.</p>
        <p>Deneyimli mühendis kadrosu, modern makine filosu ve kalite odaklı yaklaşımıyla her ölçekteki zemin sorununa kalıcı çözümler üretmektedir.</p>
        <p>TBDY 2018 ve TS EN standartlarına tam uyum sağlayan projelerimiz; statik ve dinamik yük testleriyle doğrulanmaktadır.</p>

        <div class="about-stats">
          <div class="astat"><span class="astat__num">20+</span><span class="astat__lbl">Yıl Deneyim</span></div>
          <div class="astat"><span class="astat__num">600+</span><span class="astat__lbl">Tamamlanan Proje</span></div>
          <div class="astat"><span class="astat__num">55+</span><span class="astat__lbl">İş Makinesi</span></div>
          <div class="astat"><span class="astat__num">250+</span><span class="astat__lbl">Memnun Müşteri</span></div>
        </div>
      </div>

      <div class="about-imgs">
        <img
          src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=600&h=700&q=80"
          alt="Saha mühendisliği çalışması"
          width="600" height="700"
          class="about-imgs__main"
          loading="lazy"
        />
        <img
          src="https://images.unsplash.com/photo-1590736704728-f4730bb30770?auto=format&fit=crop&w=300&h=320&q=80"
          alt="Zemin sondaj operasyonu"
          width="300" height="320"
          class="about-imgs__secondary"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Misyon & Vizyon -->
  <section class="section section--alt">
    <div class="container">
      <div class="mv-grid">
        <div class="mv-card mv-card--mission">
          <div class="mv-card__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="24" cy="24" r="18"/>
              <circle cx="24" cy="24" r="8"/>
              <line x1="24" y1="6" x2="24" y2="12"/>
              <line x1="24" y1="36" x2="24" y2="42"/>
              <line x1="6" y1="24" x2="12" y2="24"/>
              <line x1="36" y1="24" x2="42" y2="24"/>
            </svg>
          </div>
          <h3>Misyonumuz</h3>
          <p>Her yapının sağlam bir zemine oturması için bilimsel yöntemler ve kanıtlanmış teknolojilerle mühendislik çözümleri üretmek; güvenilirliği ve kaliteyi her projede en üst düzeyde tutmak.</p>
        </div>
        <div class="mv-card mv-card--vision">
          <div class="mv-card__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M24 8L44 38H4L24 8Z"/>
              <path d="M24 20L32 34H16L24 20Z"/>
            </svg>
          </div>
          <h3>Vizyonumuz</h3>
          <p>Geoteknik mühendislikte Türkiye'nin referans firması olmak; yenilikçi zemin teknolojilerini ulusal projelere entegre ederek sektörün gelişimine öncülük etmek.</p>
        </div>
        <div class="mv-card mv-card--values">
          <div class="mv-card__icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M24 4L30 16L44 18L34 28L36 42L24 36L12 42L14 28L4 18L18 16L24 4Z"/>
            </svg>
          </div>
          <h3>Değerlerimiz</h3>
          <p>Mühendislik etiği, şeffaf iletişim, sürdürülebilirlik ve iş güvenliği. Her projede standartların üstünde kalite ve zamanında teslimat taahhüdü.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sertifikalar & Belgeler -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow-sm">Kalite & Uyum</p>
        <h2>Sertifikalar & Standartlar</h2>
      </div>
      <div class="cert-grid">
        {certs.map((c) => (
          <div class="cert-card">
            <div class="cert-card__badge">
              <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
                <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.5"/>
                <path d="M10 16l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <strong>{c.label}</strong>
            <span>{c.desc}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="section container">
    <CTABox title="Projeniz İçin Uzman Görüşü Alın" />
  </div>
</BaseLayout>

<style>
.eyebrow { font-size:var(--text-sm); font-weight:700; color:#E8A85A; text-transform:uppercase; letter-spacing:.08em; margin-bottom:var(--s-3); }
.eyebrow-sm { font-size:var(--text-xs); font-weight:700; color:var(--color-highlight); text-transform:uppercase; letter-spacing:.08em; margin-bottom:var(--s-2); }

/* Hero */
.kurumsal-hero {
  background:linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  padding-block:var(--s-20) var(--s-16); color:var(--color-white);
  position:relative; overflow:hidden; text-align:center;
}
.kurumsal-hero__bg {
  position:absolute; inset:0;
  background:radial-gradient(ellipse at 70% 50%, rgba(74,127,165,.25) 0%, transparent 60%);
  pointer-events:none;
}
.kurumsal-hero__inner { position:relative; z-index:1; max-width:640px; margin-inline:auto; }
.kurumsal-hero h1 { color:var(--color-white); font-size:var(--text-5xl); margin-bottom:var(--s-4); }
.kurumsal-hero h1 span { color:#E8A85A; }
.kurumsal-hero p { color:rgba(255,255,255,.75); font-size:var(--text-lg); }

/* About Grid */
.about-grid { display:grid; grid-template-columns:1fr 1fr; gap:var(--s-16); align-items:center; }
.about-text h2 { font-size:var(--text-4xl); margin-bottom:var(--s-4); line-height:1.2; }
.about-text p { color:var(--color-text-muted); line-height:1.8; margin-bottom:var(--s-4); }
.about-stats { display:grid; grid-template-columns:repeat(2,1fr); gap:var(--s-4); margin-top:var(--s-8); }
.astat { background:var(--color-white); border:1px solid var(--color-border); border-radius:var(--r-lg); padding:var(--s-4); text-align:center; }
.astat__num { display:block; font-size:var(--text-3xl); font-weight:700; color:var(--color-highlight); }
.astat__lbl { font-size:var(--text-xs); color:var(--color-text-muted); text-transform:uppercase; letter-spacing:.05em; }

.about-imgs { position:relative; height:520px; }
.about-imgs__main { width:75%; height:100%; object-fit:cover; border-radius:var(--r-xl); position:absolute; left:0; top:0; }
.about-imgs__secondary { width:45%; aspect-ratio:1; object-fit:cover; border-radius:var(--r-lg); position:absolute; right:0; bottom:10%; border:4px solid var(--color-bg); box-shadow:var(--shadow-lg); }

/* Section headers */
.section-header { text-align:center; max-width:560px; margin-inline:auto; margin-bottom:var(--s-12); }
.section-header h2 { font-size:var(--text-4xl); margin-bottom:var(--s-3); }
.section-header p { color:var(--color-text-muted); }

/* Misyon Vizyon */
.mv-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--s-6); }
.mv-card { background:var(--color-white); border:1px solid var(--color-border); border-radius:var(--r-xl); padding:var(--s-8); }
.mv-card--mission { border-top:3px solid var(--color-highlight); }
.mv-card--vision { border-top:3px solid var(--color-secondary); }
.mv-card--values { border-top:3px solid var(--color-accent); }
.mv-card__icon { width:48px; height:48px; color:var(--color-highlight); margin-bottom:var(--s-4); }
.mv-card h3 { font-size:var(--text-xl); margin-bottom:var(--s-3); }
.mv-card p { color:var(--color-text-muted); line-height:1.75; }

/* Certs */
.cert-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--s-6); }
.cert-card { background:var(--color-white); border:1px solid var(--color-border); border-radius:var(--r-lg); padding:var(--s-6); display:flex; flex-direction:column; align-items:center; gap:var(--s-3); text-align:center; }
.cert-card__badge { width:40px; height:40px; color:var(--color-highlight); }
.cert-card strong { font-size:var(--text-base); color:var(--color-primary); }
.cert-card span { font-size:var(--text-sm); color:var(--color-text-muted); }

.section--alt { background:var(--color-bg-alt, #eef0f2); }

@media (max-width:900px) {
  .about-grid { grid-template-columns:1fr; }
  .about-imgs { height:300px; }
  .mv-grid { grid-template-columns:1fr; }
  .cert-grid { grid-template-columns:repeat(2,1fr); }
}
@media (max-width:560px) {
  .cert-grid { grid-template-columns:1fr; }
  .about-stats { grid-template-columns:1fr 1fr; }
}
</style>
