---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABox from '../../components/CTABox.astro';

const canonical = 'https://www.toremzemin.com/kurumsal/';

const certs = [
  { label: 'ISO 9001:2015', desc: 'Kalite Yönetim Sistemi' },
  { label: 'CE Belgeli', desc: 'Avrupa Standartlarına Uygunluk' },
  { label: 'TSEK Onaylı', desc: 'Türk Standartları Enstitüsü' },
  { label: 'TBDY 2018', desc: 'Deprem Yönetmeliği Uyumu' },
];

const stats = [
  { num: String(new Date().getFullYear() - 2013), suffix: '+', lbl: 'Yıl Deneyim'        },
  { num: '350', suffix: '+', lbl: 'Tamamlanan Proje'   },
  { num: '15',  suffix: '+', lbl: 'İş Makinesi'        },
  { num: '100', suffix: '%', lbl: 'Müşteri Memnuniyeti'},
];
---

<BaseLayout
  title="Kurumsal | Torem Zemin Mühendislik"
  description="Torem Zemin Mühendislik — 20+ yıllık geoteknik deneyim, 600+ tamamlanan proje, İstanbul merkezli profesyonel zemin mühendisliği firması."
  canonical={canonical}
>
  <!-- Hero -->
  <section class="kurumsal-hero">
    <div class="kurumsal-hero__bg"></div>
    <div class="kurumsal-hero__overlay"></div>
    <div class="container kurumsal-hero__inner">
      <div class="kurumsal-hero__content">
        <span class="eyebrow eyebrow--gold">Kurumsal</span>
        <h1>20 Yıllık Deneyim,<br/><span class="text-gradient">Güvenilir Mühendislik</span></h1>
        <p>Torem Zemin, İstanbul merkezli geoteknik mühendislik firmasıdır. Fore kazık, jet grout, ankraj ve zemin iyileştirme alanlarında anahtar teslim çözümler sunmaktadır.</p>
      </div>
    </div>
    
    <!-- Hero Stats Widget -->
    <div class="hero-stats-widget-container container">
      <div class="hero-stats-grid">
        {stats.map(s => (
          <div class="hero-stat-card">
            <div class="hero-stat-card__num-wrapper">
              <span class="hero-stat-card__num counter" data-target={s.num}>0</span>
              <span class="hero-stat-card__suffix">{s.suffix}</span>
            </div>
            <span class="hero-stat-card__lbl">{s.lbl}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Breadcrumb items={[{ label: 'Kurumsal' }]} />

  <!-- Hakkımızda -->
  <section class="section about-section" style="padding-top: 8rem;">
    <div class="container about-grid">
      <div class="about-text">
        <span class="eyebrow">Biz Kimiz</span>
        <h2>Türkiye'nin Önde Gelen<br>Geoteknik Firması</h2>
        <div class="about-text__content">
          <p>2004 yılında kurulan <strong>Torem Zemin Mühendislik</strong>, başta İstanbul olmak üzere Türkiye genelinde konut, ticari, altyapı ve endüstriyel projelere geoteknik çözümler sunmaktadır.</p>
          <p>Deneyimli mühendis kadrosu, modern makine filosu ve kalite odaklı yaklaşımıyla her ölçekteki zemin sorununa kalıcı çözümler üretir. Uygulamalarımız TBDY 2018 ve uluslararası standartlara tam uyum sağlar.</p>
        </div>
        <div class="about-text__content">
          <p>2004 yılında kurulan <strong>Torem Zemin Mühendislik</strong>, başta İstanbul olmak üzere Türkiye genelinde konut, ticari, altyapı ve endüstriyel projelere geoteknik çözümler sunmaktadır.</p>
          <p>Deneyimli mühendis kadrosu, modern makine filosu ve kalite odaklı yaklaşımıyla her ölçekteki zemin sorununa kalıcı çözümler üretir. Uygulamalarımız TBDY 2018 ve uluslararası standartlara tam uyum sağlar.</p>
        </div>
      </div>

      <div class="about-visuals">
        <div class="about-visuals__main">
          <div class="image-gradient-overlay"></div>
          <img src="/images/fore-kazik-saha.jpg" alt="Saha mühendisliği çalışması" loading="lazy" />
          <div class="about-visuals__badge premium-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span>Güvenilir<br/>Zemin<br/>Mühendisliği</span>
            <div class="premium-badge__glow"></div>
          </div>
        </div>
        <div class="about-visuals__secondary">
          <div class="image-gradient-overlay"></div>
          <img src="/images/makine-parki.webp" alt="Soilmec fore kazık makinesi" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Kilometre Taşları (Timeline) -->
  <section class="section timeline-section">
    <div class="container">
      <div class="section-header text-center">
        <span class="eyebrow">Tarihçe</span>
        <h2>20 Yıllık Geoteknik Serüvenimiz</h2>
        <p>Sektörde iz bırakan projeler ve büyüyen makine parkımızla dünden bugüne Torem Zemin.</p>
      </div>

      <div class="timeline">
        <div class="timeline__line"></div>
        <div class="timeline-item">
          <div class="timeline-item__dot"></div>
          <div class="timeline-item__content">
            <span class="timeline-item__year">2004</span>
            <h3>Kuruluş & İlk Adımlar</h3>
            <p>İstanbul'da kurulan Torem Zemin, ilk mini kazık ve zemin etüdü projeleriyle sektöre güçlü bir giriş yaptı.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-item__dot"></div>
          <div class="timeline-item__content">
            <span class="timeline-item__year">2010</span>
            <h3>Makine Parkı Yatırımları</h3>
            <p>Büyüyen talepler doğrultusunda ilk büyük kapasiteli fore kazık makineleri (Soilmec) filoya katıldı ve anahtar teslim endüstriyel projelere başlandı.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-item__dot"></div>
          <div class="timeline-item__content">
            <span class="timeline-item__year">2018</span>
            <h3>TBDY 2018 Uyumu & İnovasyon</h3>
            <p>Yeni deprem yönetmeliğine tam uyumlu derin kazı ve iksa sistemleri mühendislik standartlarımızın merkezine oturdu.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-item__dot"></div>
          <div class="timeline-item__content">
            <span class="timeline-item__year">2024</span>
            <h3>Sektör Liderliği</h3>
            <p>600'ü aşkın tamamlanmış proje, 50+ makinelik dev parkur ve yenilenen kurumsal kimliği ile Türkiye'nin her noktasında güven inşa etmeye devam ediyor.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Misyon & Vizyon -->
  <section class="section mv-section">
    <div class="container">
      <div class="section-header text-center">
        <span class="eyebrow">Geleceğe Bakış</span>
        <h2>Misyon, Vizyon & Değerlerimiz</h2>
        <p>Sağlam temeller üzerinde yükselen bir gelecek inşa ediyoruz.</p>
      </div>

      <div class="mv-grid">
        <div class="mv-card">
          <div class="mv-card__icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="4"/>
              <line x1="12" y1="2" x2="12" y2="4"/>
              <line x1="12" y1="20" x2="12" y2="22"/>
              <line x1="2" y1="12" x2="4" y2="12"/>
              <line x1="20" y1="12" x2="22" y2="12"/>
            </svg>
          </div>
          <h3>Misyonumuz</h3>
          <p>Her yapının sağlam bir zemine oturması için bilimsel yöntemler ve modern teknolojilerle mühendislik çözümleri üretmek; kaliteyi her projede en üst düzeyde tutmak.</p>
        </div>
        <div class="mv-card">
          <div class="mv-card__icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 12A10 10 0 1 0 22 12 10 10 0 1 0 2 12Z" stroke-dasharray="4 4"/>
              <path d="M12 8L16 12L12 16" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 12H16" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Vizyonumuz</h3>
          <p>Geoteknik mühendislikte Türkiye'nin referans firması olmak; yenilikçi zemin teknolojilerini ulusal projelere entegre ederek sektörün gelişimine öncülük etmek.</p>
        </div>
        <div class="mv-card">
          <div class="mv-card__icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22L12 10" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 10L18 16" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 10L6 16" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Değerlerimiz</h3>
          <p>Mühendislik etiği, şeffaf iletişim, sürdürülebilirlik ve üst düzey iş güvenliği. Her projede standartların fevkinde kalite ve zamanında teslimat taahhüdü.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sertifikalar & Belgeler -->
  <section class="section cert-section">
    <div class="container">
      <div class="cert-layout">
        <div class="cert-text">
          <span class="eyebrow">Kalite & Uyum</span>
          <h2>Uluslararası<br/>Standartlarda Hizmet</h2>
          <p>Projelerimizde TS EN ve yerel yönetmeliklerin gerektirdiği tüm standartları harfiyen uyguluyor, sunduğumuz her çözümde kalite belgelerimizle güven veriyoruz.</p>
        </div>
        <div class="cert-grid">
          {certs.map((c) => (
            <div class="cert-card">
              <div class="cert-card__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                  <polyline points="22 4 12 14.01 9 11.01" />
                </svg>
              </div>
              <div class="cert-card__content">
                <strong>{c.label}</strong>
                <span>{c.desc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="section container">
    <CTABox title="Projeniz İçin Uzman Görüşü Alın" />
  </div>
</BaseLayout>

<script>
  function initKurumsalCounters() {
    const counters = document.querySelectorAll<HTMLElement>('.counter');
    if (!counters.length) return;
    const speed = 200;

    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const counter = entry.target as HTMLElement;
        const targetStr = counter.getAttribute('data-target');
        if (!targetStr) return;
        const target = +targetStr;

        const updateCount = () => {
          const count = +counter.innerText;
          const inc = target / speed;
          if (count < target) {
            counter.innerText = Math.ceil(count + inc).toString();
            setTimeout(updateCount, 15);
          } else {
            counter.innerText = target.toString();
          }
        };

        updateCount();
        countObserver.unobserve(counter);
      });
    }, { threshold: 0.3 });

    counters.forEach(counter => countObserver.observe(counter));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initKurumsalCounters);
  } else {
    initKurumsalCounters();
  }
</script>

<style>
.eyebrow { 
  display: inline-block;
  font-size: 0.85rem; 
  font-weight: 700; 
  color: var(--color-navy-light, #003366); 
  text-transform: uppercase; 
  letter-spacing: 0.1em; 
  margin-bottom: 1rem; 
  background: var(--color-gray-100, #f3f4f6);
  padding: 0.35rem 0.8rem;
  border-radius: 4px;
}
.eyebrow--gold {
  color: var(--color-navy-dark, #0a192f);
  background: var(--color-gold, #cfa856);
}

.text-gradient {
  background: linear-gradient(135deg, var(--color-gold, #cfa856) 0%, #ebb44d 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* ========================================= */
/* HERO SECTION                              */
/* ========================================= */
.kurumsal-hero {
  position: relative;
  background-color: var(--color-navy-dark, #0a192f);
  margin-top: -110px; /* offset navbar */
  padding-block: 180px 160px;
  text-align: center;
}

.kurumsal-hero__bg {
  position: absolute;
  inset: 0;
  background-image: url('/images/kurumsal-bg.jpg'); /* optional fallback bg */
  background-size: cover;
  background-position: center;
  opacity: 0.2;
  mix-blend-mode: luminosity;
}

.kurumsal-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(10, 25, 47, 0.8) 0%, rgba(10, 25, 47, 1) 100%);
}

.kurumsal-hero__inner {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: center;
}

.kurumsal-hero__content {
  max-width: 700px;
}

.kurumsal-hero h1 {
  color: white;
  font-size: clamp(2.5rem, 5vw, 4rem);
  line-height: 1.1;
  margin-bottom: 1.5rem;
}

.kurumsal-hero p {
  color: rgba(255, 255, 255, 0.8);
  font-size: 1.125rem;
  line-height: 1.6;
}

/* ========================================= */
/* HERO STATS WIDGET                         */
/* ========================================= */
.hero-stats-widget-container {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translate(-50%, 50%);
  width: 100%;
  z-index: 10;
}

.hero-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  background: white;
  padding: 2.5rem;
  border-radius: 16px;
  box-shadow: 0 25px 50px -12px rgba(0, 33, 71, 0.25);
  border: 1px solid rgba(207, 168, 86, 0.2);
}

.hero-stat-card {
  text-align: center;
  padding-inline: 1rem;
}
.hero-stat-card:not(:last-child) {
  border-right: 1px solid rgba(0, 0, 0, 0.05);
}

.hero-stat-card__num-wrapper {
  display: flex;
  align-items: baseline;
  justify-content: center;
  color: var(--color-navy-dark, #002147);
  margin-bottom: 0.5rem;
}

.hero-stat-card__num {
  font-size: 3.5rem;
  font-weight: 800;
  line-height: 1;
}

.hero-stat-card__suffix {
  font-size: 2.5rem;
  font-weight: 700;
  color: var(--color-gold, #cfa856);
  margin-left: 2px;
}

.hero-stat-card__lbl {
  font-size: 0.95rem;
  color: #6b7280;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

@media (max-width: 992px) {
  .hero-stats-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .hero-stat-card:nth-child(2) {
    border-right: none;
  }
}
@media (max-width: 576px) {
  .hero-stats-grid {
    grid-template-columns: 1fr;
  }
  .hero-stat-card:not(:last-child) {
    border-right: none;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding-bottom: 1.5rem;
  }
}

/* ========================================= */
/* ABOUT US SECTION                          */
/* ========================================= */
.about-section {
  padding-top: 5rem;
}

.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.about-text h2 {
  font-size: clamp(2rem, 3vw, 2.75rem);
  color: var(--color-navy-dark, #0a192f);
  margin-bottom: 1.5rem;
  line-height: 1.2;
}

.about-text__content p {
  color: #4b5563; /* tailwind gray-600 */
  line-height: 1.8;
  margin-bottom: 1rem;
  font-size: 1.05rem;
}

.about-text__content strong {
  color: var(--color-navy-dark, #0a192f);
}



.about-visuals {
  position: relative;
  height: 600px;
}

.about-visuals__main {
  position: absolute;
  top: 0;
  right: 0;
  width: 85%;
  height: 90%;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 20px 40px rgba(10, 25, 47, 0.1);
}

.about-visuals__main img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-gradient-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10, 25, 47, 0.4) 0%, transparent 50%);
  z-index: 1;
  border-radius: inherit;
}

.premium-badge {
  position: absolute;
  bottom: 2rem;
  left: -2rem; /* offset out of the box */
  background: var(--color-navy-dark, #0a192f);
  color: white;
  padding: 1.5rem;
  border-radius: 12px;
  display: flex;
  align-items: center;
  gap: 1rem;
  box-shadow: 0 10px 30px rgba(0,0,0,0.25);
  z-index: 2;
  overflow: hidden;
  border: 1px solid rgba(212, 175, 55, 0.3);
}

.premium-badge__glow {
  position: absolute;
  width: 50px;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  top: 0;
  left: -100%;
  animation: badge-glow-anim 3s infinite;
}

@keyframes badge-glow-anim {
  0% { left: -100%; }
  20% { left: 200%; }
  100% { left: 200%; }
}

.about-visuals__badge svg {
  width: 40px;
  height: 40px;
  color: var(--color-gold, #cfa856);
}

.about-visuals__badge span {
  font-weight: 600;
  font-size: 0.9rem;
  line-height: 1.4;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.about-visuals__secondary {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 50%;
  height: 45%;
  border-radius: 12px;
  border: 8px solid white;
  overflow: hidden;
  box-shadow: 0 15px 35px rgba(0,0,0,0.1);
}

.about-visuals__secondary img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ========================================= */
/* TIMELINE SECTION                          */
/* ========================================= */
.timeline-section {
  background-color: #fafaf7;
  padding-block: 5rem;
}

.timeline {
  position: relative;
  max-width: 800px;
  margin: 4rem auto 0;
}

.timeline__line {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 30px;
  width: 2px;
  background: rgba(207, 168, 86, 0.3);
}

.timeline-item {
  position: relative;
  padding-left: 80px;
  margin-bottom: 3.5rem;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.timeline-item__dot {
  position: absolute;
  left: 22px;
  top: 6px;
  width: 18px;
  height: 18px;
  background: white;
  border: 4px solid var(--color-gold, #cfa856);
  border-radius: 50%;
  box-shadow: 0 0 0 4px rgba(207, 168, 86, 0.1);
  transition: all 0.3s ease;
}

.timeline-item:hover .timeline-item__dot {
  transform: scale(1.3);
  box-shadow: 0 0 0 6px rgba(207, 168, 86, 0.2);
}

.timeline-item__content {
  background: white;
  padding: 2rem;
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.10), 0 1px 4px rgba(0,0,0,0.06);
  border-left: 3px solid var(--color-gold, #cfa856);
  transition: all 0.3s ease;
}

.timeline-item:hover .timeline-item__content {
  transform: translateX(8px);
  border-color: var(--color-gold, #cfa856);
  box-shadow: 0 8px 32px rgba(0,0,0,0.14);
}

.timeline-item__year {
  display: inline-block;
  font-size: 1.25rem;
  font-weight: 800;
  color: var(--color-gold, #cfa856);
  margin-bottom: 0.5rem;
  font-family: monospace;
  background: rgba(207, 168, 86, 0.1);
  padding: 0.2rem 0.8rem;
  border-radius: 20px;
}

.timeline-item h3 {
  font-size: 1.4rem;
  color: var(--color-navy-dark, #0a192f);
  margin-bottom: 0.75rem;
}

.timeline-item p {
  color: #4b5563;
  line-height: 1.6;
}

@media (max-width: 768px) {
  .timeline__line {
    left: 20px;
  }
  .timeline-item {
    padding-left: 60px;
  }
  .timeline-item__dot {
    left: 12px;
  }
}

/* ========================================= */
/* MISSION & VISION                          */
/* ========================================= */
.mv-section {
  background: linear-gradient(to bottom, #f8fafc 0%, #ffffff 100%);
  padding-block: 5rem;
}

.section-header {
  margin-bottom: 4rem;
}
.section-header.text-center {
  text-align: center;
  max-width: 600px;
  margin-inline: auto;
}

.section-header h2 {
  font-size: 2.25rem;
  color: var(--color-navy-dark, #0a192f);
  margin-bottom: 1rem;
}

.section-header p {
  color: #6b7280;
  font-size: 1.1rem;
}

.mv-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.mv-card {
  background: white;
  padding: 3rem 2rem;
  border-radius: 16px;
  border: 1px solid #e5e7eb;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.mv-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4px;
  background: var(--color-gold, #cfa856);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s ease;
