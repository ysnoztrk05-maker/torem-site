---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABox from '../../components/CTABox.astro';
import { sirket } from '../../data/sirket';

const canonical = 'https://www.toremzemin.com/kurumsal/';

const certs = [
  { label: 'ISO 9001:2015', desc: 'Kalite Yönetim Sistemi' },
  { label: 'CE Belgeli', desc: 'Avrupa Standartlarına Uygunluk' },
  { label: 'TSEK Onaylı', desc: 'Türk Standartları Enstitüsü' },
  { label: 'TBDY 2018', desc: 'Deprem Yönetmeliği Uyumu' },
];

const stats = [
  { num: String(new Date().getFullYear() - 2013), suffix: '+', lbl: 'Yıl Deneyim'        },
  { num: '350', suffix: '+', lbl: 'Tamamlanan Proje'   },
  { num: '15',  suffix: '+', lbl: 'İş Makinesi'        },
  { num: String(sirket.memnuniyet), suffix: '%', lbl: 'Müşteri Memnuniyeti'},
];
---

<BaseLayout
  title="Kurumsal | Torem Zemin Mühendislik"
  description="Torem Zemin Mühendislik — 13+ yıllık geoteknik deneyim, 350+ tamamlanan proje, İstanbul merkezli profesyonel zemin mühendisliği firması."
  canonical={canonical}
>
  <!-- Hero -->
  <section class="kurumsal-hero">
    <div class="kurumsal-hero__bg"></div>
    <div class="kurumsal-hero__overlay"></div>
    <div class="container kurumsal-hero__inner">
      <div class="kurumsal-hero__content">
        <span class="eyebrow eyebrow--gold">Kurumsal</span>
        <h1>13 Yıllık Deneyim, <span class="accent">Geoteknik Mühendisliğinde</span></h1>
        <p>Torem Zemin Mühendislik, İstanbul Pendik merkezli geoteknik uygulama firmasıdır. Fore kazık, jet grout, ankraj ve zemin iyileştirme alanlarında 81 il geneline saha hizmeti vermektedir.</p>
      </div>
    </div>
    
    <!-- Hero Stats Widget -->
    <div class="hero-stats-widget-container container">
      <div class="hero-stats-grid">
        {stats.map(s => (
          <div class="hero-stat-card">
            <div class="hero-stat-card__num-wrapper">
              <span class="hero-stat-card__num counter" data-target={s.num}>{s.num}</span>
              <span class="hero-stat-card__suffix">{s.suffix}</span>
            </div>
            <span class="hero-stat-card__lbl">{s.lbl}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Breadcrumb items={[{ label: 'Kurumsal' }]} />

  <!-- Hakkımızda -->
  <section class="section about-section" style="padding-top: 8rem;">
    <div class="container about-grid">
      <div class="about-text">
        <span class="eyebrow">Biz Kimiz</span>
        <h2>Saha Deneyimiyle Yoğrulmuş<br>Geoteknik Mühendisliği</h2>
        <div class="about-text__content">
          <p><strong>Torem Zemin Mühendislik</strong>, 2013 yılında İstanbul Pendik'te kuruldu. Kurulduğu günden bu yana fore kazık, jet grout, ankraj, iksa sistemleri ve zemin iyileştirme alanlarında anahtar teslim uygulamalar gerçekleştiriyoruz.</p>
          <p>Bugün 15'i aşkın iş makinesinden oluşan kendi filomuz, jeoloji ve inşaat mühendisi kadromuzla; konut, altyapı, endüstriyel ve özel yapı projelerinde saha uygulamaları yapıyoruz. Grup şirketimiz <strong>May Geoteknik</strong> ile birlikte; etüt, tasarım ve uygulamayı aynı çatı altında yürüttüğümüz için müşterilerimiz ayrı firmalarla koordinasyon derdi yaşamıyor.</p>
          <p>Yaklaşımımız şu üç ilke üzerine kurulu: <strong>sahaya inanç</strong> (her karar mühendisin sahada gördüğüyle şekillenir), <strong>şeffaf raporlama</strong> (imalat öncesi ve sonrası veri paylaşımı) ve <strong>zamanında teslim</strong> (iş programına yazılı taahhüt).</p>
        </div>
      </div>

      <div class="about-visuals">
        <div class="about-visuals__main">
          <div class="image-gradient-overlay"></div>
          <picture>
            <source srcset="/images/fore-kazik/fore-kazik-hero.webp" type="image/webp" />
            <img src="/images/fore-kazik/fore-kazik-hero.webp" alt="Fore kazık şantiyesinde geoteknik mühendisleri — alacakaranlık" loading="lazy" decoding="async" width="600" height="700" />
          </picture>
          <div class="about-visuals__badge premium-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span>Geoteknik<br/>Mühendislik<br/>Disiplini</span>
            <div class="premium-badge__glow"></div>
          </div>
        </div>
        <div class="about-visuals__secondary">
          <div class="image-gradient-overlay"></div>
          <picture>
            <source srcset="/images/hero-sunset-2.avif" type="image/avif" />
            <source srcset="/images/hero-sunset-2.webp" type="image/webp" />
            <img src="/images/hero-sunset-2.png" alt="Derin kazı kesişen kazıklı iksa perdesi — şehir manzarasında" loading="lazy" decoding="async" width="340" height="280" />
          </picture>
        </div>
      </div>
    </div>
  </section>

  <!-- Kilometre Taşları (Timeline) -->
  <section class="section timeline-section">
    <div class="container">
      <div class="section-header text-center">
        <span class="eyebrow">Tarihçe</span>
        <h2>13 Yıllık Geoteknik Serüvenimiz</h2>
        <p>Sektörde iz bırakan projeler ve büyüyen makine parkımızla dünden bugüne Torem Zemin.</p>
      </div>

      <div class="timeline">
        <div class="timeline__line"></div>
        <div class="timeline-item">
          <div class="timeline-item__dot"></div>
          <div class="timeline-item__content">
            <span class="timeline-item__year">2013</span>
            <h3>Kuruluş — Pendik, İstanbul</h3>
            <p>Torem Zemin Mühendislik, Pendik'te küçük bir ekiple kuruldu. İlk yıllarda konut ve ticari yapı projelerinde fore kazık ve ankraj uygulamalarına odaklanıldı.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-item__dot"></div>
          <div class="timeline-item__content">
            <span class="timeline-item__year">2015–2017</span>
            <h3>Makine Parkı Yatırımı</h3>
            <p>Artan talep üzerine Soilmec, Casagrande ve Bauer markalarından yeni kazık makineleri satın alındı. Bu dönemde İstanbul çevresinde orta-büyük ölçekli iksa ve temel uygulamaları tamamlandı.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-item__dot"></div>
          <div class="timeline-item__content">
            <span class="timeline-item__year">2018</span>
            <h3>ISO 9001:2015 Belgelendirme & TBDY Uyumu</h3>
            <p>Kalite yönetim sistemi ISO 9001:2015 ile belgelendirildi. TBDY 2018 Deprem Yönetmeliği çerçevesinde mühendislik süreçleri yeniden standardize edildi; iksa sistemleri ana hizmet hattına alındı.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-item__dot"></div>
          <div class="timeline-item__content">
            <span class="timeline-item__year">2020–2022</span>
            <h3>Jet Grout &amp; Zemin İyileştirme Kapasitesi</h3>
            <p>Jet grout ve derin karıştırma (DSM) uygulamalarında ekipman ve uzmanlık yatırımları sürdürüldü. Altyapı ve endüstriyel proje portföyü genişleyerek Marmara genelinde uygulama yapar hale gelindi.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-item__dot"></div>
          <div class="timeline-item__content">
            <span class="timeline-item__year">2023–2024</span>
            <h3>Türkiye Geneli Operasyon</h3>
            <p>Ankara, İzmir, Bursa ve Kocaeli başta olmak üzere Türkiye geneli projelerde saha kurulumu yapıldı. Aynı dönemde May Geoteknik ile grup çalışması sistematikleştirildi.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-item__dot"></div>
          <div class="timeline-item__content">
            <span class="timeline-item__year">2026</span>
            <h3>Dijital Altyapı &amp; Müşteri Deneyimi</h3>
            <p>Kurumsal kimlik ve web platformu yenilendi; proje takip, raporlama ve müşteri iletişim süreçlerinde dijitalleşme tamamlandı.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Misyon & Vizyon -->
  <section class="section mv-section">
    <div class="container">
      <div class="section-header text-center">
        <span class="eyebrow">Geleceğe Bakış</span>
        <h2>Misyon, Vizyon & Değerlerimiz</h2>
        <p>Sağlam temeller üzerinde yükselen bir gelecek inşa ediyoruz.</p>
      </div>

      <div class="mv-grid">
        <div class="mv-card">
          <div class="mv-card__icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="4"/>
              <line x1="12" y1="2" x2="12" y2="4"/>
              <line x1="12" y1="20" x2="12" y2="22"/>
              <line x1="2" y1="12" x2="4" y2="12"/>
              <line x1="20" y1="12" x2="22" y2="12"/>
            </svg>
          </div>
          <h3>Misyonumuz</h3>
          <p>Zemin koşullarını doğru okumak, uygulanabilir mühendislik çözümü üretmek ve sahada yazılı taahhüdümüze sadık kalmak. Müteahhit ve yatırımcının gecikmeden, sürpriz maliyetten ve belirsizlikten uzak kalabileceği bir geoteknik iş ortağı olmak.</p>
        </div>
        <div class="mv-card">
          <div class="mv-card__icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 12A10 10 0 1 0 22 12 10 10 0 1 0 2 12Z" stroke-dasharray="4 4"/>
              <path d="M12 8L16 12L12 16" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 12H16" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Vizyonumuz</h3>
          <p>Etüt, tasarım, uygulama ve izleme süreçlerini tek bir grup çatısı altında yürütebilen; müteahhidin "hangi firmayla konuşacağım" derdini ortadan kaldıran bir geoteknik bütünlük sunmak — Torem Zemin &amp; May Geoteknik birlikteliğinin arkasındaki temel düşünce.</p>
        </div>
        <div class="mv-card">
          <div class="mv-card__icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22L12 10" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 10L18 16" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 10L6 16" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Değerlerimiz</h3>
          <p><strong>Sahaya inanç</strong> — her karar zemini gören mühendisin elinde. <strong>Şeffaflık</strong> — imalat öncesi ve sonrası veriyi paylaşırız. <strong>Yazılı taahhüt</strong> — süre ve maliyeti sözlü değil kağıt üzerinde konuşuruz. <strong>İş güvenliği</strong> — ISG Koordinatörlüğü her sahada aktif.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Grup Şirketi -->
  <section class="section grup-section">
    <div class="container">
      <div class="grup-wrap">
        <div class="grup-badge">Grup Şirketi</div>
        <h2 class="grup-title">Torem Zemin &amp; May Geoteknik<br><span>— Ortak teknik kapasite, iki uzmanlık alanı</span></h2>
        <p class="grup-desc">Torem Zemin, geoteknik mühendislik sektöründe <strong>May Geoteknik</strong> ile aynı grup çatısı altında faaliyet gösterir. Bu birliktelik; paylaşılan makine parkı, ortak Ar-Ge süreçleri ve sektörel derin bilgi birikimi sayesinde müşterilerimize <strong>genişletilmiş teknik kapasite</strong> sunar. Her iki firma da bağımsız olarak faaliyet gösterir; ancak büyük ölçekli veya karmaşık projelerde ortak mühendislik gücüyle çözüm üretir.</p>
        <div class="grup-cards">
          <div class="grup-card grup-card--torem">
            <div class="grup-card__logo-slot"><strong>TOREM</strong> <span>ZEMİN</span></div>
            <p class="grup-card__tagline">Anahtar Teslim Saha Uygulaması</p>
            <ul class="grup-card__spec">
              <li>Fore kazık &middot; Jet grout &middot; Ankraj</li>
              <li>15+ iş makinesi, 350+ proje</li>
              <li>İstanbul + Türkiye geneli</li>
            </ul>
            <span class="grup-card__current">Bu Site</span>
          </div>
          <div class="grup-card grup-card--may">
            <div class="grup-card__logo-slot"><strong>MAY</strong> <span>GEOTEKNİK</span></div>
            <p class="grup-card__tagline">Geoteknik Etüt, Tasarım &amp; Denetim</p>
            <ul class="grup-card__spec">
              <li>Zemin etüdü &middot; Laboratuvar</li>
              <li>Projelendirme &middot; Teknik danışmanlık</li>
              <li>Aletsel gözlem &middot; İzleme</li>
            </ul>
            <a href="https://maygeoteknik.com/" target="_blank" rel="noopener noreferrer" class="grup-card__link">maygeoteknik.com →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Üyelikler -->
  <section class="section uyelik-section">
    <div class="container">
      <div class="section-header text-center">
        <span class="eyebrow">Mesleki Üyelikler</span>
        <h2>Sektörel Otorite &amp; Meslek Oda Üyelikleri</h2>
        <p>Torem Zemin, geoteknik mühendislik camiasının kurumsal çatıları altında aktif üyedir — her proje bu meslek ilkeleri çerçevesinde yürütülür.</p>
      </div>
      <div class="uyelik-grid">
        <div class="uyelik-card">
          <div class="uyelik-card__logo" aria-hidden="true">
            <span class="uyelik-card__initials">TMMOB</span>
          </div>
          <strong>TMMOB</strong>
          <span>Türk Mühendis ve Mimar Odaları Birliği</span>
          <em>Mesleki yetkinlik çatı kuruluşu</em>
        </div>
        <div class="uyelik-card">
          <div class="uyelik-card__logo" aria-hidden="true">
            <span class="uyelik-card__initials">JMO</span>
          </div>
          <strong>Jeoloji Mühendisleri Odası</strong>
          <span>TMMOB Bağlı Meslek Odası</span>
          <em>Zemin ve jeoteknik ilkeler</em>
        </div>
        <a href="https://zemincilerdernegi.com/" target="_blank" rel="noopener noreferrer" class="uyelik-card uyelik-card--link">
          <div class="uyelik-card__logo" aria-hidden="true">
            <span class="uyelik-card__initials">ZD</span>
          </div>
          <strong>Zeminciler Derneği</strong>
          <span>Geoteknik Sektörel Birlik</span>
          <em>Aktif üye &mdash; uygulayıcı firmalar ağı</em>
        </a>
      </div>
    </div>
  </section>

  <!-- Sertifikalar & Belgeler -->
  <section class="section cert-section">
    <div class="container">
      <div class="cert-layout">
        <div class="cert-text">
          <span class="eyebrow">Kalite & Uyum</span>
          <h2>Uluslararası<br/>Standartlarda Hizmet</h2>
          <p>Projelerimizde TS EN ve yerel yönetmeliklerin gerektirdiği tüm standartları harfiyen uyguluyor, sunduğumuz her çözümde kalite belgelerimizle güven veriyoruz.</p>
        </div>
        <div class="cert-grid">
          {certs.map((c) => (
            <div class="cert-card">
              <div class="cert-card__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                  <polyline points="22 4 12 14.01 9 11.01" />
                </svg>
              </div>
              <div class="cert-card__content">
                <strong>{c.label}</strong>
                <span>{c.desc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="section container">
    <CTABox title="Projeniz İçin Uzman Görüşü Alın" />
  </div>
</BaseLayout>

<script>
  function initKurumsalCounters() {
    const counters = document.querySelectorAll<HTMLElement>('.counter');
    if (!counters.length) return;
    const speed = 200;

    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const counter = entry.target as HTMLElement;
        const targetStr = counter.getAttribute('data-target');
        if (!targetStr) return;
        const target = +targetStr;

        let current = Math.floor(target * 0.85);
        counter.innerText = current.toString();
        const inc = Math.max(1, (target - current) / 30);
        const updateCount = () => {
          current = Math.min(current + inc, target);
          counter.innerText = Math.floor(current).toString();
          if (current < target) setTimeout(updateCount, 30);
          else counter.innerText = target.toString();
        };

        updateCount();
        countObserver.unobserve(counter);
      });
    }, { threshold: 0.3 });

    counters.forEach(counter => countObserver.observe(counter));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initKurumsalCounters);
  } else {
    initKurumsalCounters();
  }
</script>

<style>
.eyebrow { 
  display: inline-block;
  font-size: 0.85rem; 
  font-weight: 700; 
  color: var(--color-primary); 
  text-transform: uppercase; 
  letter-spacing: 0.1em; 
  margin-bottom: 1rem; 
  background: rgba(15, 23, 42, 0.05);
  padding: 0.35rem 0.8rem;
  border-radius: 4px;
}
.eyebrow--gold {
  color: #fff;
  background: var(--color-accent);
}

/* ========================================= */
/* HERO SECTION                              */
/* ========================================= */
.kurumsal-hero {
  position: relative;
  background-color: var(--color-primary);
  margin-top: -110px; /* offset navbar */
  padding-block: 180px 160px;
  text-align: center;
}

.kurumsal-hero__bg {
  position: absolute;
  inset: 0;
  background-image: url('/images/kurumsal-bg.jpg'); /* optional fallback bg */
  background-size: cover;
  background-position: center;
  opacity: 0.15;
  mix-blend-mode: luminosity;
}

.kurumsal-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(10, 25, 47, 0.8) 0%, rgba(10, 25, 47, 1) 100%);
}

.kurumsal-hero__inner {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: center;
}

.kurumsal-hero__content {
  max-width: 700px;
}

.kurumsal-hero h1 {
  color: white;
  font-size: clamp(2.5rem, 5vw, 4rem);
  line-height: 1.1;
  margin-bottom: 1.5rem;
}

.kurumsal-hero p {
  color: rgba(255, 255, 255, 0.8);
  font-size: 1.125rem;
  line-height: 1.6;
}

/* ========================================= */
/* HERO STATS WIDGET                         */
/* ========================================= */
.hero-stats-widget-container {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translate(-50%, 50%);
  width: 100%;
  z-index: 10;
}

.hero-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  background: rgba(15, 23, 42, 0.75);
  backdrop-filter: blur(20px);
  padding: 2.5rem;
  border-radius: 24px;
  box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.hero-stat-card {
  text-align: center;
  padding-inline: 1rem;
}
.hero-stat-card:not(:last-child) {
  border-right: 1px solid rgba(255, 255, 255, 0.1);
}

.hero-stat-card__num-wrapper {
  display: flex;
  align-items: baseline;
  justify-content: center;
  color: #fff;
  margin-bottom: 0.5rem;
}

.hero-stat-card__num {
  font-size: 3.5rem;
  font-weight: 700;
  line-height: 1;
}

.hero-stat-card__suffix {
  font-size: 2.5rem;
  font-weight: 700;
  color: var(--color-accent);
  margin-left: 2px;
}

.hero-stat-card__lbl {
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

@media (max-width: 1024px) {
  .hero-stats-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .hero-stat-card:nth-child(2) {
    border-right: none;
  }
}
@media (max-width: 560px) {
  .hero-stats-grid {
    grid-template-columns: 1fr;
  }
  .hero-stat-card:not(:last-child) {
    border-right: none;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding-bottom: 1.5rem;
  }
}

/* ========================================= */
/* ABOUT US SECTION                          */
/* ========================================= */
.about-section {
  padding-top: 5rem;
}

.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.about-text h2 {
  font-size: clamp(2rem, 3vw, 2.75rem);
  color: var(--color-primary);
  margin-bottom: 1.5rem;
  line-height: 1.2;
}

.about-text__content p {
  color: #475569;
  line-height: 1.8;
  margin-bottom: 1rem;
  font-size: 1.05rem;
}

.about-text__content strong {
