---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CTABox from '../../../components/CTABox.astro';
import { sirket } from '../../../data/sirket';

const canonical = 'https://www.toremzemin.com/kurumsal/neden-torem/';
const deneyimYil = new Date().getFullYear() - 2013;

/* ── 6 somut fark ─────────────────────────────────────────────── */
const farklar = [
  {
    no: '01',
    baslik: 'Kendi Makine Parkı',
    slogan: 'Kiralık değil, mülk.',
    aciklama: 'Soilmec, Casagrande ve Bauer markalarından 15+ iş makinesi kendi filomuzdadır. İş programı değişse bile makine beklenmez — sahada hazırız.',
    ikon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`
  },
  {
    no: '02',
    baslik: 'Etüt & Uygulama Aynı Çatıda',
    slogan: 'Tek grup, tek koordinasyon.',
    aciklama: 'Geoteknik etüt ve tasarım odaklı May Geoteknik grup şirketimizdir. Etütten uygulamaya aynı grup çatısı altında — siz farklı firmalar arasında koordinasyon derdi yaşamazsınız.',
    ikon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>`
  },
  {
    no: '03',
    baslik: 'Jeoloji + İnşaat Mühendisliği Uzmanlığı',
    slogan: 'Teknik soru, teknik cevap.',
    aciklama: 'Torem Zemin\'i iki mühendis ortak kurdu: Jeoloji Yüksek Mühendisi (KTÜ + Medeniyet Üni) ve İnşaat Mühendisi (Uludağ Üni). Teknik kararı veren mühendis, aynı zamanda sözleşme imzalayan kişi — "satışçıdan mühendise bağlayayım" gecikmesi yok.',
    ikon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`
  },
  {
    no: '04',
    baslik: 'Yazılı Süre ve Maliyet Taahhüdü',
    slogan: 'Sözlü değil, kâğıtta.',
    aciklama: 'İş programı, malzeme maliyeti ve kilometre taşları sözleşmede yazılı. Haftalık dijital şantiye takibi ile ilerleyiş anlık paylaşılır; sürpriz maliyetler yok.',
    ikon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="15" x2="15" y2="15"/></svg>`
  },
  {
    no: '05',
    baslik: 'Standart Uyumlu Tasarım',
    slogan: 'ISO, TBDY, Eurocode 7.',
    aciklama: 'ISO 9001, ISO 14001, ISO 45001 belgeleri; TBDY 2018 Deprem Yönetmeliği ve TS EN 1536/1537/1997 (EC7) standartları — her proje bu referans setine uyumlu hazırlanır.',
    ikon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`
  },
  {
    no: '06',
    baslik: 'Deneyimli Saha Ekibi',
    slogan: 'Formen de mühendis de sahada.',
    aciklama: 'Ankraj ve fore kazık gruplarımızın başında deneyimli formenler; şantiye sorumlusu inşaat mühendisi; ortalama 10+ yıl saha deneyimli teknik uygulama ekibi.',
    ikon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`
  }
];

/* ── "Soru → Yaklaşım" karşılaştırmalı bölüm ──────────────────── */
const sorular = [
  {
    soru: '"Hangi hafta hangi makine sahada olacak, iş programı kayıp kayıp sonrasını bilmiyoruz."',
    yaklasim: 'Kendi makine parkımız olduğu için takvim bize bağlı — haftalık iş programı sözleşmede yazılı, dijital şantiye takibi ile günlük ilerleyiş paylaşılır.'
  },
  {
    soru: '"Sözleşmeyi imzaladık ama sürpriz maliyetler çıkmaya başladı."',
    yaklasim: 'Kâğıt üstünde olmayan kalem faturalandırılmaz. Malzeme ve ekipman satın alması kurucu ortak sorumluluğunda, hakediş şeffaf — projeyi biz size sunmadık, birlikte yürüteceğiz.'
  },
  {
    soru: '"Temsilciyle konuşuyoruz ama soru derinleşince \'mühendisle görüşeyim\' diyor."',
    yaklasim: 'Sizi karşılayan jeoloji veya inşaat mühendisidir. Zemin profili, kazık çapı, ankraj düzeni, uygulama sırası — teknik soruya aynı kişi cevap verir, aynı kişi hakediş ve süre taahhüdünü de imzalar.'
  }
];

/* ── Gerçek rakamlar (uydurma yok) ─────────────────────────────── */
const rakamlar = [
  { deger: String(deneyimYil), suffix: '+',  etiket: 'Yıl Geoteknik Deneyimi' },
  { deger: String(sirket.tamamlananProje), suffix: '+', etiket: 'Tamamlanan Proje' },
  { deger: String(sirket.memnuniyet), suffix: '%', etiket: 'Müşteri Memnuniyeti' },
  { deger: '15', suffix: '+', etiket: 'Kendi İş Makinesi' },
];
---

<BaseLayout
  title="Neden Torem Zemin? | 6 Somut Fark"
  description="Jeoloji ve inşaat mühendisliği kadrosu, kendi makine parkı, May Geoteknik grup ortaklığı ve yazılı taahhüt. Müteahhitlerin Torem Zemin'i seçmesinin 6 somut nedeni."
  canonical={canonical}
>
  <!-- HERO -->
  <section class="neden-hero">
    <div class="neden-hero__bg" aria-hidden="true"></div>
    <div class="container neden-hero__inner">
      <span class="eyebrow eyebrow--gold">Neden Torem?</span>
      <h1>6 Somut Fark,<br/><span>1 Sağlam İş Ortağı</span></h1>
      <p>Torem Zemin'i müteahhitlerin tercih etme nedenleri belli: mühendis kadro, kendi makine parkı, tek çatı altında etüt-uygulama ve yazılı süre-maliyet taahhüdü.</p>
    </div>
    <div class="neden-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none"><path d="M0,30 C360,60 720,0 1080,30 C1260,45 1380,40 1440,35 L1440,60 L0,60 Z" fill="var(--color-bg)"/></svg>
    </div>
  </section>

  <Breadcrumb items={[
    { label: 'Kurumsal', href: '/kurumsal/' },
    { label: 'Neden Torem' }
  ]} />

  <!-- AÇIKLAMA METNİ -->
  <section class="section">
    <div class="container">
      <div class="intro-block">
        <h2>Sahada Mühendislik Belirler</h2>
        <p class="intro-block__lead">Zemin işi, şantiyenin en belirsiz ve en kritik aşamasıdır. İş programını kaydıran, bütçeyi çatırdatan ya da kalite problemine dönüşen çoğu şey, zeminde başlar.</p>
        <p>Bu sayfadaki 6 başlık, Torem Zemin'in operasyonel yapısını belirleyen somut kararları özetler. Her biri sözleşmede, sahada ve hakedişte görünen kalemler — müşterilerimizin doğrudan değer aldığı pratiklerdir.</p>
      </div>
    </div>
  </section>

  <!-- 6 AVANTAJ GRID -->
  <section class="section avantajlar-kapsayici">
    <div class="container">
      <div class="avantajlar-grid">
        {farklar.map((item) => (
          <article class="avantaj-kart">
            <span class="avantaj-kart__no">{item.no}</span>
            <div class="avantaj-kart__ikon" set:html={item.ikon} />
            <h3>{item.baslik}</h3>
            <p class="avantaj-kart__slogan">{item.slogan}</p>
            <p class="avantaj-kart__aciklama">{item.aciklama}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SORU → YAKLAŞIM -->
  <section class="section soru-section">
    <div class="container">
      <div class="soru-section__head">
        <span class="soru-eyebrow">Pratikte Karşılığı</span>
        <h2>Şantiyede Sık Karşılaşılan 3 Başlık —<br/>Torem Yaklaşımı</h2>
        <p>Müteahhitlerin saha süreçlerinde sıkça dile getirdiği konular ve bu başlıklarda nasıl konumlandığımız.</p>
      </div>

      <div class="soru-list">
        {sorular.map((s, i) => (
          <div class="soru-card">
            <div class="soru-card__soru">
              <span class="soru-card__label">Müteahhit sorusu</span>
              <p>{s.soru}</p>
            </div>
            <div class="soru-card__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </div>
            <div class="soru-card__yaklasim">
              <span class="soru-card__label soru-card__label--gold">Torem yaklaşımı</span>
              <p>{s.yaklasim}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RAKAMLAR BANDI (trust-safe, gerçek) -->
  <section class="section fark-rakamlar">
    <div class="container">
      <div class="fark-grid">
        <div class="fark-metin">
          <span class="eyebrow eyebrow--gold">Rakamlarla Torem</span>
          <h2>Deneyim, Kapasite,<br/><span>Saha Kadrosu</span></h2>
          <p>Kurulduğumuz 2013'ten bu yana İstanbul merkezli, Türkiye genelinde faaliyet gösteren bir geoteknik uygulama firmasıyız. Proje portföyümüzü ve operasyonel kapasitemizi bu rakamlar özetliyor.</p>
        </div>
        <div class="fark-stats">
          {rakamlar.map((r) => (
            <div class="fstat">
              <span class="fstat__deger">{r.deger}{r.suffix}</span>
              <span class="fstat__etiket">{r.etiket}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="section container">
    <CTABox
      title="Projeniz İçin Uzman Görüşü Alın"
      text="Zemin etüt raporunuzu paylaşın, uygulanabilir yöntemleri ve tahmini iş programını birlikte değerlendirelim."
    />
  </div>

</BaseLayout>

<style>
/* ============================ */
/* HERO                         */
/* ============================ */
.neden-hero {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-navy-dark) 100%);
  margin-top: -110px;
  padding-block: 10rem 8rem;
  color: #fff;
  position: relative;
  overflow: hidden;
  text-align: center;
}
.neden-hero__bg {
  position: absolute; inset: 0;
  background-image: radial-gradient(circle at 70% 30%, rgba(212,175,55,0.15) 0%, transparent 60%),
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: auto, 40px 40px, 40px 40px;
  pointer-events: none;
}
.neden-hero__inner { position: relative; z-index: 2; max-width: 720px; margin: 0 auto; padding: 0 var(--s-6); }
.neden-hero h1 {
  font-family: var(--font-serif);
  color: #fff;
  font-size: clamp(2rem, 4vw, 3.2rem);
  line-height: 1.2;
  margin-bottom: 1.25rem;
  font-weight: 700;
}
.neden-hero h1 span {
  color: var(--color-highlight);
  font-style: italic;
  font-weight: 500;
}
.neden-hero p { color: rgba(255,255,255,.78); font-size: 1.08rem; line-height: 1.7; }
.neden-hero__wave { position: absolute; bottom: -1px; left: 0; width: 100%; line-height: 0; }
.neden-hero__wave svg { width: 100%; height: 60px; display: block; }

.eyebrow--gold {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-highlight);
  background: rgba(212,175,55,0.1);
  padding: 0.4rem 1rem;
  border-radius: 999px;
  border: 1px solid rgba(212,175,55,0.3);
  margin-bottom: 1.5rem;
}

/* ============================ */
/* INTRO BLOCK                  */
/* ============================ */
.intro-block {
  max-width: 780px;
  margin: 0 auto;
  text-align: center;
}
.intro-block h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.7rem, 2.8vw, 2.2rem);
  color: var(--color-primary);
  margin-bottom: 1.25rem;
  line-height: 1.25;
}
.intro-block__lead {
  font-size: 1.15rem;
  color: var(--color-primary);
  font-weight: 500;
  margin-bottom: 1.25rem;
  line-height: 1.55;
}
.intro-block p:not(.intro-block__lead) {
  color: var(--color-text-muted);
  line-height: 1.75;
  font-size: 1rem;
}

/* ============================ */
/* 6 AVANTAJ GRID               */
/* ============================ */
.avantajlar-kapsayici {
  background: var(--color-bg-alt);
  padding-block: 5rem;
}
.avantajlar-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  max-width: 1120px;
  margin: 0 auto;
}
.avantaj-kart {
  background: #fff;
  padding: 2rem 1.75rem;
  border-radius: 16px;
  border: 1px solid var(--color-border);
  position: relative;
  overflow: hidden;
  transition: box-shadow .3s, transform .3s, border-color .3s;
}
.avantaj-kart::before {
  content: '';
  position: absolute;
  inset: 0 0 auto 0;
  height: 3px;
  background: linear-gradient(90deg, var(--color-earth), var(--color-highlight));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .4s cubic-bezier(.22,1,.36,1);
}
.avantaj-kart:hover {
  transform: translateY(-4px);
  box-shadow: 0 14px 32px rgba(0,33,71,0.07);
  border-color: var(--color-highlight);
}
.avantaj-kart:hover::before { transform: scaleX(1); }

.avantaj-kart__no {
  position: absolute;
  top: 1.25rem;
  right: 1.25rem;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-earth);
  opacity: 0.55;
  letter-spacing: 0.05em;
}

.avantaj-kart__ikon {
  width: 52px;
  height: 52px;
  border-radius: 14px;
  background: rgba(212,175,55,0.08);
  color: var(--color-highlight);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
  transition: background .3s, color .3s;
}
.avantaj-kart__ikon svg { width: 24px; height: 24px; }
.avantaj-kart:hover .avantaj-kart__ikon {
  background: var(--color-highlight);
  color: #fff;
}

.avantaj-kart h3 {
  font-family: var(--font-serif);
  font-size: 1.15rem;
  color: var(--color-primary);
  margin: 0 0 0.35rem;
  font-weight: 700;
  line-height: 1.3;
}
.avantaj-kart__slogan {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-earth);
  margin: 0 0 0.75rem;
  font-style: italic;
}
.avantaj-kart__aciklama {
  color: var(--color-text-muted);
  line-height: 1.6;
  font-size: 0.9rem;
  margin: 0;
}

/* ============================ */
/* SORU → YAKLAŞIM              */
/* ============================ */
.soru-section { padding-block: 5rem; }
.soru-section__head {
  text-align: center;
  max-width: 720px;
  margin: 0 auto 3rem;
}
.soru-eyebrow {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--color-earth);
  margin-bottom: 0.75rem;
}
.soru-section__head h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.6rem, 2.8vw, 2.1rem);
  color: var(--color-primary);
  line-height: 1.25;
  margin-bottom: 0.75rem;
}
.soru-section__head p {
  color: var(--color-text-muted);
  font-size: 1.02rem;
  line-height: 1.7;
}

.soru-list {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  max-width: 1000px;
  margin: 0 auto;
}
.soru-card {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: 16px;
  padding: 1.75rem;
  display: grid;
  grid-template-columns: 1fr 60px 1fr;
  gap: 1.25rem;
  align-items: center;
  transition: box-shadow .3s, border-color .3s;
}
.soru-card:hover {
  box-shadow: 0 14px 32px rgba(0,33,71,0.06);
  border-color: var(--color-highlight);
}

.soru-card__label {
  display: inline-block;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  margin-bottom: 0.45rem;
}
.soru-card__label--gold { color: var(--color-highlight); }

.soru-card__soru p {
  margin: 0;
  font-size: 0.95rem;
  color: var(--color-text);
  font-style: italic;
  line-height: 1.55;
}

.soru-card__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-earth);
  opacity: 0.6;
}
.soru-card__arrow svg { width: 28px; height: 28px; }

.soru-card__yaklasim {
  background: rgba(212,175,55,0.06);
  border-left: 3px solid var(--color-highlight);
  padding: 1rem 1.25rem;
  border-radius: 0 10px 10px 0;
}
.soru-card__yaklasim p {
  margin: 0;
  font-size: 0.92rem;
  color: var(--color-primary);
  line-height: 1.6;
  font-weight: 500;
}

/* ============================ */
/* FARK RAKAMLAR                */
/* ============================ */
.fark-rakamlar {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-navy-dark) 100%);
  padding-block: 5rem;
  color: #fff;
  position: relative;
  overflow: hidden;
}
.fark-rakamlar::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
}
.fark-grid {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}
.fark-metin .eyebrow--gold { margin-bottom: 1rem; }
.fark-metin h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.8rem, 3.5vw, 2.4rem);
  color: #fff;
  line-height: 1.2;
  margin-bottom: 1rem;
  font-weight: 700;
}
.fark-metin h2 span {
  color: var(--color-highlight);
  font-style: italic;
  font-weight: 500;
}
.fark-metin p {
  color: rgba(255,255,255,.72);
  font-size: 1rem;
  line-height: 1.7;
}

.fark-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}
.fstat {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 14px;
  padding: 1.5rem 1.25rem;
  transition: border-color .3s, background .3s;
}
.fstat:hover {
  border-color: var(--color-highlight);
  background: rgba(212,175,55,0.06);
}
.fstat__deger {
  display: block;
  font-family: var(--font-serif);
  font-size: 2.4rem;
  font-weight: 700;
  color: var(--color-highlight);
  line-height: 1;
  margin-bottom: 0.45rem;
  letter-spacing: -0.02em;
}
.fstat__etiket {
  color: rgba(255,255,255,.72);
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-weight: 600;
}

/* ============================ */
/* RESPONSIVE                   */
/* ============================ */
@media (max-width: 1024px) {
  .avantajlar-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 900px) {
  .fark-grid { grid-template-columns: 1fr; gap: 2rem; text-align: center; }
  .fark-metin { text-align: center; }
}
@media (max-width: 768px) {
  .soru-card { grid-template-columns: 1fr; gap: 0.75rem; }
  .soru-card__arrow { transform: rotate(90deg); justify-self: center; }
  .soru-card__arrow svg { width: 22px; height: 22px; }
}
@media (max-width: 600px) {
  .neden-hero { padding-block: 8rem 6rem; }
  .avantajlar-grid { grid-template-columns: 1fr; }
