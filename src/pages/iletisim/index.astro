---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { sirket, hizmetVerilenIller } from '../../data/sirket';

// Form için il listesi — alfabetik sırala, kullanıcıya kolay arama deneyimi
const formIlleri = [...hizmetVerilenIller].sort((a, b) => a.localeCompare(b, 'tr'));

const canonical = 'https://www.toremzemin.com/iletisim/';

// Bu sayfa için zengin LocalBusiness schema — geo, çalışma saatleri ve iletişim
// detayları burada toplanır. areaServed BaseLayout'taki orgSchema'da zaten yayınlandı,
// burada tekrar etmiyoruz (duplicate önler).
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://www.toremzemin.com/#organization',
  name: 'Torem Zemin Mühendislik',
  url: 'https://www.toremzemin.com',
  telephone: ['+90-531-659-46-36', '+90-216-379-33-10'],
  email: 'info@toremzemin.com',
  priceRange: '₺₺',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Pendik',
    addressLocality: 'Pendik',
    addressRegion: 'İstanbul',
    postalCode: '34890',
    addressCountry: 'TR',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 40.878, longitude: 29.233 },
  hasMap: 'https://www.google.com/maps/place/Pendik,+İstanbul',
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday'],
    opens: '08:30',
    closes: '18:00',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    telephone: '+90-531-659-46-36',
    email: 'info@toremzemin.com',
    areaServed: 'TR',
    availableLanguage: ['Turkish', 'English'],
  },
};
---

<BaseLayout
  title="İletişim | Ücretsiz Keşif ve Danışmanlık | Torem Zemin"
  description="Torem Zemin ile iletişime geçin. Ücretsiz keşif raporu ve proje danışmanlığı için +90 531 659 46 36 veya info@toremzemin.com"
  canonical={canonical}
  schema={localBusinessSchema}
>
  <!-- Minimal & Powerful Hero -->
  <section class="iletisim-premium-hero">
    <div class="container iletisim-premium-hero__inner">
      <div class="iletisim-premium-hero__content">
        <h1>Projenizi Birlikte<br><span>Değerlendirelim</span></h1>
        <div class="hero-phone">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012.18 1h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.16a16 16 0 006.93 6.93l1.52-1.52a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <a href="tel:+905316594636">+90 531 659 46 36</a>
        </div>
        <div class="trust-badges">
          <span class="trust-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Ücretsiz Keşif</span>
          <span class="trust-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> 24 Saat İçinde Dönüş</span>
          <span class="trust-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Teknik Uzman</span>
        </div>
      </div>
    </div>
    <div class="iletisim-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,30 C360,60 720,0 1080,30 C1260,45 1380,40 1440,35 L1440,60 L0,60 Z" fill="var(--color-bg)" />
      </svg>
    </div>
  </section>

  <Breadcrumb items={[{ label: 'İletişim' }]} />

  <!-- 60/40 Split Grid -->
  <section class="section">
    <div class="container contact-split-grid">
      
      <!-- Sol: İletişim Formu -->
      <div class="contact-form-panel">
        <h2>Ücretsiz Keşif Raporu İsteyin</h2>
        <p class="form-panel-desc">Projenizin zemin ihtiyaçlarını değerlendirelim ve size özel çözüm teklifimizi sunalım.</p>
        
        <form class="premium-form" action="https://formspree.io/f/mbdpjwzo" method="POST" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="name">Ad Soyad *</label>
              <input type="text" id="name" name="name" placeholder="Adınız Soyadınız" required />
            </div>
            <div class="form-group">
              <label for="phone">Telefon *</label>
              <input type="tel" id="phone" name="phone" placeholder="🇹🇷 +90 5XX XXX XX XX" required />
            </div>
          </div>
          
          <div class="form-row">
            <div class="form-group">
              <label for="email">E-posta</label>
              <input type="email" id="email" name="email" placeholder="ornek@firma.com" />
            </div>
            <div class="form-group">
              <label for="city">Şehir</label>
              <select id="city" name="city">
                <option value="">İl Seçiniz...</option>
                {formIlleri.map((il) => (
                  <option value={il.toLocaleLowerCase('tr')}>{il}</option>
                ))}
                <option value="diger">Listede Yok / Diğer</option>
              </select>
            </div>
          </div>
          
          <div class="form-group">
            <label for="service">Hizmet Türü</label>
            <select id="service" name="service">
              <option value="">Hizmet seçiniz...</option>
              <option value="fore-kazik">Fore Kazık</option>
              <option value="jet-grout">Jet Grout</option>
              <option value="ankraj">Ankraj & Zemin Çivisi</option>
              <option value="iksa">İksa Sistemleri</option>
              <option value="zemin-etudu">Zemin Etüdü</option>
              <option value="diger">Diğer / Emin Değilim</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="message">Proje Açıklaması *</label>
            <textarea id="message" name="message" rows="4" placeholder="Zemin yapısı, uygulanacak alan, tahmini metraj bilgisini kısaca özetleyin..." required></textarea>
          </div>
          
          <button type="submit" class="btn-submit">
            Keşif Raporu Talep Et &rarr;
          </button>
        </form>
      </div>

      <!-- Sağ: Bilgi Paneli -->
      <div class="contact-info-panel">
        
        <a href="https://wa.me/905316594636" target="_blank" rel="noopener noreferrer" class="whatsapp-btn">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          WhatsApp'tan Yazın
        </a>

        <div class="cinfo-panel-items">
          <div class="cinfo-panel-item">
            <span class="cinfo-label">Mobil</span>
            <a href="tel:+905316594636" class="cinfo-value">+90 531 659 46 36</a>
          </div>
          <div class="cinfo-panel-item">
            <span class="cinfo-label">Ofis</span>
            <a href="tel:+902163793310" class="cinfo-value">+90 216 379 33 10</a>
          </div>
          <div class="cinfo-panel-item">
            <span class="cinfo-label">E-posta</span>
            <a href="mailto:info@toremzemin.com" class="cinfo-value">info@toremzemin.com</a>
          </div>
          <div class="cinfo-panel-item">
            <span class="cinfo-label">Adres</span>
            <p class="cinfo-value">Pendik / İstanbul</p>
          </div>
          <div class="cinfo-panel-item">
            <span class="cinfo-label">Çalışma Saatleri</span>
            <p class="cinfo-value">Pzt-Cum: 08:30 - 18:00</p>
            <p class="cinfo-sub">Acil durumlar için 7/24 WhatsApp</p>
          </div>
        </div>

        <div class="cert-icons">
          <img src="/icons/iso-9001.svg" alt="ISO 9001" onerror="this.style.display='none'" />
          <img src="/icons/ce-mark.svg" alt="CE Belgeli" onerror="this.style.display='none'" />
          <img src="/icons/tsek.svg" alt="TSEK Onaylı" onerror="this.style.display='none'" />
          <div class="cert-text">Kalite &<br>Güvence</div>
        </div>
      </div>
      
    </div>
  </section>

  <!-- Google Map -->
  <section class="map-section" aria-label="Konum haritası">
    <div class="container">
      <iframe
        src="https://maps.google.com/maps?q=40.878,29.233&z=15&output=embed"
        width="100%"
        height="350"
        style="border:0; border-radius:12px; display:block;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Torem Zemin Mühendislik Konum — Pendik, İstanbul"
      ></iframe>
    </div>
  </section>

  <!-- Alt Sosyal Kanıt Şeridi -->
  <section class="social-proof-strip">
    <div class="container social-proof-grid">
      <div class="sp-item"><span>350+</span> Tamamlanan Proje</div>
      <div class="sp-item"><span>{sirket.memnuniyet}%</span> Müşteri Memnuniyeti</div>
      <div class="sp-item"><span>13+</span> Yıllık Deneyim</div>
    </div>
  </section>

</BaseLayout>

<style>
/* ── Hero ── */
.iletisim-premium-hero {
  background: var(--color-primary);
  background-image: radial-gradient(circle at 30% 50%, rgba(212,175,55,0.12) 0%, transparent 60%),
                    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 100% 100%, 40px 40px, 40px 40px;
  margin-top: -110px;
  padding-block: calc(var(--s-20) + 110px) calc(var(--s-16) + 60px);
  color: var(--color-white);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.iletisim-premium-hero__inner {
  position: relative; z-index: 2;
}
.iletisim-premium-hero__content h1 {
  font-size: clamp(2.5rem, 4vw, 4rem);
  font-weight: 700;
  margin-bottom: var(--s-6);
  line-height: 1.1;
  color: #ffffff;
}
.iletisim-premium-hero h1 span {
  color: var(--color-highlight);
}

.hero-phone {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.20);
  box-shadow: 0 8px 32px rgba(0,0,0,0.15);
  padding: 12px 28px;
  border-radius: 100px;
  margin-bottom: var(--s-8);
  flex-wrap: nowrap;
  transition: transform 0.3s ease, border-color 0.3s ease;
}
.hero-phone:hover {
  transform: translateY(-3px);
  border-color: var(--color-highlight);
}
.hero-phone svg {
  color: var(--color-highlight);
  width: 28px;
  height: 28px;
  flex-shrink: 0;
}
.hero-phone a {
  color: #fff;
  font-size: 1.4rem;
  font-weight: 700;
  text-decoration: none;
  letter-spacing: 0.04em;
  white-space: nowrap;
}

.trust-badges {
  display: flex;
  justify-content: center;
  gap: var(--s-6);
  flex-wrap: wrap;
}
.trust-badge {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
  font-size: 0.95rem;
  color: rgba(255,255,255,0.9);
}
.trust-badge svg {
  color: var(--color-highlight);
  width: 18px;
  height: 18px;
}

.iletisim-hero__wave { position: absolute; bottom: 0; left: 0; right: 0; height: 60px; z-index: 3; line-height: 0; }
.iletisim-hero__wave svg { width: 100%; height: 100%; }

/* ── 60/40 Split Grid ── */
.contact-split-grid {
  display: grid;
  grid-template-columns: 6fr 4fr;
  gap: var(--s-8);
  align-items: stretch;
  margin-top: -100px; /* Pull up to overlap hero */
  position: relative;
  z-index: 10;
}

/* ── Sol: İletişim Formu ── */
.contact-form-panel {
  background: var(--color-white);
  padding: 48px;
  border-radius: 20px;
  box-shadow: 0 24px 48px rgba(0, 21, 48, 0.06);
  border: 1px solid rgba(0,0,0,0.04);
}

.contact-form-panel h2 {
  font-size: 2.2rem;
  color: var(--color-primary);
  margin-bottom: 8px;
  font-weight: 700;
}

.form-panel-desc {
  font-size: 1.05rem;
  color: var(--color-text-muted);
  margin-bottom: var(--s-8);
}

.premium-form .form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 20px;
}

.premium-form .form-group {
  display: flex;
  flex-direction: column;
  margin-bottom: 20px;
}

.premium-form label {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 8px;
}

.premium-form input,
.premium-form select,
.premium-form textarea {
  border: 1.5px solid #e2e0db;
  border-radius: 8px;
  padding: 14px 16px;
  font-size: 1rem;
  font-family: inherit;
  transition: all 0.2s ease;
  background: var(--color-white);
}

.premium-form input:focus,
.premium-form select:focus,
.premium-form textarea:focus {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(0,21,48,0.08); /* Derived from primary */
}

.premium-form textarea {
  resize: vertical;
}

.btn-submit {
  width: 100%;
  background: var(--color-highlight);
  color: var(--color-white);
  font-weight: 700;
  font-size: 1.1rem;
  padding: 16px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
  margin-top: 8px;
}

.btn-submit:hover {
  background: var(--color-highlight);
  filter: brightness(1.1);
  transform: translateY(-2px);
  box-shadow: 0 8px 16px rgba(212,175,55,0.25);
}

/* ── Sağ: Bilgi Paneli ── */
.contact-info-panel {
  background: linear-gradient(145deg, var(--color-primary), #001530);
  border-radius: 20px;
  padding: 48px;
  color: white;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  box-shadow: 0 24px 48px rgba(0, 21, 48, 0.15);
}
.contact-info-panel::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 4px;
  background: linear-gradient(90deg, var(--color-highlight), transparent);
}

@keyframes pulse-green {
  0% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.4); }
  70% { box-shadow: 0 0 0 12px rgba(37, 211, 102, 0); }
  100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0); }
}

.whatsapp-btn {
  background: #25D366;
  color: white;
  animation: pulse-green 2s infinite;
  border-radius: 12px;
  padding: 16px 24px;
  font-weight: 700;
  font-size: 1.25rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  text-decoration: none;
  margin-bottom: 40px;
  transition: transform 0.2s;
}

.whatsapp-btn:hover {
  transform: scale(1.02);
  color: white;
}

.cinfo-panel-items {
  display: flex;
  flex-direction: column;
  gap: 24px;
  margin-bottom: 40px;
  flex: 1;
}

.cinfo-panel-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.cinfo-label {
  font-size: 0.8rem;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  letter-spacing: 0.05em;
  font-weight: 600;
}

.cinfo-value {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--color-highlight);
  text-decoration: none;
  margin: 0;
}

.cinfo-value[href]:hover {
  color: #fff;
}

.cinfo-sub {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.7);
  margin: 0;
  margin-top: 2px;
}

.cert-icons {
  display: flex;
  align-items: center;
  gap: 16px;
  padding-top: 24px;
  border-top: 1px solid rgba(255,255,255,0.1);
}

.cert-icons img {
  width: 48px;
  height: auto;
  opacity: 0.8;
}

.cert-text {
  font-size: 0.85rem;
  font-weight: 700;
  color: rgba(255,255,255,0.6);
  line-height: 1.2;
}

/* ── Harita ── */
.map-section {
  padding-bottom: var(--s-16);
}

/* ── Sosyal Kanıt Şeridi ── */
.social-proof-strip {
  background: var(--color-primary);
  padding: 32px 0;
}

.social-proof-grid {
  display: flex;
  justify-content: center;
  gap: 40px;
  flex-wrap: wrap;
}

.sp-item {
  color: rgba(255,255,255,0.8);
  font-size: 1.1rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 8px;
}

.sp-item span {
  color: var(--color-highlight);
  font-size: 1.8rem;
  font-weight: 700;
}

@media (max-width: 900px) {
  .contact-split-grid { grid-template-columns: 1fr; }
  .premium-form .form-row { grid-template-columns: 1fr; }
  .iletisim-premium-hero__content h1 { font-size: 2.5rem; }
  .trust-badges { flex-direction: column; align-items: center; gap: 12px; }
  .social-proof-grid { gap: 20px; flex-direction: column; align-items: center; }
  .contact-info-panel { padding: 32px 24px; }
}
</style>
