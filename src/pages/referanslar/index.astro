<style>
/* -------------------- Eyebrow / accent -------------------- */
.eyebrow { font-size:var(--text-sm); font-weight:700; color:var(--color-highlight); text-transform:uppercase; letter-spacing:.08em; margin-bottom:var(--s-3); }
.eyebrow--sm { font-size:var(--text-xs); margin-bottom:var(--s-2); display:inline-block; }

/* -------------------- Hero -------------------- */
.refs-hero {
  position:relative;
  margin-top:-110px;
  padding-block:calc(var(--s-20) + 110px) calc(var(--s-16) + 60px);
  background: linear-gradient(135deg, var(--color-navy-dark) 0%, var(--color-primary) 55%, var(--color-secondary) 100%);
  color:var(--color-white);
  overflow:hidden;
}
.refs-hero__photo {
  position:absolute; inset:0;
  background-image: image-set(
    url('/images/hero-sunset-1.avif') type('image/avif'),
    url('/images/hero-sunset-1.webp') type('image/webp'),
    url('/images/hero-sunset-1.png') type('image/png')
  );
  background-size:cover; background-position:center;
  opacity:.28; filter:grayscale(.3);
}
.refs-hero__gradient {
  position:absolute; inset:0;
  background:linear-gradient(135deg, rgba(0,21,48,.92) 0%, rgba(0,33,71,.78) 55%, rgba(15,52,96,.85) 100%);
}
.refs-hero__grid-pattern {
  position:absolute; inset:0; opacity:.08;
  background-image:
    linear-gradient(rgba(255,255,255,1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px);
  background-size:40px 40px;
}
.refs-hero__inner { position:relative; z-index:2; max-width:860px; text-align:center; margin-inline:auto; }
.refs-hero h1 { color:#fff; font-size:var(--text-5xl); margin-bottom:var(--s-4); line-height:1.1; font-family:var(--font-serif); font-weight:700; letter-spacing:-0.02em; }
.refs-hero .accent { color:var(--color-highlight); font-style:italic; }
.refs-hero__desc { color:rgba(255,255,255,.85); font-size:var(--text-lg); line-height:1.7; max-width:680px; margin-inline:auto; margin-bottom:var(--s-8); }

.refs-hero__trust { display:grid; grid-template-columns:repeat(2, 1fr); gap:var(--s-3); max-width:780px; margin-inline:auto; }
.htrust { text-align:left; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.12); border-radius:var(--r-lg); padding:var(--s-4) var(--s-5); display:flex; flex-direction:column; gap:4px; }
.htrust__title { font-family:var(--font-serif); font-size:var(--text-lg); font-weight:700; color:var(--color-highlight); line-height:1.3; }
.htrust__alt { font-size:var(--text-xs); color:rgba(255,255,255,.75); line-height:1.5; }

.refs-hero__wave { position:absolute; bottom:0; left:0; right:0; height:60px; z-index:3; line-height:0; }
.refs-hero__wave svg { width:100%; height:100%; }

/* -------------------- Section header -------------------- */
.section-header { text-align:center; max-width:680px; margin-inline:auto; margin-bottom:var(--s-10); }
.section-header h2 { font-size:var(--text-4xl); color:var(--color-primary); margin-bottom:var(--s-3); font-family:var(--font-serif); font-weight:700; }
.section-header p { color:var(--color-text-muted); line-height:1.65; }

.section--bg-alt { background:var(--color-bg-alt); }

/* -------------------- Case Study — Editorial Zebra Layout -------------------- */
.case-studies { display:flex; flex-direction:column; gap:var(--s-12); }

.case-study {
  display:grid; grid-template-columns: 1.1fr 1fr;
  gap:var(--s-10); align-items:center;
}
.case-study--reverse { grid-template-columns: 1fr 1.1fr; }
.case-study--reverse .case-study__visual { order:2; }

.case-study__visual {
  position:relative; aspect-ratio: 4/3;
  border-radius:var(--r-xl); overflow:hidden;
  box-shadow: 0 20px 40px rgba(0,33,71,.15), 0 8px 16px rgba(0,0,0,.06);
}
.case-study__visual img { width:100%; height:100%; object-fit:cover; transition:transform var(--t-slow); }
.case-study:hover .case-study__visual img { transform:scale(1.03); }
.case-study__sektor {
  position:absolute; top:var(--s-4); left:var(--s-4); z-index:2;
  background:var(--color-white); color:var(--color-primary);
  font-size:var(--text-xs); font-weight:700;
  text-transform:uppercase; letter-spacing:.08em;
  padding:6px 14px; border-radius:999px;
  box-shadow:var(--shadow-md);
}

.case-study__body { display:flex; flex-direction:column; gap:var(--s-4); }
.case-study__logo { height:72px; display:flex; align-items:center; }
.case-study__logo img {
  max-width:220px; max-height:72px; width:auto; height:auto; object-fit:contain;
  filter:grayscale(.15);
}
.case-study__ad {
  font-family:var(--font-serif); font-size:var(--text-4xl); font-weight:700;
  color:var(--color-primary); line-height:1.15; margin:0;
  letter-spacing:-0.015em;
}
.case-study__meta {
  font-size:var(--text-sm); color:var(--color-text-muted);
  text-transform:uppercase; letter-spacing:.08em; font-weight:600; margin:0;
}
.case-study__meta span { color:var(--color-accent); }
.case-study__hikaye {
  font-size:var(--text-base); color:var(--color-text);
  line-height:1.75; margin:0;
}
.case-study__footer {
  display:flex; align-items:center; justify-content:space-between;
  gap:var(--s-4); padding-top:var(--s-4);
  border-top:1px solid var(--color-border); flex-wrap:wrap;
}
.case-study__etiket {
  font-size:var(--text-xs); font-weight:700; color:var(--color-primary);
  background:rgba(212,175,55,.14); border:1px solid rgba(212,175,55,.35);
  padding:6px 14px; border-radius:var(--r-sm);
  text-transform:uppercase; letter-spacing:.06em;
}
.case-study__cta {
  display:inline-flex; align-items:center; gap:var(--s-2);
  font-size:var(--text-sm); font-weight:700;
  color:var(--color-highlight); text-decoration:none;
  transition:color var(--t-fast);
}
.case-study__cta:hover { color:var(--color-primary); }

/* -------------------- Logo Wall (statik grid) -------------------- */
.logo-wall {
  display:grid;
  grid-template-columns: repeat(5, 1fr);
  gap:var(--s-3);
  max-width:1100px; margin-inline:auto;
  background:var(--color-white); border:1px solid var(--color-border);
  border-radius:var(--r-xl); padding:var(--s-5);
  box-shadow:var(--shadow-sm);
}
.logo-wall__cell {
  height:88px; display:flex; align-items:center; justify-content:center;
  padding:var(--s-3); border-radius:var(--r-sm);
  transition:background var(--t-fast);
}
.logo-wall__cell:hover { background:var(--color-bg-alt); }
.logo-wall__cell picture { display:flex; align-items:center; justify-content:center; width:100%; height:100%; }
.logo-wall__cell img {
  max-width:130px; max-height:52px; width:auto; height:auto; object-fit:contain;
  filter:grayscale(1); opacity:.7; transition:all var(--t-base);
}
.logo-wall__cell:hover img { filter:grayscale(0); opacity:1; transform:scale(1.05); }
/* JPG logoların beyaz/açık-gri zeminini krem sayfa fonu üzerinde gizle —
   şeffaf PNG'ler hazırlanana kadar geçici çözüm. */
.logo-wall__cell img { mix-blend-mode:multiply; }

/* -------------------- Arşiv Arama -------------------- */
.archive-toolbar {
  display:flex; flex-direction:column; gap:var(--s-3); align-items:stretch;
  margin-bottom:var(--s-8);
  background:var(--color-white); border:1px solid var(--color-border); border-radius:var(--r-lg);
  padding:var(--s-4) var(--s-5);
}
.archive-search {
  position:relative;
  display:flex; align-items:center; gap:var(--s-2);
  background:var(--color-white); border:1px solid var(--color-border);
  border-radius:999px; padding:0 var(--s-4);
  flex:1; min-width:280px; max-width:360px;
  transition:all var(--t-fast);
}
.archive-search:focus-within {
  border-color:var(--color-highlight);
  box-shadow:0 0 0 4px rgba(212,175,55,.12);
}
.archive-search svg { color:var(--color-text-muted); flex-shrink:0; }
.archive-search input {
  flex:1; border:none; outline:none; background:transparent;
  padding:var(--s-3) 0; font-size:var(--text-sm); color:var(--color-text);
  font-family:var(--font);
}
.archive-search input::placeholder { color:var(--color-text-muted); }

/* Satır bazlı hide */
.ref-table tbody tr[data-hidden="true"] { display:none; }

/* -------------------- Müşteri İfadeleri (Testimonial) -------------------- */
.testimonial-grid {
  display:grid; gap:var(--s-5);
  grid-template-columns:repeat(auto-fit, minmax(320px, 1fr));
}
.testimonial-card {
  position:relative;
  background:var(--color-white);
  border:1px solid var(--color-border);
  border-left:4px solid var(--color-highlight);
  border-radius:var(--r-lg);
  padding:var(--s-6) var(--s-6) var(--s-5);
  display:flex; flex-direction:column; gap:var(--s-3);
  transition:transform var(--t-base), box-shadow var(--t-base);
}
.testimonial-card:hover {
  transform:translateY(-2px);
  box-shadow:0 8px 24px rgba(0,33,71,.08);
}
.testimonial-quote-mark {
  position:absolute; top:8px; right:18px;
  font-family:var(--font-serif); font-size:64px; line-height:1;
  color:var(--color-highlight); opacity:.25;
  pointer-events:none;
}
.testimonial-vurgu {
  font-family:var(--font-serif); font-size:var(--text-xl);
  line-height:1.4; color:var(--color-primary); font-weight:500;
  margin:0 0 var(--s-2) 0;
}
.testimonial-metin {
  font-size:var(--text-base); line-height:1.65; color:var(--color-text);
  margin:0;
}
.testimonial-footer {
  display:flex; align-items:center; gap:var(--s-4);
  margin-top:var(--s-3); padding-top:var(--s-4);
  border-top:1px solid var(--color-border);
}
.testimonial-logo {
  flex-shrink:0; width:56px; height:56px; border-radius:var(--r-sm);
  background:var(--color-bg); display:flex; align-items:center; justify-content:center;
  border:1px solid var(--color-border);
}
.testimonial-logo img { max-width:48px; max-height:48px; object-fit:contain; }
.testimonial-kim {
  display:flex; flex-direction:column; gap:2px;
  font-size:var(--text-sm); line-height:1.4;
}
.testimonial-kim strong { color:var(--color-primary); font-weight:700; font-size:var(--text-base); }
.testimonial-unvan { color:var(--color-text-muted); font-size:var(--text-sm); }
.testimonial-bullet { margin-inline:6px; color:var(--color-border); }
.testimonial-proje {
  margin-top:4px;
  font-size:var(--text-xs); color:var(--color-accent); font-weight:600;
  font-style:italic;
}

/* -------------------- Saha Kapsamı — Türkiye Haritası Sinematik Hero -------------------- */
.saha-hero-section {
  position:relative; overflow:hidden;
  padding-block:var(--s-16);
  color:var(--color-white);
}
.saha-hero__bg {
  position:absolute; inset:0; z-index:0;
  background:
    linear-gradient(135deg, var(--color-navy-dark) 0%, var(--color-primary) 50%, var(--color-secondary) 100%);
}
.saha-hero__bg::after {
  content:""; position:absolute; inset:0;
  background-image:
    radial-gradient(circle at 30% 40%, rgba(212,175,55,.08) 0%, transparent 50%),
    radial-gradient(circle at 70% 60%, rgba(29,110,165,.1) 0%, transparent 50%);
}
.saha-hero__overlay {
  position:absolute; inset:0; z-index:1; opacity:.06;
  background-image:
    linear-gradient(rgba(255,255,255,1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px);
  background-size:40px 40px;
}
.saha-hero__inner { position:relative; z-index:2; }

.section-header--light h2 { color:var(--color-white); }
.section-header--light h2 .accent { color:var(--color-highlight); font-style:italic; }
.section-header--light p { color:rgba(255,255,255,.82); }
.section-header--light .eyebrow { color:var(--color-highlight); }

.saha-grid {
  display:grid; grid-template-columns: minmax(0, 1.6fr) minmax(280px, 1fr);
  gap:var(--s-10); align-items:center; margin-top:var(--s-8);
}

/* Türkiye Haritası SVG — coğrafi bölge poligonları */
.saha-map { position:relative; }
.saha-map__svg { width:100%; height:auto; max-height:560px; filter:drop-shadow(0 6px 20px rgba(0,0,0,.4)); }

/* Ana Türkiye silueti — alt katman, boşlukları kapatır */
.saha-map__svg .region-base {
  fill:url(#rgBase);
  stroke:rgba(212,175,55,.55); stroke-width:1.5; stroke-linejoin:round;
  pointer-events:none;
}

/* Bölge poligonları — üst katman, ince ayrım çizgisi + hafif ton */
.saha-map__svg .region {
  fill:transparent;
  stroke:rgba(212,175,55,.28); stroke-width:0.8; stroke-linejoin:round;
  stroke-dasharray:3 3;
  transition:fill var(--t-base), stroke var(--t-base);
}
.saha-map__svg .region:hover {
  stroke:rgba(212,175,55,.7);
  stroke-dasharray:none;
  fill:rgba(212,175,55,.10);
}
.saha-map__svg .region--guneydogu {
  stroke:rgba(181,83,43,.4);
}
.saha-map__svg .region--guneydogu:hover {
  stroke:rgba(181,83,43,.75);
  fill:rgba(181,83,43,.10);
}

/* Bölge etiketleri (büyük, yarı saydam, alt katman) */
.saha-map__svg .region-label {
  font-family:var(--font-serif); font-size:13px; font-weight:600;
  fill:rgba(255,255,255,.42); text-transform:uppercase; letter-spacing:.18em;
  text-anchor:middle; pointer-events:none;
}
.saha-map__svg .region-label--earth { fill:rgba(255,217,194,.55); }

/* Öne çıkan il pin'leri (altın, küçük) */
.saha-map__svg .pin--star circle {
  fill:var(--color-highlight); stroke:rgba(255,255,255,.85); stroke-width:1.2;
  transition:transform var(--t-fast), fill var(--t-fast);
}
.saha-map__svg .pin--star:hover circle {
  transform:scale(1.4); transform-origin:center;
  fill:var(--color-white);
}
.saha-map__svg .pin__label--sm {
  font-family:var(--font); font-size:10px; font-weight:600;
  fill:rgba(255,255,255,.85); letter-spacing:.04em;
  text-anchor:middle; pointer-events:none;
}

.saha-map__svg .pin circle {
  fill:var(--color-highlight); stroke:var(--color-white); stroke-width:1.5;
  transition:fill var(--t-fast), transform var(--t-fast);
  cursor:pointer;
}
.saha-map__svg .pin:hover circle:last-of-type { fill:var(--color-white); transform:scale(1.2); transform-origin:center; }
.saha-map__svg .pin__label {
  font-family:var(--font); font-size:11px; font-weight:700;
  fill:rgba(255,255,255,.88); text-transform:uppercase; letter-spacing:.05em;
  pointer-events:none;
}
.saha-map__svg .pin__label--hq { font-size:13px; fill:var(--color-highlight); }
.saha-map__svg .pin__sublabel {
  font-family:var(--font); font-size:9px; font-weight:600;
  fill:rgba(255,255,255,.7); letter-spacing:.08em; text-transform:uppercase;
  pointer-events:none;
}
.saha-map__svg .pin--hq circle:nth-of-type(2) {
  fill:var(--color-highlight); stroke:var(--color-white); stroke-width:3;
}

/* Deprem bölgesi pin (terracotta — toprak) */
.saha-map__svg .pin--deprem circle {
  fill:var(--color-earth); stroke:#ffd9c2; stroke-width:1.5;
}
.saha-map__svg .pin--deprem:hover circle { fill:var(--color-earth-light); transform:scale(1.2); }
.saha-map__svg .pin__label--deprem { fill:#ffd9c2; font-weight:700; }

/* Ghost pinleri (ek saha ağı — "daha fazlası var" sinyali) */
.saha-map__svg .pin--ghost circle {
  fill:rgba(255,255,255,.4);
  stroke:rgba(255,255,255,.5);
  stroke-width:0.5;
}

/* Harita altı legend */
.map-legend {
  display:flex; justify-content:center; gap:var(--s-5);
  margin-top:var(--s-4); flex-wrap:wrap;
  font-size:11px; color:rgba(255,255,255,.75);
  text-transform:uppercase; letter-spacing:.06em; font-weight:600;
}
.legend-item { display:inline-flex; align-items:center; gap:var(--s-2); }
.legend-dot { display:inline-block; width:10px; height:10px; border-radius:50%; }
.legend-dot--active { background:var(--color-highlight); border:1px solid var(--color-white); width:12px; height:12px; }
.legend-dot--star   { background:var(--color-highlight); border:1px solid rgba(255,255,255,.85); width:8px; height:8px; }
.legend-dot--deprem { background:var(--color-earth); border:1px solid #ffd9c2; }
.legend-dot--ghost  { background:rgba(255,255,255,.5); }

/* Deprem Bölgesi Panel Kartı */
.saha-panel__card--deprem {
  background:linear-gradient(135deg, rgba(181,83,43,.22) 0%, rgba(181,83,43,.08) 100%);
  border-color:rgba(215,122,82,.45);
}
.saha-panel__badge--deprem { color:var(--color-earth-light); }
.deprem-iller { display:flex; flex-wrap:wrap; gap:6px; margin-top:var(--s-3); }
.deprem-il {
  font-size:11px; font-weight:600; color:#ffd9c2;
  background:rgba(181,83,43,.28); border:1px solid rgba(215,122,82,.5);
  padding:3px 9px; border-radius:var(--r-sm);
}
.saha-panel__cta strong { color:var(--color-highlight); font-weight:700; }

/* -------------------- Arşiv: Teknik Chip'leri -------------------- */
.tek-chips { display:flex; flex-wrap:wrap; gap:4px; }
.tek-chip {
  display:inline-block; font-size:11px; font-weight:600;
  padding:3px 9px; border-radius:999px;
  white-space:nowrap; line-height:1.5;
  border:1px solid transparent;
}
.tek-chip--kazik        { background:rgba(0,33,71,.08);    color:var(--color-primary);    border-color:rgba(0,33,71,.22); }
.tek-chip--iksa         { background:rgba(29,110,165,.12); color:var(--color-accent);     border-color:rgba(29,110,165,.32); }
.tek-chip--ankraj       { background:rgba(181,83,43,.12);  color:var(--color-earth);      border-color:rgba(181,83,43,.32); }
.tek-chip--iyilestirme  { background:rgba(212,175,55,.16); color:#8a6f17;                 border-color:rgba(212,175,55,.4); }
.tek-chip--test         { background:rgba(90,106,122,.12); color:var(--color-text-muted); border-color:rgba(90,106,122,.3); }
.tek-chip--default      { background:var(--color-bg-alt);  color:var(--color-text);       border-color:var(--color-border); }

/* Yan panel */
.saha-panel { display:flex; flex-direction:column; gap:var(--s-4); }
.saha-panel__card {
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.15);
  border-radius:var(--r-xl);
  padding:var(--s-5) var(--s-6);
}
.saha-panel__card--hq {
  background:linear-gradient(135deg, rgba(212,175,55,.18) 0%, rgba(212,175,55,.06) 100%);
  border-color:rgba(212,175,55,.35);
}
.saha-panel__badge {
  font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
  color:var(--color-highlight); display:inline-block; margin-bottom:var(--s-2);
}
.saha-panel__badge--muted { color:rgba(255,255,255,.6); }
.saha-panel__card h3 {
  font-family:var(--font-serif); font-size:var(--text-2xl); color:var(--color-white);
  margin:0 0 var(--s-2) 0; font-weight:700; line-height:1.2;
}
.saha-panel__card p {
  color:rgba(255,255,255,.78); font-size:var(--text-sm); line-height:1.65; margin:0;
}

.bolge-list {
  list-style:none; padding:0; margin:0;
  display:flex; flex-direction:column; gap:var(--s-3);
}
.bolge-list li {
  font-size:var(--text-sm); color:rgba(255,255,255,.85); line-height:1.55;
  padding-left:var(--s-4); position:relative;
}
.bolge-list li::before {
  content:""; position:absolute; left:0; top:8px;
  width:8px; height:8px; border-radius:50%;
  background:var(--color-highlight);
}
.bolge-list strong { color:var(--color-white); font-weight:700; }

.saha-panel__cta {
  font-size:var(--text-sm); color:rgba(255,255,255,.75); line-height:1.6;
  margin:0; padding-top:var(--s-2); border-top:1px dashed rgba(255,255,255,.15);
}
.saha-panel__cta a { color:var(--color-highlight); font-weight:700; text-decoration:underline; }

/* -------------------- FAQ (SSS) -------------------- */
.faq-container { max-width:860px; margin-inline:auto; }
.faq-list { display:flex; flex-direction:column; gap:var(--s-2); }
.faq-item {
  background:var(--color-white);
  border:1px solid var(--color-border);
  border-radius:var(--r-lg);
  transition:border-color var(--t-fast), box-shadow var(--t-fast);
}
.faq-item[open] {
  border-color:var(--color-highlight);
  box-shadow:0 4px 16px rgba(212,175,55,.1);
}
.faq-item > summary {
  list-style:none; cursor:pointer;
  display:flex; align-items:center; justify-content:space-between; gap:var(--s-4);
  padding:var(--s-4) var(--s-5);
  transition:background var(--t-fast);
}
.faq-item > summary::-webkit-details-marker { display:none; }
.faq-item > summary:hover { background:var(--color-bg); }
.faq-item__soru {
  font-family:var(--font-serif); font-size:var(--text-base); font-weight:600;
  color:var(--color-primary); line-height:1.4;
}
.faq-item__icon {
  flex-shrink:0; width:28px; height:28px; border-radius:50%;
  background:rgba(212,175,55,.12); color:var(--color-highlight);
  display:flex; align-items:center; justify-content:center;
  font-size:1.1rem; font-weight:700; transition:transform var(--t-fast), background var(--t-fast);
}
.faq-item[open] .faq-item__icon {
  transform:rotate(45deg); background:var(--color-highlight); color:var(--color-primary);
}
.faq-item__cevap {
  padding:0 var(--s-5) var(--s-5) var(--s-5);
  margin:0; font-size:var(--text-sm); color:var(--color-text);
  line-height:1.75;
}

/* -------------------- Logo Marquee (kayan şerit) -------------------- */
.logo-marquee {
  overflow:hidden; position:relative;
  padding:var(--s-6) 0;
  mask-image: linear-gradient(90deg, transparent 0, #000 80px, #000 calc(100% - 80px), transparent 100%);
  -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 80px, #000 calc(100% - 80px), transparent 100%);
}
.logo-marquee__row {
  display:flex; gap:var(--s-8); width:max-content;
  animation: logo-scroll 60s linear infinite;
}
.logo-marquee:hover .logo-marquee__row { animation-play-state:paused; }
@keyframes logo-scroll {
  from { transform:translateX(0); }
  to   { transform:translateX(-50%); }
}
.logo-chip {
  flex:0 0 auto; width:180px; height:90px;
  background:var(--color-white); border:1px solid var(--color-border); border-radius:var(--r-lg);
  display:flex; align-items:center; justify-content:center;
  padding:var(--s-3) var(--s-4);
  transition:all var(--t-fast);
}
.logo-chip:hover { border-color:var(--color-highlight); box-shadow:var(--shadow-md); transform:translateY(-2px); }
.logo-chip picture { display:flex; align-items:center; justify-content:center; width:100%; height:100%; }
.logo-chip img { max-width:140px; max-height:58px; width:auto; height:auto; object-fit:contain; filter:grayscale(1); opacity:.7; transition:all var(--t-base); }
.logo-chip:hover img { filter:grayscale(0); opacity:1; }

.logo-caption { margin-top:var(--s-6); text-align:center; font-size:var(--text-sm); color:var(--color-text-muted); line-height:1.65; max-width:720px; margin-inline:auto; font-style:italic; }


/* -------------------- Tablolar -------------------- */
.ref-table-wrap { background:var(--color-white); border:1px solid var(--color-border); border-radius:var(--r-lg); overflow-x:auto; box-shadow:var(--shadow-sm); }
.ref-table-wrap--active { border-color:var(--color-highlight); }
.ref-table { width:100%; border-collapse:collapse; font-size:var(--text-sm); }
.ref-table thead { background:var(--color-primary); color:var(--color-white); }
.ref-table th { text-align:left; padding:var(--s-3) var(--s-4); font-weight:700; font-size:var(--text-xs); text-transform:uppercase; letter-spacing:.06em; }
.ref-table td { padding:var(--s-3) var(--s-4); border-top:1px solid var(--color-border); vertical-align:top; }
.ref-table tbody tr:hover { background:var(--color-bg); }
.ref-table strong { color:var(--color-primary); font-weight:700; }

.pill { display:inline-block; padding:.2rem .6rem; border-radius:999px; font-size:var(--text-xs); font-weight:700; background:var(--color-bg); color:var(--color-text); }
.pill--active { background:var(--color-highlight); color:var(--color-primary); }

/* -------------------- Arşiv toggle -------------------- */
.archive-toggle {
  background:var(--color-white); border:1px solid var(--color-border); border-radius:var(--r-xl); overflow:hidden;
}
.archive-toggle > summary {
  list-style:none; cursor:pointer;
  display:flex; align-items:center; justify-content:space-between;
  padding:var(--s-5) var(--s-6); font-size:var(--text-base);
  background:var(--color-bg); border-bottom:1px solid var(--color-border);
  transition:background var(--t-fast);
}
.archive-toggle > summary:hover { background:var(--color-bg-alt); }
.archive-toggle > summary::-webkit-details-marker { display:none; }
.archive-toggle > summary strong { color:var(--color-primary); font-family:var(--font-serif); font-size:var(--text-lg); font-weight:700; }
.archive-toggle__sub { color:var(--color-text-muted); font-size:var(--text-sm); margin-left:var(--s-2); }
.archive-toggle__icon { font-size:1.5rem; color:var(--color-highlight); transition:transform var(--t-fast); }
.archive-toggle[open] .archive-toggle__icon { transform:rotate(180deg); }
.archive-body { padding:var(--s-8) var(--s-6); }

.year-filters { display:flex; flex-wrap:wrap; justify-content:center; gap:var(--s-2); margin-bottom:var(--s-8); }
.filter-group {
  display:flex; flex-wrap:wrap; gap:6px; align-items:center;
  width:100%;
  padding-block:var(--s-2);
}
.filter-group + .filter-group { border-top:1px dashed var(--color-border); padding-top:var(--s-3); margin-top:var(--s-2); }
.filter-label {
  font-size:var(--text-xs); font-weight:700; text-transform:uppercase; letter-spacing:.06em;
  color:var(--color-text-muted); margin-right:var(--s-2); flex-shrink:0;
}
.yf-btn, .sf-btn {
  background:var(--color-white); border:1px solid var(--color-border); color:var(--color-text);
  padding:.4rem .85rem; border-radius:999px; font-size:var(--text-sm); font-weight:600;
  cursor:pointer; transition: all var(--t-fast);
}
.yf-btn:hover, .sf-btn:hover { border-color:var(--color-highlight); color:var(--color-primary); }
.yf-btn--active { background:var(--color-highlight); border-color:var(--color-highlight); color:var(--color-primary); }
.sf-btn--active { background:var(--color-primary); border-color:var(--color-primary); color:var(--color-white); }

.year-block { margin-bottom:var(--s-8); }
.year-block[data-hidden="true"] { display:none; }
.year-title { font-family:var(--font-serif); font-size:var(--text-2xl); font-weight:700; color:var(--color-primary); margin-bottom:var(--s-4); padding-bottom:var(--s-3); border-bottom:2px solid var(--color-highlight); display:inline-block; }
.year-count { color:var(--color-text-muted); font-weight:500; font-size:var(--text-base); font-family:var(--font); }

/* -------------------- Responsive -------------------- */
@media (max-width:1024px) {
  .logo-wall { grid-template-columns: repeat(4, 1fr); }
}
@media (max-width:900px) {
  .refs-hero__trust { grid-template-columns:1fr; }
  .saha-grid { grid-template-columns:1fr; gap:var(--s-8); }
  .case-study, .case-study--reverse { grid-template-columns: 1fr; gap:var(--s-6); }
  .case-study--reverse .case-study__visual { order:0; }
  .case-study__ad { font-size:var(--text-3xl); }
  .logo-wall { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width:560px) {
  .refs-hero h1 { font-size:var(--text-3xl); }
  .case-study__ad { font-size:var(--text-2xl); }
  .logo-wall { grid-template-columns: repeat(2, 1fr); gap:var(--s-2); padding:var(--s-3); }
  .logo-wall__cell { height:68px; padding:var(--s-2); }
  .logo-wall__cell img { max-width:100px; max-height:44px; }
  .ref-table { font-size:var(--text-xs); }
  .ref-table th, .ref-table td { padding:var(--s-2) var(--s-3); }
  .ref-table th:nth-child(2), .ref-table td:nth-child(2) { display:none; }
  .archive-search { max-width:100%; }
}
</style>

<script>
  // Filtreler — Yıl, Sektör, Arama (üçü kombineli)
  const yilButtons    = document.querySelectorAll<HTMLButtonElement>('.yf-btn');
  const sektorButtons = document.querySelectorAll<HTMLButtonElement>('.sf-btn');
  const blocks        = document.querySelectorAll<HTMLElement>('.year-block');
  let activeYear:   string = 'all';
  let activeSektor: string = 'all';
  let activeQuery:  string = '';

  function uygulaFiltre() {
    const q = activeQuery.toLocaleLowerCase('tr');
    blocks.forEach((block) => {
      const yilUygun = activeYear === 'all' || block.dataset.year === activeYear;
      if (!yilUygun) {
        block.setAttribute('data-hidden', 'true');
        return;
      }
      let gorunenSatir = 0;
      const satirlar = block.querySelectorAll<HTMLElement>('tbody tr');
      satirlar.forEach((tr) => {
        const sektorUygun = activeSektor === 'all' || tr.dataset.sektor === activeSektor;
        const aramaUygun  = !q || tr.innerText.toLocaleLowerCase('tr').includes(q);
        if (sektorUygun && aramaUygun) {
          tr.removeAttribute('data-hidden');
          gorunenSatir++;
        } else {
          tr.setAttribute('data-hidden', 'true');
        }
      });
      if (gorunenSatir === 0 && (q || activeSektor !== 'all')) block.setAttribute('data-hidden', 'true');
      else block.removeAttribute('data-hidden');
    });
  }

  yilButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeYear = btn.dataset.year ?? 'all';
      yilButtons.forEach((b) => b.classList.toggle('yf-btn--active', b === btn));
      uygulaFiltre();
    });
  });

  sektorButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeSektor = btn.dataset.sektor ?? 'all';
      sektorButtons.forEach((b) => b.classList.toggle('sf-btn--active', b === btn));
      uygulaFiltre();
    });
  });

  const arama = document.getElementById('arsivSearch') as HTMLInputElement | null;
  if (arama) {
    arama.addEventListener('input', () => {
      activeQuery = arama.value.trim();
      uygulaFiltre();
    });
  }
</script>
