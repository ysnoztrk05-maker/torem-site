---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABox from '../../components/CTABox.astro';
import {
  devamEdenProjeler,
  tamamlananProjeler,
  referansIstatistik,
  teknikKategorileri,
  teknikSayilari,
  operasyonMerkezi,
  sahaKapsamiIller,
  oneCikanMusteriler,
  musteriHikayeleri,
  depremBolgesiIller,
  depremBolgesiAciklama,
  teknikParcala,
  teknikleriCikar,
  musteriIfadeleri,
  sektorler,
  sektorBul,
} from '../../data/referanslar';

const canonical = 'https://www.toremzemin.com/referanslar/';

// --- Aggregate veriler
const teknikSayacla  = teknikSayilari();
const oneCikan       = oneCikanMusteriler();
const sahaIller      = sahaKapsamiIller();

// --- SSS / AEO FAQ (AI motorları doğrudan alıntılar)
const faqListesi = [
  {
    soru: 'Torem Zemin Mühendislik hangi müşteri gruplarıyla çalışıyor?',
    cevap: 'Torem Zemin, kamu kurumları (TOKİ, İBB, Pendik Belediyesi, İPKB), holding ve gayrimenkul yatırım ortaklıkları (Emlak Konut, Rönesans Holding, Koray GYO, Ziraat GYO, Şahinler Holding, Kolin, Doğuş Grup), enerji ve endüstri yatırımcıları (Smart Güneş, Girişim Elektrik, Bakioğlu/Freshbak, Gemak, Ülker) ve lojistik-ticari yapı yüklenicileriyle çalışmaktadır.',
  },
  {
    soru: 'Torem Zemin Türkiye\'de hangi illerde saha operasyonu yürütmektedir?',
    cevap: 'Pendik/İstanbul\'daki operasyon merkezimizden 81 il geneline mühendis ve ekipman sevkiyatı yapmaktayız. Yoğun saha tecrübemiz Marmara, Ege, Akdeniz, Doğu ve Güneydoğu Anadolu bölgelerinde bulunmaktadır; ulusal enerji altyapısı ve yol projelerinde Türkiye genelinde saha hizmeti vermekteyiz.',
  },
  {
    soru: 'Torem Zemin kamu projelerinde nasıl bir deneyime sahiptir?',
    cevap: 'Rönesans Holding ortaklığında yürütülen şehir hastanesi fore kazık uygulaması, TOKİ bağlantılı Emlak Konut konut projeleri, İstanbul Proje Koordinasyon Birimi (İPKB) okul yapıları ve Derinsu-TOKİ koordinasyonunda yürütülen Uşak Millet Bahçesi öngermeli ankraj uygulaması başlıca kamu projelerimizdendir. Ayrıca Pendik Belediyesi ile sosyal tesis ve katlı otopark çalışmaları yürütülmüştür.',
  },
  {
    soru: 'Torem Zemin hangi geoteknik mühendislik hizmetlerini sunmaktadır?',
    cevap: 'Dört ana çözüm ailesinde uçtan uca hizmet veriyoruz: derin temel mühendisliği (fore kazık, mini kazık, CFA, baret), derin kazı iksa sistemleri (ankrajlı fore kazık perde, diyafram duvar, Berlin duvar, secant pile, palplans), zemin iyileştirme (jet grout, deep soil mixing, taş kolon, zemin enjeksiyonu) ve destekleme-ankraj (öngermeli, kalıcı, kaya ankrajı, zemin çivisi). TS EN 1536, TS EN 1537, TS EN 12716, TS EN 14199 ve TBDY 2018 standartlarına uygun uygulama yapılmaktadır.',
  },
  {
    soru: 'Torem Zemin enerji sektörü için hangi çözümleri uyguladı?',
    cevap: 'Smart Güneş Enerjileri için Denizli Erzin ve Çanakkale güneş enerji santrali sahalarında mini kazık temel sistemleri, Girişim Elektrik ile Artvin Hopa\'da TEİAŞ trafo merkezi fore kazık temeli, Bakioğlu Holding için fabrika zemini iyileştirme (jet grout + fore kazık), Eren Enerji ile çimento fabrikası temel uygulaması tamamlanmıştır. Rüzgar tribünü temellerinde de fore kazık uygulamaları yapılmıştır.',
  },
  {
    soru: 'Torem Zemin kaç yıldır geoteknik mühendislik alanında hizmet veriyor?',
    cevap: '2013\'ten bu yana faaliyetlerini sürdüren Torem Zemin Mühendislik, konut, endüstri, enerji, ulaşım ve kamu projelerinde geoteknik uygulamalar gerçekleştirmektedir. 350+ tamamlanan projeyle Türkiye genelinde referans portföyü oluşturulmuştur.',
  },
  {
    soru: 'Torem Zemin\'in öne çıkan (flagship) projeleri nelerdir?',
    cevap: 'Öne çıkan dört saha hikayemiz: Bakioğlu Holding & Freshbak — Manisa Salihli OSB endüstriyel yatırım (kazıklı temel + zemin iyileştirme, 2024); Emlak Konut & Öz Kıyı — İstanbul Çekmeköy kentsel dönüşüm (fore kazık, 2024); Gemak Gemi İnşaat — Yalova Altınova tersane raylı sistem (kazıklı temel, 2022); Rönesans Holding — şehir hastanesi fore kazık temeli (2017).',
  },
  {
    soru: 'Torem Zemin\'in uygulamaları hangi standartlara uygundur?',
    cevap: 'Tüm uygulamalarımız TS EN 1536 (fore kazık), TS EN 1537 (ankraj), TS EN 12716 (jet grout), TS EN 14199 (mikro kazık / mini kazık) ve Türkiye Bina Deprem Yönetmeliği (TBDY 2018) hükümlerine uygun olarak yürütülmektedir. ISO 9001:2015 kalite yönetim sistemi çerçevesinde çalışıyoruz.',
  },
  {
    soru: 'Torem Zemin deprem bölgesinde hangi uygulamaları gerçekleştirdi?',
    cevap: '6 Şubat 2023 Kahramanmaraş depremleri sonrası yeniden yapılanma sürecinde Hatay, Kahramanmaraş, Gaziantep, Adıyaman, Malatya, Mersin ve Elazığ\'da aktif saha operasyonları yürütüyoruz. Afet bölgesindeki çalışmalarımız zemin güçlendirme (jet grout, fore kazık), derin temel sistemleri ve ankrajlı iksa uygulamalarını kapsamaktadır. Bu projeler 2025\'te işlenmekte olup yeniden yapılanma takvimiyle koordineli yürütülmektedir.',
  },
  {
    soru: 'İstanbul dışında hangi illerde saha ekibi sevk edilebiliyor?',
    cevap: 'Pendik/İstanbul\'daki operasyon merkezimizden 81 il geneline mühendis ve ekipman sevki yapılmaktadır. Yedi coğrafi bölgenin tamamında — Marmara, Ege, Akdeniz, İç Anadolu, Karadeniz, Doğu ve Güneydoğu Anadolu — saha hizmeti vermekteyiz. Lokasyonunuza özel keşif talebi için iletişim formumuzu kullanabilirsiniz.',
  },
  {
    soru: 'Bölgemde Torem Zemin referans var mı, hangi müşteriyle çalıştılar?',
    cevap: 'Marmara bölgesinde İstanbul\'un her iki yakası, Kocaeli, Yalova, Bursa ve Çanakkale\'de; Ege\'de İzmir, Manisa, Aydın, Denizli ve Uşak\'ta; Akdeniz\'de Adana, Mersin ve Hatay\'da; Doğu ve Güneydoğu\'da Gaziantep, Kahramanmaraş, Adıyaman, Malatya, Elazığ ve Artvin gibi illerde kurumsal müşterilerle tamamlanmış projelerimiz bulunmaktadır. Bölgenize yakın referanslar için arşiv tablosundaki arama kutusunu kullanabilirsiniz.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqListesi.map((f) => ({
    '@type': 'Question',
    name: f.soru,
    acceptedAnswer: { '@type': 'Answer', text: f.cevap },
  })),
};

// Yıllara göre gruplama (tamamlanan)
const yillaraGoreGrup = new Map<number | string, typeof tamamlananProjeler>();
for (const r of tamamlananProjeler) {
  const key = r.yil;
  if (!yillaraGoreGrup.has(key)) yillaraGoreGrup.set(key, []);
  yillaraGoreGrup.get(key)!.push(r);
}
const yilListesi = [...yillaraGoreGrup.entries()].sort((a, b) => Number(b[0]) - Number(a[0]));

// Hero — 2 niteliksel trust signal (ölçülü, rakamı sayfa diğer yerlerinden çekiyor)
const heroTrust = [
  { baslik: `${referansIstatistik.baslangicYili}'ten Bu Yana Saha Operasyonu`, alt: 'Kamu kurumları, holdingler ve GYO\'larla sürdürülen iş birlikleri' },
  { baslik: '81 İl Kapsamında Sevkiyat Ağı',                                   alt: 'Pendik merkezli mühendis ve ekipman sevkiyatı — yedi coğrafi bölge' },
];


// Schema: ItemList (projeler) + Organization.hasOfferCatalog
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Torem Zemin Referans Projeleri',
  numberOfItems: referansIstatistik.toplamProje,
  itemListElement: [...devamEdenProjeler, ...tamamlananProjeler].slice(0, 50).map((r, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Project',
      name: r.proje,
      description: `${r.proje} — ${r.teknik} uygulaması`,
      location: { '@type': 'Place', name: r.lokasyon },
      startDate: String(r.yil),
      agent: { '@type': 'Organization', name: r.musteri },
    },
  })),
};

// Schema.org Review listesi — AEO motorları için müşteri ifadelerini doğrudan veri olarak işaretler
const reviewSchemas = musteriIfadeleri.map((t) => ({
  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: { '@type': 'Organization', name: 'Torem Zemin Mühendislik' },
  author: {
    '@type': 'Person',
    name: t.ad,
    jobTitle: t.unvan,
    worksFor: { '@type': 'Organization', name: t.firma },
  },
  reviewBody: t.metin,
  ...(t.vurgu ? { name: t.vurgu } : {}),
}));

const offerCatalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Torem Zemin Mühendislik',
  url: 'https://www.toremzemin.com',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Geoteknik Mühendislik Uzmanlık Alanları',
    itemListElement: teknikKategorileri.map((t) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: t.title,
        serviceType: 'Geoteknik Mühendislik',
        url: `https://www.toremzemin.com${t.href}`,
      },
      eligibleQuantity: { '@type': 'QuantitativeValue', value: teknikSayacla[t.slug] },
    })),
  },
};

// Matris için yoğunluk yüzdesi
const yogunluk = (deger: number) => enYukseHucre === 0 ? 0 : Math.round((deger / enYukseHucre) * 100);
---

<BaseLayout
  title={`Referanslar — ${referansIstatistik.toplamProje}+ Proje | Torem Zemin`}
  description={`Torem Zemin Mühendislik'in ${referansIstatistik.baslangicYili}'ten bu yana kamu, holding, GYO ve endüstri müşterileriyle tamamladığı ${referansIstatistik.toplamProje}+ proje — 81 il geneline saha sevki.`}
  canonical={canonical}
  schema={[itemListSchema, offerCatalogSchema, faqSchema, ...reviewSchemas]}
>
  <!-- HERO -->
  <section class="refs-hero">
    <div class="refs-hero__photo" aria-hidden="true"></div>
    <div class="refs-hero__gradient" aria-hidden="true"></div>
    <div class="refs-hero__grid-pattern" aria-hidden="true"></div>
    <div class="container refs-hero__inner">
      <p class="eyebrow">Müşteri Referansları</p>
      <h1>Birlikte Çalıştığımız <span class="accent">Kurumlar</span></h1>
      <p class="refs-hero__desc">
        Kamu kurumları, holding grupları, gayrimenkul yatırım ortaklıkları, enerji ve endüstri yatırımcılarıyla yürüttüğümüz geoteknik uygulamalardan seçilmiş referanslar.
      </p>

      <div class="refs-hero__trust">
        {heroTrust.map((t) => (
          <div class="htrust">
            <span class="htrust__title">{t.baslik}</span>
            <span class="htrust__alt">{t.alt}</span>
          </div>
        ))}
      </div>
    </div>
    <div class="refs-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,30 C360,60 720,0 1080,30 C1260,45 1380,40 1440,35 L1440,60 L0,60 Z" fill="var(--color-bg)" />
      </svg>
    </div>
  </section>

  <Breadcrumb items={[{ label: 'Referanslar' }]} />

  <!-- CASE STUDY SPOTLIGHT — Editorial zebra layout (4 flagship) -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow eyebrow--sm">Öne Çıkan Saha Hikayeleri</p>
        <h2>Seçilmiş Müşteri Projeleri</h2>
        <p>Kurumsal müşterilerimizle yürütülen dört farklı sektörden saha hikayesi — kapsam, çözüm ve sonuç.</p>
      </div>

      <div class="case-studies">
        {musteriHikayeleri.filter((h) => h.flagship).map((h, idx) => {
          const cover = h.sahaFoto ?? h.kategoriFallback ?? '/images/hero-main.jpg';
          const reverse = idx % 2 === 1;
          return (
            <article class={`case-study ${reverse ? 'case-study--reverse' : ''}`}>
              <div class="case-study__visual">
                <img src={cover} alt={`${h.ad} saha görseli`} loading="lazy" decoding="async" width="800" height="520" />
                {h.sektorEtiket && <span class="case-study__sektor">{h.sektorEtiket}</span>}
              </div>
              <div class="case-study__body">
                {h.logoBase && (
                  <picture class="case-study__logo">
                    <source srcset={`${h.logoBase}.avif`} type="image/avif" />
                    <source srcset={`${h.logoBase}.webp`} type="image/webp" />
                    <img src={`${h.logoBase}.${h.logoExt}`} alt={`${h.ad} logosu`} loading="lazy" decoding="async" width="160" height="72" />
                  </picture>
                )}
                <h3 class="case-study__ad">{h.ad}</h3>
                <p class="case-study__meta">{h.lokasyon} · <span>{h.yil}</span></p>
                <p class="case-study__hikaye">{h.hikayeUzun ?? h.hikaye}</p>
                <div class="case-study__footer">
                  <span class="case-study__etiket">{h.etiket}</span>
                  {h.projeSlug && (
                    <a href={`/projelerimiz/${h.projeSlug}/`} class="case-study__cta">
                      Projeyi Detaylı İncele →
                    </a>
                  )}
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- LOGO WALL — Statik grid (22 müşteri bir bakışta) -->
  <section class="section section--bg-alt">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow eyebrow--sm">Müşteri Portföyü</p>
        <h2>Birlikte Çalıştığımız Kurumlar</h2>
        <p>Kamu kurumları, holding grupları, gayrimenkul yatırım ortaklıkları, enerji ve endüstri yatırımcılarından bir kesit.</p>
      </div>

      <div class="logo-wall">
        {oneCikan.map((m) => (
          <div class="logo-wall__cell" title={`${m.ad} — ${m.aciklama}`}>
            <picture>
              <source srcset={`${m.logoBase}.avif`} type="image/avif" />
              <source srcset={`${m.logoBase}.webp`} type="image/webp" />
              <img src={`${m.logoBase}.${m.logoExt}`} alt={`${m.ad} logosu`} loading="lazy" decoding="async" width="160" height="64" />
            </picture>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MÜŞTERİ İFADELERİ — Testimonials (gerçek yetkili sözleri) -->
  {musteriIfadeleri.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow eyebrow--sm">Müşteri Sözleri</p>
          <h2>Birlikte Çalıştığımız Yetkililer Ne Söylüyor</h2>
          <p>Saha tecrübemize dair kurumsal müşterilerimizin yetkililerinden doğrudan ifadeler.</p>
        </div>

        <div class="testimonial-grid">
          {musteriIfadeleri.map((t) => (
            <article class="testimonial-card" itemscope itemtype="https://schema.org/Review">
              <meta itemprop="itemReviewed" content="Torem Zemin Mühendislik" />
              <span class="testimonial-quote-mark" aria-hidden="true">&ldquo;</span>
              {t.vurgu && <p class="testimonial-vurgu" itemprop="reviewBody">{t.vurgu}</p>}
              <p class="testimonial-metin">{t.metin}</p>
              <footer class="testimonial-footer" itemprop="author" itemscope itemtype="https://schema.org/Person">
                {t.logoBase && (
                  <picture class="testimonial-logo">
                    <source srcset={`${t.logoBase}.avif`} type="image/avif" />
                    <source srcset={`${t.logoBase}.webp`} type="image/webp" />
                    <img src={`${t.logoBase}.${t.logoExt ?? 'jpg'}`} alt={`${t.firma} logosu`} loading="lazy" decoding="async" width="80" height="40" />
                  </picture>
                )}
                <div class="testimonial-kim">
                  <strong itemprop="name">{t.ad}</strong>
                  <span class="testimonial-unvan">
                    <span itemprop="jobTitle">{t.unvan}</span>
                    <span class="testimonial-bullet" aria-hidden="true">·</span>
                    <span itemprop="worksFor">{t.firma}</span>
                  </span>
                  {t.proje && (
                    <span class="testimonial-proje">{t.proje}{t.yil ? ` · ${t.yil}` : ''}</span>
                  )}
                </div>
              </footer>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- SAHA KAPSAMI — Türkiye Haritası + Sinematik Hero -->
  <section class="section saha-hero-section">
    <div class="saha-hero__bg" aria-hidden="true"></div>
    <div class="saha-hero__overlay" aria-hidden="true"></div>

    <div class="container saha-hero__inner">
      <div class="section-header section-header--light">
        <p class="eyebrow eyebrow--sm">Saha Kapsamı</p>
        <h2>Pendik Merkezli, <span class="accent">81 İl Kapsamında</span></h2>
        <p>İstanbul Pendik'teki operasyon merkezimizden mühendis ve ekipman sevkiyatı yapıyoruz. Yedi coğrafi bölgenin tamamına — Marmara, Ege, Akdeniz, İç Anadolu, Karadeniz, Doğu ve Güneydoğu Anadolu — saha sevki gerçekleşmektedir. Aşağıdaki harita yoğun saha tecrübemizin coğrafi dağılımını gösterir.</p>
      </div>

      <div class="saha-grid">
        <!-- Türkiye haritası -->
        <div class="saha-map">
          <svg class="saha-map__svg" viewBox="0 0 1000 520" xmlns="http://www.w3.org/2000/svg" aria-label="Türkiye — coğrafi bölgelere göre saha kapsam haritası">
            <defs>
              <linearGradient id="rgGold" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(212,175,55,.10)" />
                <stop offset="100%" stop-color="rgba(212,175,55,.04)" />
              </linearGradient>
              <linearGradient id="rgEarth" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(181,83,43,.18)" />
                <stop offset="100%" stop-color="rgba(181,83,43,.06)" />
              </linearGradient>
              <linearGradient id="rgBase" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(212,175,55,.10)" />
                <stop offset="100%" stop-color="rgba(212,175,55,.04)" />
              </linearGradient>
            </defs>

            <!-- ANA TÜRKİYE SİLUETİ — alt katman (boşlukları doldurur, bütünlük verir) -->
            <path class="region-base" d="M 40,170 Q 55,130 110,108 L 200,92 L 285,98 L 380,90 L 490,88 L 600,90 L 720,95 L 815,108 L 870,140 L 905,180 L 920,225 L 905,270 L 870,310 L 825,335 L 790,355 L 700,365 L 600,365 L 500,360 L 420,360 L 320,358 L 240,348 L 160,335 L 90,310 L 50,280 L 35,235 L 30,195 Z" />

            <!-- 7 COĞRAFİ BÖLGE — üst katman (hafif ton farkı + sınırlar) -->
            <!-- MARMARA (sol-üst, HQ bölgesi) -->
            <path class="region region--marmara" d="M 40,170 Q 55,130 110,108 L 200,92 L 285,98 L 330,135 L 320,180 L 270,215 L 175,218 L 95,210 L 50,205 Z" />
            <!-- EGE (sol-orta-alt, kıyı şeridi) -->
            <path class="region region--ege" d="M 50,210 L 175,218 L 250,235 L 270,290 L 240,335 L 165,348 L 90,330 L 45,275 Z" />
            <!-- AKDENİZ (orta-güney) -->
            <path class="region region--akdeniz" d="M 240,335 L 320,330 L 430,318 L 530,322 L 580,340 L 540,358 L 420,358 L 320,355 L 250,350 Z" />
            <!-- İÇ ANADOLU (orta) -->
            <path class="region region--ic-anadolu" d="M 270,215 L 320,180 L 410,170 L 510,175 L 565,200 L 580,260 L 540,300 L 460,310 L 370,308 L 295,285 L 270,240 Z" />
            <!-- KARADENİZ (üst-orta-sağ şerit) -->
            <path class="region region--karadeniz" d="M 285,98 L 380,90 L 490,88 L 600,90 L 720,95 L 815,108 L 850,140 L 780,158 L 670,160 L 560,158 L 460,160 L 380,155 L 330,135 Z" />
            <!-- DOĞU ANADOLU (sağ-orta) -->
            <path class="region region--dogu-anadolu" d="M 600,160 L 720,158 L 815,160 L 880,180 L 905,225 L 870,265 L 790,260 L 700,245 L 615,225 L 580,200 Z" />
            <!-- GÜNEYDOĞU ANADOLU (sağ-alt — deprem bölgesi vurgu) -->
            <path class="region region--guneydogu" d="M 540,300 L 615,275 L 700,275 L 790,275 L 825,310 L 790,345 L 700,360 L 600,360 L 540,355 L 530,330 Z" />

            <!-- BÖLGE ETİKETLERİ -->
            <text x="180" y="160" class="region-label">MARMARA</text>
            <text x="155" y="280" class="region-label">EGE</text>
            <text x="420" y="345" class="region-label">AKDENİZ</text>
            <text x="430" y="240" class="region-label">İÇ ANADOLU</text>
            <text x="565" y="125" class="region-label">KARADENİZ</text>
            <text x="755" y="218" class="region-label">DOĞU ANADOLU</text>
