---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABox from '../../components/CTABox.astro';

const canonical = 'https://www.toremzemin.com/projelerimiz/';

const projects = [
  {
    title: 'Başakşehir Karma Yapı Kompleksi',
    category: 'Fore Kazık',
    catSlug: 'fore-kazik',
    location: 'İstanbul, Başakşehir',
    year: '2024',
    desc: '48 katlı karma yapı için 512 adet fore kazık uygulaması. Kazık çapı Ø880mm, kazık boyu 28m. 3D zemin modeli ile tasarım.',
    image: '/images/fore-kazik-saha.jpg',
    tags: ['Ø880mm', '28m Derinlik', '512 Kazık'],
  },
  {
    title: 'Pendik Metro İstasyonu İksası',
    category: 'İksa Sistemleri',
    catSlug: 'iksa',
    location: 'İstanbul, Pendik',
    year: '2023',
    desc: 'İstanbul metro hattı genişleme projesi. 14m derinliğinde ankrajlı palplanş iksa sistemi, kritik kentsel ortamda sıfır çökme toleransı.',
    image: '/images/iksa-sistemleri.jpg',
    tags: ['14m Derinlik', 'Kentsel Ortam', 'Ankrajlı'],
  },
  {
    title: 'Kocaeli Endüstriyel Depo Kompleksi',
    category: 'Jet Grout',
    catSlug: 'jet-grout',
    location: 'Kocaeli, Gebze',
    year: '2023',
    desc: 'Yüksek taşıma kapasiteli endüstriyel zemin için jet grout kolon uygulaması. 80.000 m² alan, zayıf zeminlerin iyileştirilmesi.',
    image: '/images/zemin-iyilestirme.jpg',
    tags: ['80.000 m²', 'Zemin İyileştirme', 'Jet Grout'],
  },
  {
    title: 'Bursa Toprak Kayma Güçlendirme',
    category: 'Zemin Çivisi',
    catSlug: 'zemin-civisi',
    location: 'Bursa, Nilüfer',
    year: '2024',
    desc: 'Yerleşim bölgesinde aktif toprak kayması stabilizasyonu. 240 adet zemin çivisi, shotcrete yüzey koruma, izleme sistemi.',
    image: '/images/hero-main.jpg',
    tags: ['240 Çivi', 'Shotcrete', 'İzleme Sistemi'],
  },
  {
    title: 'Kadıköy Tarihi Yapı Yenileme',
    category: 'Mini Kazık',
    catSlug: 'mini-kazik',
    location: 'İstanbul, Kadıköy',
    year: '2022',
    desc: 'Tarihi binanın temel güçlendirmesi. Sınırlı çalışma alanında Ø114mm mini kazık uygulaması, minimum titreşim.',
    image: '/images/makine-parki.webp',
    tags: ['Ø114mm', 'Tarihi Yapı', 'Mini Kazık'],
  },
  {
    title: 'Ankara OSB Sanayi Binası',
    category: 'Öngermeli Ankraj',
    catSlug: 'ankraj',
    location: 'Ankara, Sincan OSB',
    year: '2022',
    desc: 'Organize sanayi bölgesinde derin iksa ve kalıcı ankraj sistemi. 18m derinlik, 3 sıra öngermeli ankraj, 2000 kN kapasite.',
    image: '/images/ankraj.jpg',
    tags: ['18m Derinlik', '2000 kN', 'Kalıcı Ankraj'],
  },
];

const stats = [
  { num: '600+', label: 'Tamamlanan Proje' },
  { num: '20+', label: 'Yıl Sektör Deneyimi' },
  { num: '15+', label: 'Şehir' },
  { num: '100%', label: 'Müşteri Memnuniyeti' },
];
---

<BaseLayout
  title="Projelerimiz | Torem Zemin Mühendislik"
  description="Torem Zemin tamamlanan projeler — fore kazık, jet grout, iksa, ankraj ve zemin iyileştirme uygulamalarından seçme referans projeler."
  canonical={canonical}
>
  <!-- Hero -->
  <section class="projeler-hero">
    <div class="projeler-hero__bg" aria-hidden="true"></div>
    <div class="container projeler-hero__inner">
      <p class="eyebrow">Referans Projeler</p>
      <h1>Güçlü Zemin,<br><span>Sağlam Yapılar</span></h1>
      <p>600'ü aşkın tamamlanan projeden seçmeler — konut, altyapı, endüstriyel ve kamu projelerinde kanıtlanmış başarı.</p>
    </div>
    <div class="projeler-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,30 C360,60 720,0 1080,30 C1260,45 1380,40 1440,35 L1440,60 L0,60 Z" fill="var(--color-bg)" />
      </svg>
    </div>
  </section>

  <Breadcrumb items={[{ label: 'Projelerimiz' }]} />

  <!-- İstatistikler -->
  <section class="section section--dark">
    <div class="container">
      <div class="proj-stats">
        {stats.map((s) => (
          <div class="pstat">
            <span class="pstat__num">{s.num}</span>
            <span class="pstat__lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Proje Grid -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow-sm">Seçme Çalışmalar</p>
        <h2>Referans Proje Galerisi</h2>
        <p>Her proje, mühendislik mükemmeliyetine olan bağlılığımızın somut kanıtıdır.</p>
      </div>

      <!-- Filtreler -->
      <div class="proj-filters" role="group" aria-label="Proje kategorisi filtrele">
        <button class="filter-btn filter-btn--active" data-filter="all">Tümü</button>
        <button class="filter-btn" data-filter="fore-kazik">Fore Kazık</button>
        <button class="filter-btn" data-filter="jet-grout">Jet Grout</button>
        <button class="filter-btn" data-filter="ankraj">Ankraj</button>
        <button class="filter-btn" data-filter="iksa">İksa</button>
        <button class="filter-btn" data-filter="mini-kazik">Mini Kazık</button>
        <button class="filter-btn" data-filter="zemin-civisi">Zemin Çivisi</button>
      </div>

      <div class="proj-grid">
        {projects.map((p) => (
          <article class="pcard" data-cat={p.catSlug}>
            <div class="pcard__img-wrap">
              <img src={p.image} alt={p.title} loading="lazy" width="600" height="400" />
              <span class="pcard__cat">{p.category}</span>
            </div>
            <div class="pcard__body">
              <div class="pcard__meta">
                <span class="pcard__loc">
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M8 2a4 4 0 100 8A4 4 0 008 2zM8 14s-6-4-6-7a6 6 0 1112 0c0 3-6 7-6 7z"/></svg>
                  {p.location}
                </span>
                <span class="pcard__year">{p.year}</span>
              </div>
              <h3 class="pcard__title">{p.title}</h3>
              <p class="pcard__desc">{p.desc}</p>
              <div class="pcard__tags">
                {p.tags.map((t) => <span class="ptag">{t}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <div class="section container">
    <CTABox title="Projenizi Birlikte Tasarlayalım" />
  </div>
</BaseLayout>

<style>
.eyebrow { font-size:var(--text-sm); font-weight:700; color:var(--color-highlight); text-transform:uppercase; letter-spacing:.08em; margin-bottom:var(--s-3); }
.eyebrow-sm { font-size:var(--text-xs); font-weight:700; color:var(--color-highlight); text-transform:uppercase; letter-spacing:.08em; margin-bottom:var(--s-2); }

/* Hero */
.projeler-hero {
  background:linear-gradient(135deg, var(--color-navy-dark, #001530) 0%, var(--color-primary) 100%);
  margin-top: -110px;
  padding-block:calc(var(--s-20) + 110px) calc(var(--s-16) + 60px); color:var(--color-white);
  position:relative; overflow:hidden; text-align:center;
}
.projeler-hero__bg {
  position:absolute; inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 30px 30px;
  pointer-events:none; z-index:1;
}
.projeler-hero__inner { position:relative; z-index:2; max-width:640px; margin-inline:auto; }
.projeler-hero__wave { position:absolute; bottom:0; left:0; right:0; height:60px; z-index:3; line-height:0; }
.projeler-hero__wave svg { width:100%; height:100%; }
.projeler-hero h1 { color:var(--color-white); font-size:var(--text-5xl); margin-bottom:var(--s-4); }
.projeler-hero h1 span { color:var(--color-highlight); }
.projeler-hero p { color:rgba(255,255,255,.75); font-size:var(--text-lg); }

/* Stats dark band */
.section--dark { background:var(--color-primary); }
.proj-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--s-6); }
.pstat { text-align:center; padding:var(--s-6); }
.pstat__num { display:block; font-size:var(--text-4xl); font-weight:700; color:var(--color-highlight); }
.pstat__lbl { font-size:var(--text-sm); color:rgba(255,255,255,.65); text-transform:uppercase; letter-spacing:.05em; }

/* Section header */
.section-header { text-align:center; max-width:560px; margin-inline:auto; margin-bottom:var(--s-12); }
.section-header h2 { font-size:var(--text-4xl); margin-bottom:var(--s-3); }
.section-header p { color:var(--color-text-muted); }

/* Project grid */
.proj-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--s-7); }
.pcard { background:var(--color-white); border-radius:var(--r-xl); overflow:hidden; border:1px solid var(--color-border); transition:transform var(--t-base), box-shadow var(--t-base); }
.pcard:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }
.pcard__img-wrap { position:relative; aspect-ratio:3/2; overflow:hidden; }
.pcard__img-wrap img { width:100%; height:100%; object-fit:cover; transition:transform var(--t-slow); }
.pcard:hover .pcard__img-wrap img { transform:scale(1.04); }
.pcard__cat { position:absolute; top:var(--s-3); left:var(--s-3); background:var(--color-highlight); color:white; font-size:var(--text-xs); font-weight:600; padding:.2rem .7rem; border-radius:999px; text-transform:uppercase; }
.pcard__body { padding:var(--s-5); }
.pcard__meta { display:flex; align-items:center; justify-content:space-between; margin-bottom:var(--s-3); }
.pcard__loc { display:inline-flex; align-items:center; gap:var(--s-1); font-size:var(--text-xs); color:var(--color-text-muted); }
.pcard__loc svg { width:12px; height:12px; }
.pcard__year { font-size:var(--text-xs); font-weight:700; color:var(--color-accent); background:rgba(74,127,165,.1); padding:.15rem .5rem; border-radius:999px; }
.pcard__title { font-size:var(--text-lg); font-weight:700; color:var(--color-primary); margin-bottom:var(--s-3); line-height:1.3; }
.pcard__desc { font-size:var(--text-sm); color:var(--color-text-muted); line-height:1.65; margin-bottom:var(--s-4); }
.pcard__tags { display:flex; flex-wrap:wrap; gap:var(--s-2); }
.ptag { font-size:var(--text-xs); background:var(--color-bg); border:1px solid var(--color-border); color:var(--color-text-muted); padding:.2rem .55rem; border-radius:var(--r-sm); }

@media (max-width:900px) { .proj-grid { grid-template-columns:repeat(2,1fr); } .proj-stats { grid-template-columns:repeat(2,1fr); } }
@media (max-width:560px) { .proj-grid { grid-template-columns:1fr; } .proj-stats { grid-template-columns:1fr 1fr; } }

/* ── Filters ── */
.proj-filters { display:flex; gap:var(--s-3); flex-wrap:wrap; margin-bottom:var(--s-8); }
.filter-btn { padding:var(--s-2) var(--s-4); border:1.5px solid var(--color-border); border-radius:var(--r-lg); background:var(--color-white); color:var(--color-text); font-size:var(--text-sm); font-weight:500; cursor:pointer; transition:border-color var(--t-fast), background var(--t-fast), color var(--t-fast); }
.filter-btn:hover { border-color:var(--color-highlight); }
.filter-btn--active { background:var(--color-highlight); color:#1a1400; border-color:var(--color-highlight); }
.pcard { transition:opacity .22s ease, transform .22s ease; }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLElement>('.filter-btn');
  const cards      = document.querySelectorAll<HTMLElement>('.pcard');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');

      const filter = btn.dataset.filter ?? 'all';

      // Fade out all
      cards.forEach((c) => { c.style.opacity = '0.3'; c.style.transform = 'scale(0.97)'; });

      setTimeout(() => {
        cards.forEach((c) => {
          const match = filter === 'all' || c.dataset.cat === filter;
          c.style.display = match ? '' : 'none';
          if (match) requestAnimationFrame(() => { c.style.opacity = '1'; c.style.transform = 'scale(1)'; });
        });
      }, 180);
    });
  });
</script>
