---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sayfa Bulunamadı | Torem Zemin"
  description="Aradığınız sayfa bulunamadı."
  noindex={true}
>
  <div class="not-found section">
    <div class="container not-found__inner text-center">
      <div class="not-found__code" aria-hidden="true">404</div>
      <h1>Sayfa Bulunamadı</h1>
      <p>Aradığınız sayfa kaldırılmış, taşınmış veya hiç var olmamış olabilir.</p>
      <div class="not-found__actions">
        <a href="/" class="btn btn--primary">Ana Sayfaya Dön</a>
        <a href="/hizmetlerimiz/" class="btn btn--ghost">Hizmetlerimiz</a>
        <a href="/iletisim/" class="btn btn--ghost">İletişim</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
.not-found { min-height: 60vh; display: flex; align-items: center; }
.not-found__inner { max-width: 500px; margin-inline: auto; }
.not-found__code {
  font-size: 8rem;
  font-weight: 700;
  color: var(--color-highlight);
  line-height: 1;
  margin-bottom: var(--s-4);
  opacity: 0.3;
}
.not-found h1 { margin-bottom: var(--s-4); }
.not-found p  { color: var(--color-text-muted); margin-bottom: var(--s-8); }
.not-found__actions { display: flex; gap: var(--s-4); justify-content: center; flex-wrap: wrap; }
</style>
