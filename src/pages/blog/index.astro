---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { blogPosts } from '../../data/content';
---

<BaseLayout
  title="Zemin Mühendisliği Blog | Torem Zemin"
  description="Fore kazık, jet grout, ankraj ve zemin iyileştirme hakkında uzman içerikler, teknik analizler ve sektör haberleri."
>
  <section class="blog-hero">
    <div class="container blog-hero__inner">
      <p class="eyebrow">Teknik Blog</p>
      <h1>Zemin Mühendisliği<br><span>Bilgi Merkezi</span></h1>
      <p>Geoteknik mühendislik alanında uzman içerikler, teknik analizler ve sektörel güncellemeler.</p>
    </div>
  </section>

  <Breadcrumb items={[{ label: 'Blog' }]} />

  <section class="section">
    <div class="container">
      <!-- Öne Çıkan Yazı -->
      {blogPosts.length > 0 && (
        <article class="blog-featured">
          <a href={`/blog/${blogPosts[0].slug}/`} class="blog-featured__img">
            <img src={blogPosts[0].heroImage} alt={blogPosts[0].title} width="800" height="460" loading="eager" fetchpriority="high" />
            <span class="blog-featured__cat">{blogPosts[0].category}</span>
          </a>
          <div class="blog-featured__body">
            <p class="blog-featured__meta">{blogPosts[0].date} · {blogPosts[0].readTime}</p>
            <h2 class="blog-featured__title">
              <a href={`/blog/${blogPosts[0].slug}/`}>{blogPosts[0].title}</a>
            </h2>
            <p class="blog-featured__excerpt">{blogPosts[0].excerpt}</p>
            <a href={`/blog/${blogPosts[0].slug}/`} class="btn btn--primary">Yazıyı Oku</a>
          </div>
        </article>
      )}

      <!-- Diğer Yazılar -->
      <div class="blog-list">
        {blogPosts.slice(1).map((post) => (
          <article class="blog-row">
            <a href={`/blog/${post.slug}/`} class="blog-row__img">
              <img src={post.image} alt={post.title} loading="lazy" width="320" height="200" />
            </a>
            <div class="blog-row__body">
              <p class="blog-row__meta">
                <span class="blog-row__cat">{post.category}</span>
                {post.date} · {post.readTime}
              </p>
              <h2 class="blog-row__title">
                <a href={`/blog/${post.slug}/`}>{post.title}</a>
              </h2>
              <p class="blog-row__excerpt">{post.excerpt}</p>
              <a href={`/blog/${post.slug}/`} class="blog-row__link">Devamını Oku →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.eyebrow { font-size:var(--text-sm); font-weight:700; color:#E8A85A; text-transform:uppercase; letter-spacing:.08em; margin-bottom:var(--s-3); }
.blog-hero {
  background:linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  padding-block:var(--s-20) var(--s-16); color:var(--color-white); text-align:center;
}
.blog-hero__inner { max-width:640px; margin-inline:auto; }
.blog-hero h1 { color:var(--color-white); font-size:var(--text-5xl); margin-bottom:var(--s-4); }
.blog-hero h1 span { color:#E8A85A; }
.blog-hero p { color:rgba(255,255,255,.75); font-size:var(--text-lg); }

/* Öne çıkan yazı */
.blog-featured { display:grid; grid-template-columns:1fr 1fr; gap:var(--s-10); align-items:center; margin-bottom:var(--s-16); background:var(--color-white); border-radius:var(--r-xl); overflow:hidden; border:1px solid var(--color-border); box-shadow:var(--shadow-md); }
.blog-featured__img { display:block; height:100%; min-height:360px; overflow:hidden; position:relative; }
.blog-featured__img img { width:100%; height:100%; object-fit:cover; }
.blog-featured__cat {
  position:absolute; top:var(--s-4); left:var(--s-4);
  background:var(--color-highlight); color:white;
  font-size:var(--text-xs); font-weight:600; padding:.25rem .75rem; border-radius:999px; text-transform:uppercase;
}
.blog-featured__body { padding:var(--s-8); }
.blog-featured__meta { font-size:var(--text-sm); color:var(--color-text-muted); margin-bottom:var(--s-3); }
.blog-featured__title { font-size:var(--text-3xl); margin-bottom:var(--s-4); line-height:1.25; }
.blog-featured__title a { color:var(--color-primary); }
.blog-featured__title a:hover { color:var(--color-highlight); }
.blog-featured__excerpt { color:var(--color-text-muted); margin-bottom:var(--s-6); line-height:1.75; }

/* Liste */
.blog-list { display:flex; flex-direction:column; gap:var(--s-6); }
.blog-row { display:grid; grid-template-columns:280px 1fr; gap:var(--s-7); background:var(--color-white); border-radius:var(--r-lg); overflow:hidden; border:1px solid var(--color-border); transition:box-shadow var(--t-base); }
.blog-row:hover { box-shadow:var(--shadow-lg); }
.blog-row__img { display:block; overflow:hidden; }
.blog-row__img img { width:100%; height:100%; object-fit:cover; min-height:160px; transition:transform var(--t-slow); }
.blog-row:hover .blog-row__img img { transform:scale(1.04); }
.blog-row__body { padding:var(--s-6); display:flex; flex-direction:column; justify-content:center; }
.blog-row__meta { font-size:var(--text-xs); color:var(--color-text-muted); display:flex; align-items:center; gap:var(--s-3); margin-bottom:var(--s-3); }
.blog-row__cat { background:var(--color-highlight-10, rgba(200,135,58,.1)); color:var(--color-highlight); padding:.15rem .6rem; border-radius:999px; font-weight:600; }
.blog-row__title { font-size:var(--text-2xl); margin-bottom:var(--s-3); line-height:1.3; }
.blog-row__title a { color:var(--color-primary); }
.blog-row__title a:hover { color:var(--color-highlight); }
.blog-row__excerpt { font-size:var(--text-sm); color:var(--color-text-muted); line-height:1.7; margin-bottom:var(--s-4); }
.blog-row__link { font-size:var(--text-sm); font-weight:600; color:var(--color-highlight); margin-top:auto; }
@media (max-width:768px) { .blog-featured { grid-template-columns:1fr; } .blog-featured__img { min-height:220px; } .blog-row { grid-template-columns:1fr; } }
</style>
